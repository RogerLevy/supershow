\ ------------------------------------------------------------------------------
\ Cell-counted strings
\ max , size , data ...
\ ------------------------------------------------------------------------------

: lcount ( lstr - addr len )
    cell+ dup cell+ swap @ ;

: lplace ( addr len lstr - )
    cell+ 2dup ! cell+ swap move ;

: lappend ( addr len lstr - )
    cell+ >r
    r@ cell+ r@ @ +  ( addr len dest )
    over >r swap move r>
    r@ @ + r> ! ;

: l$,  ( a len - )
    dup cell+ dup , allot here lplace ;

: l$@+ ( a - a' a'' len )
    lcount 2dup cell+ + -rot ;

: lmaxsize ( lstr - n )
    @ ;

: lmaxsize! ( n lstr - )
    ! ;

: lsize ( lstr - n )
    cell+ @ ;

: lsize! ( lstr - n )
    cell+ ! ;