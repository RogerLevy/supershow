\ ==============================================================================
\ Module System
\ Replaces scope.vfx
\ ==============================================================================

0 value current-module       \ currently active module (0 = top-level / [forth])
create current-package 256 allot  \ package prefix of current module (counted string)

save-order vocabulary moduleing

only forth also moduleing definitions

\ ------------------------------------------------------------------------------
\ Module struct
\ ------------------------------------------------------------------------------

0
cell field mod.pub-wl        \ public wordlist handle
cell field mod.priv-wl       \ private wordlist handle
cell field mod.imports       \ linked list head of imports (0 = none)
cell field mod.reexports     \ linked list head of reexports (0 = none)
cell field mod.srcfile       \ zstring pointer to source file name (for collision detection)
constant /module

0
cell field imp.mod            \ pointer to imported module struct
cell field imp.next           \ next node (0 = end)
constant /imp-node

\ ------------------------------------------------------------------------------
\ Module name helpers
\ ------------------------------------------------------------------------------

create mnb 256 allot
: >bracket-name ( a u - a' u' )
    {: a u :}
    s" [" mnb place a u mnb append s" ]" mnb append
    mnb count ;

: >bare-name ( a u - a' u' )
    1 /string 1 - ;

: bracket-name? ( a u - f )
    dup 2 < if 2drop 0 exit then
    over c@ '[' = >r
    + 1- c@ ']' = r> and ;

: >module-name ( a u - a' u' )
    \ Strip brackets if present; return bare name.
    \ Lets import/import-as accept either [name] or name.
    2dup bracket-name? if >bare-name then ;

: file-module-name ( - a u )
    CurrSourceName -path -ext ;

: module-name>package ( a u - a' u' )
    \ Prefix up to last '.', or full name if no dot.
    {: a u | i :}
    u to i
    begin i while
        a i 1- + c@ '.' = if a i 1- exit then
        i 1- to i
    repeat
    a u ;

: bare-name? ( a u - f )
    \ True if string contains no path separators
    2dup s" /" search nip nip 0= >r
         s" \" search nip nip 0= r> and ;

\ ------------------------------------------------------------------------------
\ Query predicates
\ ------------------------------------------------------------------------------

: module-imported? ( mod1 mod2 - f )
    {: mod1 mod2 | node :}
    mod1 mod.imports @ to node
    begin node while
        node imp.mod @ mod2 = if -1 exit then
        node imp.next @ to node
    repeat
    0 ;

: imports-transitively? ( mod1 mod2 - f )
    {: mod1 mod2 | node :}
    mod1 mod2 module-imported? if -1 exit then
    mod1 mod.imports @ to node
    begin node while
        node imp.mod @ mod2 recurse if -1 exit then
        node imp.next @ to node
    repeat
    0 ;

: module-accessible? ( mod1 mod2 - f )
    \ is mod2 directly imported by mod1, or reexported by any of mod1's imports?
    {: mod1 mod2 | node rnode :}
    mod1 mod2 module-imported? if -1 exit then
    mod1 mod.imports @ to node
    begin node while
        node imp.mod @ mod.reexports @ to rnode
        begin rnode while
            rnode imp.mod @ mod2 = if -1 exit then
            rnode imp.next @ to rnode
        repeat
        node imp.next @ to node
    repeat
    0 ;

\ ------------------------------------------------------------------------------
\ Import list operations
\ ------------------------------------------------------------------------------

: add-import ( mod imported-mod - )
    {: mod imported-mod :}
    here
    imported-mod ,          \ imp.mod
    mod mod.imports @ ,     \ imp.next
    mod mod.imports ! ;

: add-reexport ( mod imported-mod - )
    {: mod imported-mod :}
    here
    imported-mod ,          \ imp.mod
    mod mod.reexports @ ,   \ imp.next
    mod mod.reexports ! ;

\ ------------------------------------------------------------------------------
\ Lookup / creation
\ ------------------------------------------------------------------------------

: find-module ( a u - mod | 0 )
    -path -ext >bracket-name
    forth-wordlist search-wordlist
    dup -exit
    drop >body ;

: find-module-exact ( a u - mod | 0 )
    >bracket-name
    forth-wordlist search-wordlist
    dup -exit
    drop >body ;

create qname-buf 256 allot
: find-module-qualified ( a u - mod | 0 )
    \ File paths (has path separator): strip path/ext via find-module.
    \ Dotted names (qualified, no path sep): look up exactly.
    \ Bare names: try as-is first, then package-qualified.
    {: a u | mod :}
    a u bare-name? 0= if
        a u find-module exit
    then
    a u s" ." search nip nip if
        a u find-module-exact exit
    then
    a u find-module to mod
    mod if mod exit then
    current-package c@ 0= if 0 exit then
    current-package count qname-buf place
    s" ." qname-buf append
    a u qname-buf append
    qname-buf count find-module-exact ;

: interpret-word-in ( a u wid - )
    {: wid | word[ 64 ] :}
    word[ place
    word[ count
    wid search-wordlist ( 0 | xt 1 | xt -1 )
    0= abort" Word not found in module."
    drop
    save-order
    wid 1 set-order
    word[ count parser
    restore-order
    execute ;

: does-module
    does> ( mod )
        {: m :}
        current-module m = ?exit
        current-module m module-accessible? not if
            m body>name type ."  not imported." -1 abort
        then
        bl parse m mod.pub-wl @ interpret-word-in ;

: make-module ( a u - mod )
    wordlist >r wordlist >r
    save-order also forth definitions
    >bracket-name screate here
    r> ,                    \ mod.pub-wl
    r> ,                    \ mod.priv-wl
    0 ,                     \ mod.imports
    0 ,                     \ mod.reexports
    CurrSourceName drop ,   \ mod.srcfile
    immediate
    does-module
    restore-order ;

\ ------------------------------------------------------------------------------
\ Search order management
\ ------------------------------------------------------------------------------

\ Walk linked list recursively so tail (first inserted) is processed first,
\ giving last-imported highest priority — matching live import order.

defer +mod-order

: +reexports-order ( node - )
    dup 0= if drop exit then
    dup imp.next @ recurse
    imp.mod @ +mod-order ;

: (+mod-order) ( mod - )
    dup mod.reexports @ +reexports-order
    mod.pub-wl @ +order ;

' (+mod-order) is +mod-order

: +imports-order ( node - )
    dup 0= if drop exit then
    dup imp.next @ recurse
    imp.mod @ +mod-order ;

: build-module-search-order ( mod - )
    \ Set search order: priv-wl, pub-wl, all imported pub-wls (+reexports), forth
    only forth
    dup mod.imports @ +imports-order
    dup mod.pub-wl @ +order
        mod.priv-wl @ +order
    definitions ;             \ compilation target = top of order = priv-wl

: ?module ( a u - mod )
    2dup find-module-qualified ?dup if nip nip exit then
    make-module ;

: ?module-exact ( a u - mod )
    2dup find-module-exact ?dup if nip nip exit then
    make-module ;

\ ------------------------------------------------------------------------------
\ import internals
\ ------------------------------------------------------------------------------

0 value qualified-import?
create qualified-key-buf 256 allot

: find-or-load ( name path - mod )
    \ name: registry name (bare or dotted)  path: file path to load if needed
    {: name path | mod loaded-mod :}
    name count find-module-qualified to mod
    mod 0= if
        save-order  current-module >r
        path count expanded included   \ file must call `module`
        current-module to loaded-mod
        r> to current-module  restore-order
        name count find-module-qualified to mod
        mod 0= if
            loaded-mod ?dup 0= abort" Imported file did not declare a module."
            to mod
        then
    then
    mod ;

: check-import ( mod - mod )
    dup current-module = abort" Tried to import current module into itself."
    dup current-module imports-transitively? if abort" Circular import detected." then ;

: do-import ( mod - )
    current-module over module-imported? not if
        current-module over add-import
    then
    drop
    get-current >r
    current-module build-module-search-order
    r> set-current ;

\ ------------------------------------------------------------------------------
\ misc
\ ------------------------------------------------------------------------------

: skip-empty  begin bl preparse nip 0= while refill drop repeat ;
: /order  only forth definitions ;

\ ==============================================================================

only forth definitions also moduleing

\ ------------------------------------------------------------------------------
\ Diagnostics
\ ------------------------------------------------------------------------------

: module-imports. ( mod - )
    {: mod | node :}
    mod body>name type ."  imports:" cr
    mod mod.imports @ to node
    begin node while
        ."   " node imp.mod @ body>name type cr
        node imp.next @ to node
    repeat ;


: module-reexports. ( mod - )
    {: mod | node :}
    mod body>name type ."  reexports:" cr
    mod mod.reexports @ to node
    begin node while
        ."   " node imp.mod @ body>name type cr
        node imp.next @ to node
    repeat ;


: module. ( mod - )
    cr dup module-imports. cr module-reexports. ;

\ ------------------------------------------------------------------------------
\ Core words
\ ------------------------------------------------------------------------------

redef : module ( - )
    qualified-import? if
        0 to qualified-import?
        CurrSourceName -ext qualified-key-buf place
        qualified-key-buf count 2dup module-name>package current-package place
        bl preparse bracket-name? if bl parse 2drop then
        ?module-exact
    else
        \ peek at next token; if [bracketed], use it; otherwise use filename
        bl preparse bracket-name? if
            bl parse >bare-name    \ consume token, strip brackets
        else
            file-module-name
        then
        2dup module-name>package current-package place
        ?module
    then
    to current-module
    current-module build-module-search-order ;

redef : global ( - )
    only forth definitions  0 to current-module ;

: ^ ( - <name> )
    {: | name[ 256 ] path[ 256 ] mod :}
    bl parse >module-name name[ place
    name[ count bare-name? if
        s" %idir%/" path[ place
        name[ count path[ append
        s" .vfx" path[ append
        path[ count expanded fileexists? 0= if
            name[ count path[ place
        then
    else
        name[ count path[ place
        path[ count s" .vfx" strin? 0= if s" .vfx" path[ append then
    then
    name[ count find-module-qualified to mod
    mod 0= if
        save-order current-module >r
        path[ count expanded included
        current-module to mod
        r> to current-module restore-order
        mod 0= if abort" ^ : file did not declare a module." then
    then
    mod dup to current-module
    ." Current module: " current-module .name cr
    build-module-search-order ;

redef : public ( - )
    current-module ?dup 0= abort" PUBLIC : No current module"
    dup mod.pub-wl @ set-current
    dup mod.priv-wl @ +order        \ keep private in search order
    drop ;

redef : private ( - )
    current-module ?dup 0= abort" PRIVATE : No current module"
    mod.priv-wl @ set-current ;

redef : forth-public ( - )
    current-module ?dup 0= abort" FORTH-PUBLIC : No current module"
    {: mod :}
    only forth
    mod mod.imports @ +imports-order
    mod mod.pub-wl @ +order
    mod mod.priv-wl @ +order
    forth-wordlist set-current ;

\ Single-line private: temporarily go private, compile one line, restore
: || ( - )
    get-current >r
    current-module ?dup if
        mod.priv-wl @ set-current
    else
        -1 abort" || : No current module"
    then
    0 parse evaluate
    r> set-current ; immediate

\ ------------------------------------------------------------------------------
\ import / reexport
\ ------------------------------------------------------------------------------

: import ( - <[name]> )
    {: | name[ 256 ] path[ 256 ] mod :}
    bl parse >module-name name[ place
    \ Resolve file path separately; name[ stays clean for registry lookup.
    name[ count bare-name? if
        s" %idir%/" path[ place
        name[ count path[ append
        s" .vfx" path[ append
        path[ count expanded fileexists? 0= if
            name[ count path[ place   \ no %idir% file; use name as path fallback
        then
    else
        name[ count path[ place
    then
    name[ path[ find-or-load check-import to mod
    mod do-import ;

: import-as ( - <[name]> <[localname]> )
    {: | name[ 256 ] cmd[ 256 ] key[ 256 ] saved-key[ 256 ] mod save-qi :}

    \ parse source module name
    bl parse >module-name name[ place

    \ Check if already loaded by predicting the qualified key
    name[ count expanded normalize -ext key[ place
    key[ count find-module-exact to mod

    mod 0= if
        \ load file with qualified naming (full srcfile path as key)
        \ save/restore reentrancy state in case we're nested inside another import-as
        qualified-import? to save-qi
        qualified-key-buf count saved-key[ place
        0 qualified-key-buf c!
        -1 to qualified-import?
        save-order  current-module >r
            name[ count expanded included   \ module populates qualified-key-buf
        r> to current-module  restore-order
        qualified-key-buf count key[ place   \ copy into local before restoring
        save-qi to qualified-import?
        saved-key[ count qualified-key-buf place

        key[ c@ 0= abort" Imported file did not declare a module."
        key[ count find-module-exact to mod
    then

    \ find and register the module
    mod check-import to mod
    mod do-import

    \ create [localname] alias in private wordlist via aka
    bl parse >module-name >bracket-name   \ normalize then re-bracket for alias
    get-current >r
    current-module mod.priv-wl @ set-current
    also forth                              \ ensure forth-wordlist is searchable for aka
    s" aka " cmd[ place
    cmd[ append                          \ [localname] first
    s"  " cmd[ append
    key[ count >bracket-name cmd[ append \ then existing [qualified-name]
    cmd[ count evaluate
    previous
    r> set-current ;

: reexport ( - <[name]> )
    {: | mod a u :}
    bl parse 2dup bracket-name? 0= abort" REEXPORT: expected [module-name]"
    2dup to u to a
    >bare-name find-module-qualified to mod
    mod 0= if
        \ Fall back to searching current module's private wl (for import-as aliases)
        a u current-module mod.priv-wl @ search-wordlist
        dup 0= abort" Module not found for reexport."
        drop >body to mod
    then
    current-module mod module-accessible? not if abort" Can only reexport an accessible module." then
    current-module mod add-reexport ;

: import: ( - )
    begin skip-empty  bl preparse s" ;" s= if bl parse 2drop exit then import again ;

: reexport: ( - )
    begin skip-empty  bl preparse s" ;" s= if bl parse 2drop exit then reexport again ;

\ ------------------------------------------------------------------------------
\ [forth] module  (special: always available, public wl = forth-wordlist)
\ ------------------------------------------------------------------------------

redef : [forth] ( <word> - )
    bl parse forth-wordlist interpret-word-in ; immediate

\ ------------------------------------------------------------------------------
\ Include order preservation (same as scope.vfx)
\ ------------------------------------------------------------------------------

create _inc-buf 256 allot
: ?idir-path ( a u - a' u' )
    \ Bare name (no path sep)? Probe %idir%/name.vfx; return path if found.
    2dup bare-name? if
        s" %idir%/" _inc-buf place
        2dup _inc-buf append
        s" .vfx" _inc-buf append
        _inc-buf count expanded fileexists? if
            2drop _inc-buf count exit
        then
    then ;

\ Package save stack (handles nested includes)
16 constant max-pkg-depth
create pkg-save-stack max-pkg-depth 256 * allot
0 value pkg-sp

: push-package  current-package count  pkg-save-stack pkg-sp 256 * +  place  pkg-sp 1+ to pkg-sp ;
: pop-package   pkg-sp 1- to pkg-sp  pkg-save-stack pkg-sp 256 * + count  current-package place ;

redef : include
    current-module >r  push-package
    save-order getPathSpec ?idir-path included restore-order
    pop-package  r> to current-module ;
redef : require
    current-module >r  push-package
    save-order getPathSpec ?idir-path required restore-order
    pop-package  r> to current-module ;
redef : included
    current-module >r  push-package
    save-order included restore-order
    pop-package  r> to current-module ;

restore-order
