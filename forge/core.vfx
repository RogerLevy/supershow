: e -1 abort" e is not defined" ;
: failed? ; immediate
: redef ( - )
    warnings? >r postpone -warnings 0 parse evaluate r> to warnings? ;

\ =============================================================================
\ File error fixes (VFX returns -1 instead of actual OS error)
\ =============================================================================

extern DWORD GetLastError();
: ?os-error ( n - n' ) if GetLastError else 0 then ;

redef : create-file ( c-addr u fam -- fileid ior )
    create-file ?os-error ;

redef : open-file ( c-addr u fam -- fileid ior )
    open-file ?os-error ;

redef : close-file ( fileid -- ior )
    close-file ?os-error ;

redef : read-file ( c-addr u1 fileid -- u2 ior )
    read-file ?os-error ;

redef : write-file ( c-addr u fileid -- ior )
    write-file ?os-error ;

redef : delete-file ( c-addr u -- ior )
    delete-file ?os-error ;

redef : rename-file ( c-addr1 u1 c-addr2 u2 -- ior )
    rename-file ?os-error ;

redef : resize-file ( ud fileid -- ior )
    resize-file ?os-error ;

redef : reposition-file ( ud fileid -- ior )
    reposition-file ?os-error ;

redef : file-size ( fileid -- ud ior )
    file-size ?os-error ;

redef : file-position ( fileid -- ud ior )
    file-position ?os-error ;

synonym aka synonym
aka not 0=
: udup  over swap ;
: >zpad  ( a n - z$ ) pad zplace pad ;
: >pad   ( a n - $ ) pad place pad ;
: $+     ( $ a n - $ ) rot dup >r append r> ;
: ?exit  ( n - ) s" if exit then" evaluate ; immediate
: -exit  ( n - ) s" 0= if exit then" evaluate ; immediate 
aka cd cwd
: 2+  ( x y x y - x' y' ) rot + >r + r> ;
: 2-  ( x y x y - x' y' ) rot swap - >r - r> ;
: 2max rot max >r max r> ;
: 2min rot min >r min r> ;
: 2clamp 2swap 2>r 2min 2r> 2max ;
: 2abs  abs swap abs swap ;
aka d@ 2@
aka d! 2!
: x@ @ ;
: y@ cell+ @ ;
: x! ! ;
: y! cell+ ! ;
redef : 2*  rot * >r * r> ;
redef : 2/  rot swap / >r / r> ;
redef : 2@ dup @ swap 4 + @ ;
redef : 2! dup >r 4 + ! r> ! ;
aka n>f s>f
: 2s>f swap s>f s>f ;
aka 2n>f 2s>f
aka f>n f>s
: 2+! dup >r 4 + +! r> +! ;
: 2, swap , , ;
: 2mod rot swap mod >r mod r> ;
: 2negate swap negate swap negate ;
: for ( n - ) s" 0 ?do" evaluate ; immediate
\ aka next loop     \ shadowed by dltree.vfx
\ aka unnext unloop
: @+  ( a - a' n ) dup cell+ swap @ ;
: c@+ ( a - a' n )  dup 1 + swap c@ ;
: 4@ @+ swap @+ swap @+ swap @ ;
: 4! >r 2swap r@ 2! r> 8 + 2! ;
: lc  ( n - n ) dup 'A' 'Z' within? if $20 or then ;
: lctype  ( a n - ) for c@+ lc emit loop drop ;      
: pagealign ( - )  here $ff and 256 swap - allot ;
: aligned-page ( - <name> )  pagealign here $100 allot&erase constant ;
: ?execute ( xt - ) ?dup -exit >r ;
: & ( <word> - a ) ' >body ;
: [&] ( <word> - a ) & postpone literal ; immediate
aka << lshift
aka >> rshift
: c>f  dup 24 >> s>f 255e f/ ;
: (hword)  base @ >r hex  0 <# #s 'x' hold '0' hold #> r> base ! ;
: h. ( n - ) (hword) type space ;
: (word)  base @ >r decimal  0 <# #s #> r> base ! ;
: #. ( n - ) (word) type space ;
: ]#  ] postpone literal ;
: ?literal  state @ if postpone literal then ;
: valof  ' >body ?literal s" @" evaluate ; immediate
: *zbuf  dup 1 + allocate throw >r r@ zplace r> ;
: ftrunc4 ( f - f ) 10000e f* ftrunc 10000e f/ ;
: fround4 ( f: n - f: n' ) 10000e f* fround 10000e f/ ;
: (tf.) fround4 -1 (f.) ;
: k  7 rpick ;

: creplace ( a len from-char to-char - )
    {: a len from-char to-char :}
    len -exit
    a len bounds do  
        i c@ from-char = if  to-char i c!  then  
    #1 +loop  
; 

: screate ( name len - ) ( - a )
    {: | name$[ 256 ] :}
    name$[ place   
    name$[ count bl '-' creplace
    name$[ $create 
;

include %idir%/../textmode/textmode-tools.vfx

: IP>NFA        \ addr -- nfa
    \ Attempt to move backwards from an address within a definition to
    \ the relevant NFA.  If not found, return temporary string containing
    \ the given address in hex.
    {: | fb[ 256 ] :}
    dup (word) fb[ place
    \ 13 -			\ NFA (count byte) is at least this far back
    500 for
        dup InForth? 0= if drop  fb[  unloop exit then
        dup name? if unloop exit then
        1-
    loop 
    drop  fb[ ; 

: A>NFA        \ addr -- nfa
    \ Attempt to move backwards from an address within a definition to
    \ the relevant NFA.  If not found, return temporary string containing
    \ the given address in hex.
    {: | fb[ 257 ] :}
    dup (word) fb[ place  0 fb[ count + c!
    unalign 
    13 -			\ NFA (count byte) is at least this far back
    500 for
        dup InForth? 0= if drop  fb[  unloop exit then
        dup name? if unloop exit then
        1-
    loop 
    drop  fb[ ; 

: >name ( xt -- nfa|xt )
    a>nfa ;

: >zname ( xt -- znfa|xt )
    >name 1 + ;

: .name ( a - )
    \ Smart name print. (Slow!)
    dup body> inForth? if
        14 push-foreground
        body> >name count lctype space
        pop-attribute
    else . then ;

\ --- Strout ---

0 value str
0 value len
variable cbuf

: +str ( a len - ) >r str len + r@ move r> +to len ;
: strout-emit ( c ? - ) drop  cbuf c!  cbuf 1 +str ;
: strout-type ( a len ? - ) drop  +str ;
: strout-cr ( ? - ) drop  10 cbuf c!  cbuf 1 +str ;

create strout-vectors
    ' drop ,          \ 0
    ' drop ,          \ 1
    ' drop ,          \ 2
    ' drop ,          \ 3
    ' drop ,          \ 4
    ' drop ,          \ 5
    ' drop ,          \ 6
    ' drop ,          \ 7
    ' drop ,          \ 8
    ' strout-emit ,   \ 9  - emit
    ' drop ,          \ 10
    ' strout-type ,   \ 11 - type
    ' strout-cr ,     \ 12 - cr
    ' drop ,          \ 13
    ' drop ,          \ 14
    ' drop ,          \ 15
    ' drop ,          \ 16
    ' drop ,          \ 17
    ' drop ,          \ 18
    ' drop ,          \ 19
    ' drop ,          \ 20
    ' drop ,          \ 21
    ' drop ,          \ 22
    ' drop ,          \ 23
    ' drop ,          \ 24

create strout-dev   0 , strout-vectors ,

: strout ( xt a - a len )  \ user-supplied buffer
    str len {: xt a _str _len | __str __len :}
    a to str   0 to len
    op-handle @ >r
    strout-dev op-handle !
    xt catch
    r> op-handle ! 
    str to __str  len to __len 
    _str to str   _len to len 
    throw 
    __str __len ;

: .ip ( a - )
    dup body> inForth? if
        11 push-foreground
        dup ip>nfa dup count lctype
        name> - ?dup if
            ." (+" (.) type  ." ) "
        else
            space
        then
        pop-attribute
    else . then ;

: body>name ( a - name len ) body> >name count ;

: .data ( a - )
    dup body> inForth? if
        12 push-foreground
        dup body>name lctype
        dup a>nfa name> >body - ?dup if
            dup 0 > if 
                ." (+" (.) type  ." ) "
            else
                .
            then
        else
            space
        then
        pop-attribute
    else . then ;

: f>sf  ( f:n - n ) 0 sp@ sf! ;
: sf>f  ( n - f:n ) sp@ sf@ drop ;

: :now  :noname  ';' parse evaluate  postpone ;  execute ;

: link ( list - )
    \ backward-linked list (chain)
    here  over @ ,  swap ! ;

: do-chain ( chain - )
    begin @ ?dup while dup cell+ @ execute repeat ;

: _.s
    depth 12 min {: d :}
    d 0< -4 ?throw
    3 push-attribute
    d if ."  (" depth (.) type ." ) " then
    d if
        d 0 ?do d 1 - i - pick . loop 
    else
        ." Data-stack empty! "
    then
    \ ." ] "
    pop-attribute ;

: .s  _.s cr ;

: _f.s 
    fdepth {: d :}
    d 0< -400 ?throw
    3 push-attribute
    ."   F:[ " 
    d if
        d 0 ?do d 1 - i - fpick f. loop 
    else
        ." Float-stack empty! "
    then
    ." ] "
    pop-attribute ;

: f.s  _f.s cr ;

: rs ( - ) reset-stacks ;

: ending ( a len c - a' len' )
   >r begin  2dup r@ scan
      ?dup while  2swap 2drop  #1 /string
   repeat  r> 2drop ;

: slashes ( a len - a len )  
    2dup '/' '\' creplace ;

: -path ( a len - a len' ) slashes  '\' ending  0 max ;
: -ext  ( a len - a len' ) 2dup '.' scan nip - ;

: <scan ( a len c - a len' )
    {: a len c :}
    a len 
    2dup bounds swap 1 - do
        i c@ c = if 1 - exit then 
        1 - 
    -1 +loop ;

aka parse' parse

: parse ( n - a len )
    parse-word ;
: preword ( - pad )
    >in @ bl parse rot >in ! >pad ;
: preparse ( n - a len )
    >in @ swap parse-word rot >in ! ;

: ?constant ( n - <name> ) ( - n )
    preword find nip if drop ' drop else constant then ;
: ?fconstant ( n - <name> ) ( - n )
    preword find nip if fdrop ' drop else fconstant then ;
: ?value ( n - <name> ) ( - n )
    preword find nip if drop ' drop else value then ;

: lastbody ( - a ) last @ ctrl>nfa name> >body ;

: >lowercase ( a c - a c ) 2dup bounds ?do i dup c@ lc swap c! loop ;
: >uppercase ( a c - a c ) 2dup upper ;

: jumptable ( - <name> ) ( ... n - ... ) 
    create does> swap cells + @ ?execute ;

: h.8 ( n - )
    base @ hex  swap
    0 <# # # # # # # # # #> type
    base !
    space ;

: (.rs) ( a -- )
    {: rp :}
    3 push-attribute
    ."  R:[ " 
    \ Walk from bottom (r0) to top (rp@), going downward
    rp r0 @ over 9 cells + min  ?do
        i @ .name                    \ Print return address
    cell negate +loop
    ." ] "
    pop-attribute ;

: .rs ( -- )
    rp@ (.rs) cr ;

: clamp ( n lo hi - n' ) >r max r> min ;

: umod ( n n -- n' ) 2dup mod dup 0< if + else nip then nip ;

aka se" s\"        \ " \ syntax highlight guard

: walk-order ( xt - ) ( thread# nfa - f )
    {: xt :}
    get-order for
        cr dup .name 
        xt swap WalkWordList
    loop ;
    
: .abort ( err a:msg len:msg - )
    rot if
        4 push-attribute
        \ ." ABORT: " 
        type cr
        rp@ cell+ (.rs) cr
        .s
        pop-attribute
        c" " 'AbortText !
        \ EditOnError
        -2 throw
    else
        2drop
    then ;

: abort"
    ?comp
    postpone s"         \ syntax-highlighting guard: "
    postpone .abort  discard-sinline
; immediate

: magic-id ( - <name> <id> )
    create here 0 ,
    bl parse drop @ swap !
    does> @ ;

: .- ( n - ) (.) type ;

: .comma ( n - )
    \ Format number with commas e.g. 100000000 -> 100,000,000
    \ By Claude Sonnet 4
    dup 0< if ." -" abs then
    dup 1000000000 >= if
        dup 1000000000 / .- ." ,"
        1000000000 mod
        dup 1000000 / 0 <# # # # #> type ." ,"
        1000000 mod
        dup 1000 / 0 <# # # # #> type ." ,"
        1000 mod 0 <# # # # #> type
    else dup 1000000 >= if
        dup 1000000 / .- ." ,"
        1000000 mod
        dup 1000 / 0 <# # # # #> type ." ,"
        1000 mod 0 <# # # # #> type
    else dup 1000 >= if
        dup 1000 / .- ." ,"
        1000 mod 0 <# # # # #> type
    else
        .-
    then then then ;

: interpret-string ( a len - res )
    to-source
    -1 to source-id
    0 >in !
    'SourceFile off
    ['] interpret catch 
    dup 0= if
        -1 >in !  \ prevent erroneous source text display on later errors
    then ;

: strip-exe   \ c-addr u -- 'c-addr 'u
  dup 0= if  exit  then
  bl skip               \ c-addr u --
  dup if
    over c@ [char] " = if
      1 /string
      [char] " scan
    else
      bl scan
    then
    1 /string bl skip
  then
;

: strin? ( haystack len needle len - flag ) search nip nip ;    
: .:  postpone (s") 0 parse $, postpone type postpone cr ; immediate

: toggle dup @ 0= swap ! ;

variable old-dp
: temp{ ( - )  here old-dp ! ;
: temp} ( - a len )  old-dp @ here over -  old-dp @ dp ! ;
    
: $@+ ( a - a' str len ) count 2dup + -rot ;
: $, ( a len - ) dup >r    here place    r> 1 + allot ;

: evaluator ( code len <name> - )
    create $, immediate does> count evaluate ;

: indent ( n - ) 4 * spaces ;
: cstring ( <name> - ) create 256 allot&erase ;
  
cstring lastword
: find  ( $ - c-addr 0 | xt 1 | xt -1 ) dup count lastword place  find ;
: sfind ( a len - c-addr 0 | xt 1 | xt -1 ) {: | name[ 256 ] :} name[ place name[ find ;
: save-next-word  preword count lastword place ;
: '  save-next-word  ' ;
: [']  save-next-word  postpone ['] ; immediate    
: locate  save-next-word locate ;
: see  save-next-word see ;
: show  save-next-word show ;
: aka  save-next-word aka ;

aka save-exe save

: s= compare 0= ;
: z$= zcount rot zcount s= ;
: ext? ( fn len ext len - flag ) 2swap '.' ending s= ;
: ['] ( <name> - xt ) state @ if postpone ['] else ' then ; immediate
: u+  rot + swap ;

\ Search order stack
here dup 65535 and 65536 swap - allot 
constant search-order-stack 
variable sosp   search-order-stack sosp ! \ object stack pointer

: sos-push ( ? - ) sosp @ !  4 sosp w+! ;
: sos-pop ( - ? ) -4 sosp w+!  sosp @ @ ;
: sos-pushes ( ... n - ) dup >r for sos-push loop r> sos-push ;
: sos-pops ( - ... n ) sos-pop dup >r for sos-pop loop r> ;
: save-order ( - ) get-order sos-pushes get-current sos-push ;
: restore-order ( - ) sos-pop set-current sos-pops set-order ;

: >shout ( a len - ) 
    2>r save-order 2r>
    ['] evaluate catch ?dup if .throw 2drop then
    restore-order ;

: shout" ( - <string>" )
    \ Late-bound execution; don't care if it succeeds.  
    \ Search order is preserved.
    \ Caller cannot pass params in directly.
    state @ if
        postpone (s") ", postpone >shout
    else
        '"' parse >syspad >shout
    then ; immediate

: cutoff ( a len char - a' len' ) >r 2dup r> scan nip - ;
: move, ( a len - ) dup >r here swap move r> allot ;

: continuation: ( <name> - ) ( ... xt - ... )
    create immediate
    here 0 ,
    :noname swap !
    postpone r>
    does> 
        lvcount @ abort" Can't use locals inside continuations."
        @ compile, ;

errdef err_redefined "Word redefined"

\ Redefine redefhook: protection from unintentional redefinitions (use REDEF)
: vfxland-redefhook
    6 push-attribute 
        LastNameFound .name ." Word was redefined. (Precede with REDEF to override.)" 
    pop-attribute
    err_redefined throw ;

' vfxland-redefhook is redefhook  

: evaluate-lines ( addr len -- )
    {: addr len | line-start line-len pos :}
    addr to line-start
    0 to pos
    begin
        pos len < while
        addr pos + c@ 10 = if           \ Found newline
            addr pos + line-start - to line-len
            line-len if
                \ line-start line-len type cr
                line-start line-len evaluate
            then
            addr pos + 1+ to line-start \ Start of next line
        then
        1 +to pos
    repeat
    \ Handle last line if no trailing newline
    addr pos + line-start - to line-len
    line-len if
        line-start line-len type cr
        line-start line-len evaluate
    then ;

\ =============================================================================
\ Extend INTERPRET to track last word interpreted
\ =============================================================================

redef : (interpret)	\ --
    page-check
    begin  
        ?stack 
        parse-name 
        2dup lastword place
        dup
    while
        parser execute
    repeat
    2drop ;

' (interpret) is interpret

\ =============================================================================
\ Float-color utilities
\ =============================================================================

redef code sf-!	\ addr -- addr' ; F: -- f
\ *G Places the 32 bit float at addr on the float stack, and
\ ** increments addr by 4.
\ ** NDP387.FTH only.
  add   ebx, # -4		\ update address
  fstp  float 0 [ebx]   \ store at addr
  fnext,
end-code

: 4f@  sf@+ sf@+ sf@+ sf@ ; 
: 4f!  4 cells + sf-! sf-! sf-! cell- sf! ;

: .evaluate ( a len - )
    2dup type cr evaluate ;

: sandbox ( - ) 
    only previous previous previous ;

errdef err_bailed "Word bailed."
: bail ( - ) 
    err_bailed throw ;

\ =============================================================================
\ Custom prompt
\ =============================================================================

: .engineer-prompt ( - )
  ."  ok " 
  depth if _.s then
  fdepth if _f.s then
  depth -> SbDepth
  base @ -> SbBase
  context @ -> sbContext
  current @ -> sbCurrent
;

['] .engineer-prompt is .prompt 

\ =============================================================================
\ Bitfield
\ =============================================================================

: reset-bit ( bit# addr - )
    over 3 rshift +      \ addr + bit#/8 = byte address
    swap 7 and           \ bit# mod 8 = bit position
    1 swap lshift invert
    over c@ and swap c! ;

redef : set-bit ( bit# addr - )
    over 3 rshift +
    swap 7 and
    1 swap lshift
    over c@ or swap c! ;

: store-bit ( flag bit# addr - )
    rot if set-bit else reset-bit then ;

redef : test-bit ( bit# adr - b )
    >r 8 /mod ( bit-ofs byte-ofs )
    r> + c@ 1 rot lshift and 0<> ;




create _buf 256 allot
: expanded ( a len - a' len' )
    over _buf 1 - = abort" EXPANDED: Source is buffer!"
    >pad _buf $expand _buf count ;

\ Iteration control
variable enough-flag
: enough  enough-flag on ;



create fnd-buf 64 allot&erase
variable fnd-xt

: find-top ( a c - xt|0 )
    fnd-buf place
    fnd-buf count upper
    0 fnd-xt !
    [: nip 
        dup nfa>ctrl c@ $08 and 0= if
            dup count  fnd-buf count compare 0= if
                name> fnd-xt !  false
            else
                drop true
            then
        else
            drop true
        then
    ;] WalkAllWords
    fnd-xt @ ;

s" main" find-top >name hidename
s" bitmap" find-top >name hidename
s" help" find-top >name hidename

: xchg  ( addr1 addr2 -- )
    over @ over @ swap rot ! swap ! ;