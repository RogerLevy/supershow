\ Compact class syntax parser for NIBS
\ Claude gets confused by files that use this, so there's an automatic 
\ Python script to perform expansion, but it's still useful for quick
\ experiments and stuff that I don't need help from Claude with.

module [nibs]
forth-public

|| redef : number? ( a len - f )
    isnumber? case
        1 of drop -1 exit endof
        2 of drop drop -1 exit endof
        -2 of fdrop -1 exit endof
    endcase
    0 ;

: size? ( $ - f )
    \ number or /size or s/size
    {: $ :}
    $ count number? ?dup ?exit
    $ 1 + c@ '/' = ?dup ?exit
    $ 2 + c@ '/' = ?dup ?exit
    0 ;

: "word"? ( $ - f )
    {: $ :}
    $ 1 + c@ '"' =
    $ count + 1 - c@ '"' = and ;
    
: eval  bl parse evaluate ;
: consume  bl parse 2drop ;
: pre-xt  preword count ( 1 /string ) sfind 0<> and ;
: parse-size  preword size? if eval else cell then ;
: comment?  preword 1 + c@ dup '\' = swap '(' = or ;
: eol?  preword c@ 0= ;
: ?term preword 1 + c@ ';' = dup if consume then ;

\ =============================================================================
\ Property suffix parsing  ( name[!][:type] )
\
\   !         mark as saved ( <save )
\   :n        TYPE_INT
\   :a        TYPE_ADDR
\   :$        TYPE_CSTRING
\   :l$       TYPE_LSTRING
\   :p        TYPE_FIXED
\   :f        TYPE_FLOAT
\   :xt       TYPE_XT
\   :%class   TYPE_OBJREF + reftype
\
\ These can be combined: savedprop!  typedprop:n  combo!:$  ref:%actor
\ A following number is still the property size: bigprop! 256
\ =============================================================================

|| variable first-property-seen

|| : char-pos ( a len c - i )
    {: a len c | i :}
    len 0= if -1 exit then
    0 to i
    begin i len < while
        a i + c@ c = if i exit then
        i 1+ to i
    repeat
    -1 ;

|| variable meta-save
|| variable meta-type
|| variable meta-ref

|| : clear-meta
    meta-save off  meta-type off  meta-ref off ;

|| : apply-type-code ( a len - )
    2dup s" n"  s= if 2drop TYPE_INT     meta-type ! exit then
    2dup s" a"  s= if 2drop TYPE_ADDR    meta-type ! exit then
    2dup s" $"  s= if 2drop TYPE_CSTRING meta-type ! exit then
    2dup s" l$" s= if 2drop TYPE_LSTRING meta-type ! exit then
    2dup s" p"  s= if 2drop TYPE_FIXED   meta-type ! exit then
    2dup s" f"  s= if 2drop TYPE_FLOAT   meta-type ! exit then
    2dup s" xt" s= if 2drop TYPE_XT      meta-type ! exit then
    over c@ [char] % = if
        sfind 0= if drop -1 abort" Unknown class in property type annotation" then
        >body meta-ref !  TYPE_OBJREF meta-type !  exit
    then
    2drop -1 abort" Unknown property type code" ;

|| : parse-meta ( a len - a namelen )
    \ strip ! and :type suffixes; populate meta-* side-effect variables
    clear-meta
    {: a len | bang-i colon-i :}
    a len [char] ! char-pos to bang-i
    a len [char] : char-pos to colon-i
    bang-i  0 >= if  meta-save on  then
    colon-i 0 >= if
        a colon-i + 1+  len colon-i - 1-  apply-type-code
    then
    \ name ends at first of ! or :
    bang-i 0 >= colon-i 0 >= and if  bang-i colon-i min
    else bang-i  0 >= if  bang-i
    else colon-i 0 >= if  colon-i
    else len  then then then
    a swap ;

|| : apply-meta ( - )
    meta-type @ ?dup if  current-property classifier >property-type !  then
    meta-ref  @ ?dup if  current-property classifier >property-reftype !  then
    meta-save @ if  <save  then ;

: *property ( - )
    first-property-seen on
    bl parse parse-meta ( a namelen )
    2dup sfind if
        >body valid-classifier? if
            >pad count fe" '%s' is a classifier name. Use @class, +trait, or \"trait\" syntax."
            -1 -rot .abort
        then
    else drop then
    parse-size
    f" %n nproperty %s" evaluate
    apply-meta ;

: is-class? ( ? - f )
    dup valid-object? not if drop 0 exit then
    -> cla @ %class = ;

: ?class ( - f ) 
    preword 1 + c@ '%' <> if 0 exit then
    pre-xt dup 0= if consume -1 abort" Token not found." then
    >body dup is-class? not if
        drop 0 exit
        \ consume -1 abort" Classifier not a class."
    then
    derive-class consume -1 ;

: "trait" ( $ - a len )
    {: $ :}
    $ 2 + $ count nip 2 - f" %%%s" ;

: is-trait? ( ? - f )
    dup valid-object? not if drop 0 exit then
    -> cla @ %trait = ;
    
: ?"trait" ( - f )
    preword "word"? if
        bl word "trait" sfind
        0= if consume -1 abort" Token not found." then
        >body dup is-trait? not abort" Classifier not a trait." 
        ( trait ) classifier 0 apply-trait
        -1
    else 0 then ;

: ?trait ( - f ) 
    ?"trait" ?dup ?exit
    preword 1 + c@ '%' <> if 0 exit then
    pre-xt dup 0= if consume -1 abort" Token not found." then
    >body dup is-trait? not if
        consume -1 abort" Classifier not a trait."
    then
    classifier -1 apply-trait consume -1 ;
    
: ?comment
    comment? abort" Comments not allowed in compact class definitions."  ;
    
: ?invalid
    preword size? if
        consume
        -1 abort" Invalid token."
    then
    ?comment ;

: [word]?
    {: $ :}
    $ 1 + c@ '[' =
    $ count + 1 - c@ ']' = and ;

: ?word ( - flag )
    \ %property already? if 0 exit then
    preword [word]? if
        bl parse 1 /string 1 - evaluate 
        -1 exit
    then 
    0 ;

: ?fieldspace ( - f )
    first-property-seen @ if 0 exit then
    preword size? if eval field-space -1 else 0 then ;

|| redef : token ( - )
    ?fieldspace ?exit           \ standalone number before first property = field space
    ?invalid
    ?class ?exit
    ?trait ?exit
    ?word ?exit
    *property ;

: next-line
    refill 0= abort" Unexpected end of file."
    eol? abort" Blank line encountered; check for missing semicolon." ;

: c:
    class:
    first-property-seen off
    ?comment
    eol? if next-line then
    begin ?term not while
        token
        eol? if next-line then
    repeat
    class; ;

((
\ Test:

trait: thinker trait;
trait: %lifo trait;
512 constant /actor

c: thingy ;
c: %actor  /actor  @thingy  +%lifo  "thinker"
    en buf 256 x y vx vy ;
