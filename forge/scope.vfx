\ ------------------------------------------------------------------------------
\ Scope
\  Per-file public/private words support
\  Also provides search order stack and stack imbalance checking after include
\ ------------------------------------------------------------------------------

\ Public/private
create wl$ 64 allot
variable public-xt  ' forth public-xt !

: wlname
    CurrSourceName -path -ext wl$ place
    wl$ s" >>" $+ count ;

: the-wordlist  wl$ count search-context if >body @ else 0 then ;

: _scope ( - )
    only forth definitions
    s" vocabulary " >pad wl$ count $+ count evaluate
    does> only forth definitions also @ context ! ;

: ?wordlist ( a n - wl )
    wl$ place
    the-wordlist ?dup if exit then
    _scope

    \ backward compatibility: also create `SCOPE/`
    s" synonym " >pad
    wl$ count 2 - $+
    s" / " $+
    wl$ count $+
    count
    evaluate

    the-wordlist ;

: sprivate ( a n - )
    only forth 
    ?wordlist +order definitions ;

: private ( - )
    wlname sprivate ;

: ?+order ( wl - )
    dup ?order if drop else +order then ;

: (public) ( - )
    public-xt @ >body @ set-current
    wlname ?wordlist ?+order ;

: public ( - )
    only forth (public) ;

\ Importing words from other files
: borrow ( - <vocabulary> <word> )
    save-order 
    private
    ' >body @ +order
    bl parse 2dup 
    s" synonym " >pad -rot $+ s"  " $+ -rot $+ count evaluate
    restore-order ;

\ New system 2026.02.17
\ SCOPE creates a wordlist if it doesn't already exist
\ and adds it to the search order
\ PRIVATE: PRIVATE; make the wordlist current
\ A variant of the scope named like [SCOPE] evaluates the next word
\ from the given scope.
\ Note: The new system is not compatible with BORROW, which is deprecated.

\ Side note:
\ Making things "global" is a separate topic, as "global" as a concept
\ ought to have two levels:
\ - Extensions to Forth as a language
\ - Words that are global or common to an application

: the-wordlist2  wl$ count search-context if >body else 0 then ;

: private:  save-order the-wordlist2 +order definitions ;
: private;  restore-order ;

: wlname2
    \ create `SCOPEING`
    CurrSourceName -path -ext wl$ place
    wl$ s" ing" $+ count ;

: [wlname2]
    s" [" >pad wlname2 $+ s" ]" $+ count ;

: scope
    wlname2 sfind if execute +order exit else drop then 
    wlname2 screate wordlist dup +order 
    [wlname2] screate , immediate 
    does> @ dup >r +order ' execute r> -order ;

: find-in  ( a len wid - xt|0 )
    search-wordlist dup if drop then ;
    
: [wlname2]?  [wlname2] sfind nip ;

: || ( - ) 
    [wlname2]? if private: else private then 
    0 parse evaluate 
    [wlname2]? if private; else public then ; immediate

\ Extend include words to preserve the search order
: /order only forth definitions ;

: floaded included ;
: fload getPathSpec included ;
redef : include  save-order /order getPathSpec included restore-order ;
redef : included save-order /order included restore-order ;
redef : require  save-order /order getPathSpec required restore-order ;
redef : required save-order /order required restore-order ;
: ?included  2dup fileExist? if included else 2drop then ;
: ?required  2dup fileExist? if required else 2drop then ;
