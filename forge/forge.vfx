variable debug  debug on

[defined] release-target [if] debug off [then]

optimising off  \ DO NOT REMOVE, it breaks continuations 
                \ some optimization is still performed even with this off. 
                \ we also enable it in key places.

-idata          \ DO NOT REMOVE, it lets us see variable names

'd' dp-char !   \ double-precision int literal symbol

InCurrent       \ Configure the FFI to put externals in CURRENT instead of EXTERNALS

include %idir%/file-fix.vfx       \ Fix bug in VFX Forth INCLUDE 
include %idir%/backtick.vfx       \ Ignore trailing backticks; like commas in C
include %idir%/strlit.vfx
include %idir%/core.vfx           \ Miscellaneous utility words / core extensions

include %idir%/module.vfx
\ include %idir%/../test/module-test.vfx
\ include %idir%/../test/package-test.vfx
\ quit

include %idir%/fixed.vfx          \ 16.16 fixed-point math
include %idir%/format.vfx         \ Printf-style string formatting
include %idir%/logging.vfx        \ Printf-style string formatting
include %idir%/../lib/fstools.vfx    \ Filesystem utilities
include %idir%/../lib/lstring.vfx    \ Cell-counted strings
include %idir%/../lib/strout.vfx    \ Capture console output
include %idir%/../lib/counter.vfx

include %idir%/nibs.vfx           \ NIBS (Nib 2.0) OOP system core
include %idir%/nibs-tools.vfx     \ NIBS introspection tools
include %idir%/nibs-compact.vfx   \ Compact class syntax parser (c:)

include %idir%/oversight.vfx      \ Contract-based validation system

include %idir%/../cjson/cjson.vfx   
include %idir%/nibs-json.vfx   
include %idir%/checks.vfx         \ Core Forth word safety validations
include %idir%/array.vfx         \ NIBS arrays
include %idir%/dltree.vfx         \ Doubly-linked tree
