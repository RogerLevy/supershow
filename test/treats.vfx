module
import %supershow%/src/supershow.vfx

bitmap %idir%/assets/gfx/icons1.png
bitmap %idir%/assets/gfx/icons2.png
bitmap %idir%/assets/gfx/icon-shadow.png

icons1.png  16 16 tileset  icons1.ts
icons2.png  16 16 tileset  icons2.ts

\ ---- Private stage ----------------------------------------------------------
\ treats owns its own stage; every class in this module resolves stg@ to it,
\ so spawn/step/sprites/just hit it automatically with no explicit passing.
\ Consequence: treats can only be driven through its system (god + render).
%stage object treats.stage
treats.stage use-stage

\ ---- Treat ------------------------------------------------------------------

class: %treat  %actor derive
    prop z  :fixed
    prop vz :fixed
    %box-params    sizeof nprop box       \ embedded query records (class ptr stamped via template)
    %sprite-params sizeof nprop sprite
    template { %box-params box !  %sprite-params sprite !  2 prio ! }   \ object layer
class;

: ?ts  2 rnd if icons1.ts else icons2.ts then ;
: rndtile ( ts - bmpid )  dup -> #tiles @ rnd tile ;
: in? ( - f )  x 2@ 2>i  0 gameh within? >r  0 gamew within? r> and ;

-0.2 constant grav      \ reduced z-gravity (top-down oblique view)

: bounce ( - )                 \ this=treat; it just reached the ground
    0. z !
    vz @ 0.6 p* negate  dup vz !       \ reverse, lose 40% energy
    0.5 < if me unload then ;          \ rebound too weak -> done

%treat :: start
    ?ts rndtile bmp !
    physics>
        vx 2@ 0.98 dup 2p* vx 2!
        vx 2@ x 2+!                     \ drift on the ground plane
        grav vz +!  vz @ z +!          \ fall in z
        z @ 0> not if bounce then ;

%treat :: draw
    z @ 0 > if
        at@
        x 2@ 2>i 8 + at  icon-shadow.png cput 
        at
    then 
    0 z @ negate +atp  actor:draw ;


\ ---- Spewer -----------------------------------------------------------------

class: %spewer  %actor derive  class;

: spew
    gamew rnd  gameh rnd  at
    %treat spawn as>
        3. 3. 2rnd  1.5 1.5 2-  vx 2!     \ x,y drift, symmetric
        64. z !
        2. rnd 1. +  vz ! ;                \ pop upward in z

%spewer :: start
    act> spew ;

\ ---- Public -----------------------------------------------------------------

public

: ~treats    sprites ;
: treats-think   step ;
: treats-load   %spewer treats.stage one-in start ;   \ OOP: one spewer actor (into treats' stage) that spews

\ ---- World integration ------------------------------------------------------

\ Fill and return a treat's embedded query records.
: treat>box ( treat - %box-params )
    { box {
        you >msk @ msk !   you >lyr @ lyr !   you id !
        you >x 2@  you >bmp @ bmpwh 2>p  box-around   x2 2!  x1 2!
        0. z1 !  64. z2 !
    this } } ;

: treat>sprite ( treat - %sprite-params )
    { sprite {
        you >x 2@ x 2!   you >z @ z !   you >bmp @ bmp !   you id !   you >prio @ prio !
    this } } ;

\ Ground shadow: at the treat's x,y (z=0), background layer. Scratch record is
\ fine because the y-sorter copies each emitted record immediately.
%sprite-params object treat-shadow
: treat>shadow ( treat - %sprite-params )
    { treat-shadow {
        you >x 2@ 0 8. 2+ x 2!   0. z !   icon-shadow.png bmp !   1 prio !   you id !
    this } } ;

|| 0 value emit-xt
c: %treats %system ;
%treats :: start   act>  step ;   \ just step its stage; the runner decides how to populate it
%treats :: render  ~treats ;
%treats :: entity-count  ( - n )          treats.stage #items ;
%treats :: entity-box    ( n - %box-params )     treats.stage el@ treat>box ;
%treats :: entity-sprite ( n - %sprite-params )  treats.stage el@ treat>sprite ;
%treats :: entity-sprites ( xt - )        \ emit the treat plus, when airborne, its shadow
    to emit-xt
    [: 
       this treat>shadow emit-xt execute
       this treat>sprite emit-xt execute
    ;] each-active ;
%treats manager: treats.sys manager;

: spew-treat  treats.sys as> spew ;