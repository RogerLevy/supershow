module
import %supershow%/src/supershow.vfx
import %supershow%/addons/shapes.vfx

\ Tileset for metadata infrastructure (bitmap not rendered)
bitmap %idir%/assets/gfx/greyzebes.png
greyzebes.png 16 16 tileset-from the-tileset
20 15 tilemap the-tilemap

\ Tile indices and their metadata:
\   1 = D     floor only      ($08)
\   2 = U     ceiling only    ($04)
\   3 = L     left wall       ($02) BIT_WLT — blocks entry from left
\   4 = R     right wall      ($01) BIT_WRT — blocks entry from right
\   5 = UDLR  all solid       ($0F)
\   6 = DL    floor+left      ($0A)
\   7 = DR    floor+right     ($09)
\   8 = UL    ceiling+left    ($06)
\   9 = UR    ceiling+right   ($05)
\  10 = UD    floor+ceiling   ($0C)
\  11 = LR    left+right      ($03)
\  12 = UDR   floor+ceil+right ($0D)
\  13 = UDL   floor+ceil+left  ($0E)
\  14 = ULR   ceil+left+right  ($07)
\  15 = DLR   floor+left+right ($0B)

$FFFFFFFF constant _

