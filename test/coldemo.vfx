module
import %supershow%/src/supershow.vfx
import %supershow%/addons/shapes.vfx
import %supershow%/lib/mouse.vfx

private

\ Current cursor shape type (1=rect 2=circ 3=oval 4=line 5=poly)
variable ctype   1 ctype !

\ Mouse position in integer pixels, updated each frame
variable mx   variable my

\ ============================================================
\ Cursor shape params (computed from mx/my each use)
\ ============================================================
: crx1  mx @ 28 - >p ;    : cry1  my @ 18 - >p ;
: crx2  mx @ 28 + >p ;    : cry2  my @ 18 + >p ;
: ccx   mx @ >p ;          : ccy   my @ >p ;
: clx1  mx @ 28 - >p ;    : cly1  my @  8 - >p ;
: clx2  mx @ 28 + >p ;    : cly2  my @  8 + >p ;

\ Cursor polygon: small triangle centered on mouse, rebuilt each frame
create cpoly   3 ,   0 , 0 ,   0 , 0 ,   0 , 0 ,

: update-cpoly ( - )
    mx @ >p       my @ 18 - >p   cpoly 0 pg.vert 2!
    mx @ 18 + >p  my @ 12 + >p  cpoly 1 pg.vert 2!
    mx @ 18 - >p  my @ 12 + >p  cpoly 2 pg.vert 2! ;

\ ============================================================
\ Static shape data (inline)
\ S1: rect   (40, 40) - (120, 90)
\ S2: circle center (185, 65) r=30
\ S3: oval   center (270, 65) rx=38 ry=18
\ S4: line   (40, 140) - (130, 200)
\ S5: poly   triangle (195,140)-(265,200)-(168,200)
\ ============================================================

create spoly   3 ,
    195. ,  140. ,
    265. ,  200. ,
    168. ,  200. ,

\ ============================================================
\ Intersection checks: cursor vs each static shape
\ Uses if/exit chain; each branch returns a flag.
\ ============================================================

: hit-s1? ( - flag )
    ctype @ 1 = if  crx1 cry1 crx2 cry2   40. 40. 120. 90.  rect-rect?  exit then
    ctype @ 2 = if  40. 40. 120. 90.   ccx ccy 20.         rect-circ?  exit then
    ctype @ 3 = if  40. 40. 120. 90.   ccx ccy 32. 14.   rect-oval?  exit then
    ctype @ 4 = if  clx1 cly1 clx2 cly2         40. 40. 120. 90.  line-rect?  exit then
    ctype @ 5 = if  40. 40. 120. 90.   cpoly                 rect-poly?  exit then
    false ;

: hit-s2? ( - flag )
    ctype @ 1 = if  crx1 cry1 crx2 cry2   185. 65. 30.  rect-circ?  exit then
    ctype @ 2 = if  ccx ccy 20.          185. 65. 30.  circ-circ?  exit then
    ctype @ 3 = if  false  exit then
    ctype @ 4 = if  clx1 cly1 clx2 cly2   185. 65. 30.   line-circ?  exit then
    ctype @ 5 = if  185. 65. 30.    cpoly                 circ-poly?  exit then
    false ;

: hit-s3? ( - flag )
    ctype @ 1 = if  crx1 cry1 crx2 cry2   270. 65. 38. 18.  rect-oval?  exit then
    ctype @ 2 = if  false  exit then
    ctype @ 3 = if  ccx ccy 32. 14.   270. 65. 38. 18.  oval-oval?  exit then
    ctype @ 4 = if  clx1 cly1 clx2 cly2   270. 65. 38. 18.  line-oval?  exit then
    ctype @ 5 = if  270. 65. 38. 18.  cpoly                  oval-poly?  exit then
    false ;

: hit-s4? ( - flag )
    ctype @ 1 = if  40. 140. 130. 200.  crx1 cry1 crx2 cry2  line-rect?  exit then
    ctype @ 2 = if  40. 140. 130. 200.  ccx ccy 20.         line-circ?  exit then
    ctype @ 3 = if  40. 140. 130. 200.  ccx ccy 32. 14.   line-oval?  exit then
    ctype @ 4 = if  40. 140. 130. 200.  clx1 cly1 clx2 cly2   line-line?  exit then
    ctype @ 5 = if  40. 140. 130. 200.  cpoly                  line-poly?  exit then
    false ;

: hit-s5? ( - flag )
    ctype @ 1 = if  crx1 cry1 crx2 cry2   spoly  rect-poly?  exit then
    ctype @ 2 = if  ccx ccy 20.          spoly  circ-poly?  exit then
    ctype @ 3 = if  ccx ccy 32. 14.   spoly  oval-poly?  exit then
    ctype @ 4 = if  clx1 cly1 clx2 cly2   spoly  line-poly?  exit then
    ctype @ 5 = if  cpoly  spoly           poly-poly?  exit then
    false ;

\ ============================================================
\ Colors
\ ============================================================
: normal-col  $4488ccff rgba8 ;
: hit-col     $ffff44ff rgba8 ;
: cursor-col  $ff8844ff rgba8 ;

\ ============================================================
\ Draw static shapes — highlight when hit
\ ============================================================

: ~s1 ( - )
    hit-s1? if hit-col else normal-col then
    40 40 at  80. 50. rect ;

: ~s2 ( - )
    hit-s2? if hit-col else normal-col then
    185 65 at  30. circ ;

: ~s3 ( - )
    hit-s3? if hit-col else normal-col then
    270 65 at  38. 18. oval ;

: ~s4 ( - )
    hit-s4? if hit-col else normal-col then
    40 140 at  130. 200. line ;

: ~s5 ( - )
    hit-s5? if hit-col else normal-col then
    0 0 at  spoly poly ;

\ ============================================================
\ Draw cursor shape
\ ============================================================

: ~cursor ( - )
    cursor-col
    ctype @ 1 = if  mx @ 28 - my @ 18 - at  56. 36. rect  exit then
    ctype @ 2 = if  mx @ my @ at  20. circ  exit then
    ctype @ 3 = if  mx @ my @ at  32. 14. oval  exit then
    ctype @ 4 = if  mx @ 28 - my @ 8 - at  mx @ 28 + >p my @ 8 + >p line  exit then
    ctype @ 5 = if  0 0 at  cpoly poly  exit then
    ;

\ ============================================================
\ Input: switch cursor type with keys 1-5
\ ============================================================

: handle-keys ( - )
    <1> pressed? if 1 ctype ! exit then
    <2> pressed? if 2 ctype ! exit then
    <3> pressed? if 3 ctype ! exit then
    <4> pressed? if 4 ctype ! exit then
    <5> pressed? if 5 ctype ! exit then
    ;

\ ============================================================
\ Main
\ ============================================================

public

: demo ( - )
    handle-keys
    get-mouse  mouse  my !  mx !
    update-cpoly
    ~s1 ~s2 ~s3 ~s4 ~s5
    ~cursor ;

: main
    show>  demo ;

main
