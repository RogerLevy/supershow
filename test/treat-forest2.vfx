\ treat-forest2 — advanced coordinator: forest + treats as independent %systems.
\ This step verifies world coordination only: both systems are loaded into the
\ world, updated through `god`, and drawn through their `render` protocols.
\ (entity-box / entity-sprite querying comes next.)

\ NOTE: This is *not* a typical use-case.
\ We are just demonstrating how deep integration of simple
\ programs (like treats and forest) into a game is accomplished.

\ Normally, systems with cross-cutting concerns should be 
\ self-contained and self-sufficient.  There are going to be
\ times where a procedural approach wins out, and a %system will
\ make the most sense - but you need just a little bit of 
\ interoperability to make it mesh well in your game.  

\ ***This is NOT a component or plugin system.***

\ Think of it as sub-game-engines.

\ Sequencing and superimposing are meant to be the dominant 
\ use cases.  *And you can always just use the Stage!*


module
import %supershow%/src/supershow.vfx
import %idir%/forest.vfx
import %idir%/treats.vfx
import %suprtshow%/lib/rsort.vfx

\ ---- Cross-system y-sorted render -------------------------------------------
\ Atypical on purpose: the coordinator reaches into BOTH systems' sprite records
\ and interleaves them by depth (crowd.vfx-style), so a treat behind a tree is
\ occluded by it. forest's entity-sprite is a reused scratch, so we COPY each
\ record into a stable buffer, then radix-sort pointers by y.

4096 constant MAX_SPRITES
%sprite-params sizeof constant /spr
create spr-buf    MAX_SPRITES /spr * allot      \ stable record copies
create spr-order  MAX_SPRITES cells allot       \ pointers into spr-buf (what gets sorted)
0 value #spr

: +spr ( sprite - )
    {: src | slot :}
    #spr MAX_SPRITES < not ?exit
    src -> bmp @ 0= ?exit                       \ skip bmp-less rows (lock-marker)
    spr-buf   #spr /spr * + to slot
    src slot copy ( slot ) spr-order #spr cells + !
    1 +to #spr ;

: collect ( system - )  
    ['] +spr swap entity-sprites ;

: ~ysort ( - )
    0 to #spr
    forest.sys collect
    treats.sys collect
    \ sort key: prio (major layer) then base-y (feet = y + half sprite height)
    spr-order #spr [: dup -> prio @ 11 <<  swap dup -> y @ >i  swap -> bmp @ bmpwh nip 2 /  + + ;] rsort
    1 batch>
        #spr for
            spr-order i cells + @
            { x @  y @ z @ -  2>i at  bmp @ cput }   \ z raises the sprite off its ground y
        loop ;

: main
    $60c030ff backdrop !
    just
    forest.sys load
    treats.sys load
    show>
        god         \ steps both systems' stages
        treats-spew \ procedural spawning: one treat per frame
        ~ysort ;    \ forest + treats sprites, interleaved by depth

main
