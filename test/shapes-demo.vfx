module
import %supershow%/src/supershow.vfx
import %supershow%/addons/shapes.vfx

\ ---- animation ----------------------------------------------------------

variable frame#

\ Triangular wave: integer 0..max..0 over `period` frames
: tri ( period max -- n )
    {: period max | phase half :}
    frame# @ period mod  to phase
    period 2 / to half
    phase half < if
        phase max * half /
    else
        period phase - max * half /
    then ;

\ Fixed-point triangular wave
: tri. ( period max -- n. )  tri >p ;

private

\ ---- shapes -------------------------------------------------------------

\ circ — pulsing radius and thickness
: ~circ
    $ff6644ff rgba8
    60 70 at
    97 30 tri.   20. +              \ radius 20..50
    67 4  tri.   1.  +  thick  circ ;

\ circf — pulsing radius
: ~circf
    $4488ffff rgba8
    160 70 at
    113 25 tri.  15. +  circf ;    \ radius 15..40

\ oval — rx and ry animated independently
: ~oval
    $44ff88ff rgba8
    260 70 at
    83 30 tri.  15. +              \ rx 15..45
    71 20 tri.  12. +              \ ry 12..32
    1. thick  oval ;

\ ovalf — filled, different periods than oval
: ~ovalf
    $ffaa44ff rgba8
    60 170 at
    127 28 tri.  18. +              \ rx 18..46
    61 18 tri.   10. +              \ ry 10..28
    ovalf ;

\ line — from pen to animated endpoint
: ~line
    $ffff44ff rgba8
    160 170 at
    89 120 tri  80 +  >p            \ endpoint x 80..200
    103 80 tri  90 +  >p           \ endpoint y 90..170
    1. thick  line ;

\ rect — w and h animated independently
: ~rect
    $aa44ffff rgba8
    240 152 at
    79 40 tri.  10. +               \ w 10..50
    97 28 tri.  10. +               \ h 10..38
    1. thick  rect ;

\ rectf — centered, filled
: ~rectf
    {: | w h :}
    109 40 tri  10 +  to w
    73  28 tri  10 +  to h
    $ff4488ff rgba8
    160 w 2 / -   215 h 2 / -   at
    w >p  h >p  rectf ;

\ pixel — drifts along independent triangular paths
: ~pixel
    $ffffffff rgba8
    170 151 100 tri +   83 60 tri  100 +   at
    pixel ;

public

\ ---- main ---------------------------------------------------------------

: demo
    ~circ  ~circf  ~oval
    ~ovalf  ~line  ~rect  ~rectf
    ~pixel
    1 frame# +! ;

: main
    show>  demo ;

main
