module
import %supershow%/src/supershow.vfx

\ =============================================================================
\ Spritesheets
\ =============================================================================

bitmap %idir%/assets/gfx/2200man.png
bitmap %idir%/assets/gfx/alfador.png
bitmap %idir%/assets/gfx/fairgirl.png
bitmap %idir%/assets/gfx/lyle.png

2200man.png  21 36 tileset  man.ts
alfador.png  18 20 tileset  cat.ts
fairgirl.png 21 28 tileset  girl.ts

\ =============================================================================
\ Animations
\ =============================================================================

man.ts  flipbook: man-down   1 4 range, flipbook;
man.ts  flipbook: man-up     8 11 range, flipbook;
man.ts  flipbook: man-left   5 , 6 , 5 , 7 , flipbook;

cat.ts  flipbook: cat-down   1 , 2 , 3 , 4 , flipbook;
cat.ts  flipbook: cat-up     10 , 11 , 12 , 13 , flipbook;
cat.ts  flipbook: cat-left   6 , 7 , 8 , 7 , flipbook;

girl.ts flipbook: girl-down  0 , 1 , 0 , 2 , flipbook;
girl.ts flipbook: girl-up    5 , 6 , 5 , 7 , flipbook;
girl.ts flipbook: girl-left  3 , 4 , 3 , 4 , flipbook;

\ =============================================================================
\ NPC class
\ =============================================================================

0 constant DIR_DOWN
1 constant DIR_UP
2 constant DIR_LEFT
3 constant DIR_RIGHT

class: %npc  derive %actor
    prop anm-down :addr
    prop anm-up   :addr
    prop anm-left :addr
class;

: face ( dir - )
    dir !
    dir @ case
        DIR_DOWN  of anm-down @ 1.0 10 / cycle  0 a.flp ! endof
        DIR_UP    of anm-up   @ 1.0 10 / cycle  0 a.flp ! endof
        DIR_LEFT  of anm-left @ 1.0 10 / cycle  0 a.flp ! endof
        DIR_RIGHT of anm-left @ 1.0 10 / cycle  0 h| a.flp ! endof
    endcase ;

\ =============================================================================
\ Walking logic
\ =============================================================================

: walk-velocity ( - )
    dir @ case
        DIR_DOWN  of  0.      0.5  endof
        DIR_UP    of  0.     -0.5  endof
        DIR_LEFT  of -0.5    0.    endof
        DIR_RIGHT of  0.5    0.    endof
    endcase
    vx 2! ;

: boundary? ( - f )
    x @ >i 0 gamew within? not
    y @ >i 0 gameh within? not or ;

: rnd-dir ( - dir )  4 rnd ;

: about-face ( - )
    dir @ 1 xor face  walk-velocity  
    x 2@ 0 0 gamew gameh 2>p 1. 1. 2- 2clamp x 2! ;

: man-npc ( - )
    man-down anm-down !  man-up anm-up !  man-left anm-left ! ;

: cat-npc ( - )
    cat-down anm-down !  cat-up anm-up !  cat-left anm-left ! ;

: girl-npc ( - )
    girl-down anm-down !  girl-up anm-up !  girl-left anm-left ! ;

jumptable npc  ' man-npc ,  ' cat-npc ,  ' girl-npc ,
: rnd-npc ( - )  3 rnd npc ;

%npc :: start ( - )
    rnd-npc  rnd-dir face  walk-velocity
    act>
        boundary? if about-face walk-velocity then
        60 rnd 0= if rnd-dir face walk-velocity then ;

: sprinkle ( n - )
    for  gamew rnd gameh rnd at  %npc spawn drop  loop ;

\ =============================================================================
\ Unoptimized test sprite (not in bank — tests flush-on-fallback)
\ =============================================================================

class: %marker  derive %actor  class;

%marker :: draw ( - )
    lyle.png bcput ;

%marker :: render ( - )
    x 2@ 2>i at this draw ;

\ =============================================================================
\ Spritebank
\ =============================================================================

0 value npc-bank

: init-npc-bank ( - )
    256 3 make-spritebank to npc-bank
    man.ts  npc-bank add-tileset-to-bank
    cat.ts  npc-bank add-tileset-to-bank
    girl.ts npc-bank add-tileset-to-bank ;

%npc :: draw ( - )
    bmp @ -exit  bmp @ bcput ;

%npc :: render ( - )
    x 2@ 2>i at this draw ;

\ =============================================================================
\ Main
\ =============================================================================

public

fast{
|| : draw-npcs ( - )
    [: >y @ >i ;] sorted-actors> this render  ?pillory ;

: ~test
    $808080ff rgba8 screen
    npc-bank bank>
    draw-npcs ;
fast}

: think   step animate ;

: main
    just

    init-npc-bank
    center at  %marker spawn drop
    2000 sprinkle
    show> ~test
    work> think
;

main
