module
import %supershow%/src/supershow.vfx
import %supershow%/addons/3d/model.vfx
import %supershow%/addons/3d/render.vfx
import %supershow%/addons/3d/cube.vfx
import %supershow%/addons/3d/arwing.vfx
import %supershow%/addons/3d/grid.vfx
import %supershow%/addons/3d/collision3d.vfx


0 value the-ship
0 value the-grid
100 value gridsize

\ allrange port -- fly a ship around a randomized cuboid city with a chase camera.
\ Stage 2+3: controllable ship (placeholder cube mesh) + chase camera. No control
\ smoothing yet (deferred), and the ship mesh is a stand-in for the arwing.
\ Tune the control rates / camera offset / angle signs to taste.

\ Flat-shaded models hand the shader their object->world matrix (uModel) so it can
\ put positions in world space; the 3d pack stashes it in `modelmtx` during modelview.
\ Subclasses override draw (rather than %model itself) so model:draw can delegate.


\ ===== flat-shading =====
shader flatshade.s %supershow%/glsl/flatshade.vs %supershow%/glsl/flatshade.fs

\ Activate the shader and set its uniforms. (The per-model uModel matrix is set in each
\ model's draw -- see ~flat-model.) uLightDir is the world-space directional light; surfaces
\ run from uAmbientColor (unlit) to uLightColor (lit). uGradStrength/uGradBright drive the
\ screen-space gradient across oblique faces. uView (the camera matrix) is constant per frame.
: flatshade ( - )
    flatshade.s shade                            \ flatshade.s pushes the shader object; shade activates it
    \ unit vector TOWARD the light: normalize(-travel), travel = (-0.4,-0.25,-0.1).
    \ Pre-normalized here so the fragment shader skips a per-pixel normalize.

    0.829545e 0.518466e 0.207386e   z" uLightDir"     vec3!
    \ 0.e 1e 0e   z" uLightDir"     vec3!

    1e 1e 1e 1e          "uLightColor"   vec4!
    \ 0.1e 0.05e 0e 1e     "uAmbientColor" vec4!
    0e 0e 0e 1e "uAmbientColor" vec4!

    \ "Lava World" settings
    \ 1e 1e 0.5e 1e          "uLightColor"   vec4!
    \ 0.75e 0e 0e 1e          "uAmbientColor" vec4!
    .5e                   "uGradStrength" float!
    .5e                   "uGradGain"     float!   
    .5e                   "uGradCurve"    float!   \ <1 = bend toward ambient (more dark), 1 = linear

    \ depth fog (eye-space distance) -- tune start/end to the scene scale
    1500e                "uFogStart"     float!
    8000e                "uFogEnd"       float!
    0e 0e 0e 1e          "uFogColor"     vec4!
    1e                   "uFogAmount"    float!

    camt                 "uView"         matrix!
;

: ~flat-model ( - )
    modelmtx model-matrix!          \ object->world for the shader (direct glUniformMatrix4fv)
    ~model
;

%model :: draw  active-shader flatshade.s = if ~flat-model else ~model then ;

%grid :: draw  active-shader  0 shade  ~model  shade ;

\ ===== city =====
class: %building  %model derive  class;

: /scale
    50. 50. 50. scl v.xyz!              \ uniform scale 50
    50. 500. between                    \ random height h
    scl v.y!
;

: *building ( - building )
    %building one { cube-mesh msh !  /scale  this } ;

: genlevel ( - )
    400 for
        *building {
            \ 4 rnd 90. * pan !                 \ random quarter-turn
            -6000. 6000. between 
            scl v.y@ 
            -6000. 6000. between 
            pos v.xyz!                          \ pos = (x, h, z); base on y=0
        }
    loop
;

\ ===== ship =====
\ Controls run inside the ship's act>, so `this` = ship and bare props apply.
: ?lr ( - )                         \ bank + turn from left/right (or A/D)
    <left> held?  <A> held? or if   45. roll toward   2. pan +toward  exit then
    <right> held? <D> held? or if  -45. roll toward  -2. pan +toward  exit then
    0. roll toward
;

: ?ud ( - )                         \ pitch from up/down (or W/S)
    <up> held?    <W> held? or if  -30. tilt toward  exit then
    <down> held?  <S> held? or if   30. tilt toward  exit then
    0. tilt toward
;

: propel ( - )                      \ 3D velocity from the ship's heading
    pan @ negate 90. - 10. vec       \ ( vx. vz. ) horizontal from pan
    vel v.xz!
    tilt @ 90. - 10. vec drop         \ ( vy. ) vertical from tilt
    vel v.y!
;

class: %ship  %model derive  class;

0 value it-pos
variable collided

: ship-point-buildings ( x. .y .z - ) 
    >v rel>abs to it-pos
    actives>
        me %building is? -exit
        it-pos
        pos scl v-                          \ building min corner (cube spans pos - scl ..
        pos scl v+                          \  .. pos + scl; mesh is the ±1 unit cube)
        v-box? if collided on then
;

defer ship-physics

: flight
    ship-physics
    act>  propel ?lr ?ud
;

: wobble ( speed ammount dur. - ) 
    {: spd amt dur :}
    begin time spd * psin amt * roll !  yield dur passed? until  0 roll !
;

: test-collision
    simple-motion-3d
    0 task> 2000 20 0.75 wobble flight
;

[:
    physics>
        vel pos v+!
        collided off
        0 0 0      ship-point-buildings
        -9. .25 5. ship-point-buildings
        9. .25 5.  ship-point-buildings 
        collided @ -exit 
        test-collision 
;] is ship-physics

%ship :: start ( - )
    arwing-mesh msh !
    tilt 0.075 linearly  smooth
    pan  0.06  ang-linearly  smooth      \ heading wraps -> angular
    roll 0.06  linearly  smooth
    flight
;

\ ===== orbit camera (ported from 3dpack/cam.f + allrange.f's cam draw) =====
variable orbita  80 orbita !        \ orbit angle offset (degrees)
variable orbith  50 orbith !        \ camera height above the ship

: tilt-towards ( obj dist. - n. )
    >r  -> pos v.y@   pos v.y@  -  r> swap  angof ;

: pan-towards ( obj - n. )
    -> pos v.xz@   pos v.xz@   2-  swap negate swap  angof 90. + ;

: orbitted ( obj ang. dist. - x. z. )
    vec  rot  -> pos v.xz@  2+ ;

: situate ( obj ang. dist. - )  
    orbitted pos v.xz!  ;

\ this = camera; orbit/aim relative to the-ship, matching allrange.f
: cam-place ( - )       \ position the camera around the ship (direct, no easing)
    the-ship -> pos v.y@  orbith @ >p +  pos v.y!     \ height above ship
    the-ship  orbita @ >p  the-ship -> pan @ negate 0. +  +  200.  situate
;

: cam-follow ( - )
    cam-place
    the-ship pan-towards pan toward
    the-ship 200. tilt-towards tilt toward
;

class: %camera  %model derive  class;

%camera :: start ( - )
    pan  0.06 ang-linearly smooth
    tilt 0.06 linearly  smooth
    cam-place                               \ initial placement, then snap the aim so the
    the-ship pan-towards pan snap           \ camera starts facing the ship (no startup somersault)
    the-ship 200. tilt-towards tilt snap
    act>  cam-follow
;

\ ===== grid floor =====
\ Off-stage (%grid make, not on the stage) so it stays out of draw-models' depth
\ sort -- a scene-spanning floor can't be point-sorted. Drawn first as background.
: setup-grid ( - )
    %grid make to the-grid
    grid-mesh the-grid >msh !
    the-grid {
        gridsize >p dup dup scl v.xyz!      \ scale the unit grid up (cell = gridsize)
        90. tilt !                          \ lay it flat (XY -> XZ floor)
    }
;

\ ===== render: grid first (background), then the depth-sorted models =====
: ~render ( - )
    3d  update-camera
    the-grid render
    flatshade
    draw-models
;

\ ===== main =====
public

: main ( - )
    just
    setup-grid
    %ship spawn to the-ship
    the-ship { 0. 0. 0. pos 3v!  10. 10. 10. scl 3v! }
    %camera spawn to the-cam
    genlevel
    show> step ~render
;

main