module
import %supershow%/src/supershow.vfx
import %supershow%/addons/3d/model.vfx
import %supershow%/addons/3d/render.vfx
import %supershow%/addons/3d/cube.vfx

\ Stage 1 of the allrange port: a randomized cuboid "city" viewed from a static
\ camera. Validates the stage-based 3D renderer + depth sort + camera transform.
\ Tune setup-camera (pos / tilt / fov) if the city isn't framed well.

: *model ( mesh - model )  
    %model one  dup >r >msh !  r> ;

: genlevel ( - )
    100 for
        cube-mesh *model {
            50. 50. 50. scl v.xyz!            \ uniform scale 50
            4 rnd 90 * >p pan !               \ random quarter-turn
            50 500 between                    \ random height h
            dup >p scl v.y!                   \ scl.y = h (tall building)
            >p                                \ h -> fixed for pos.y
            -4000 4000 between >p swap        \ ( rx. h. )
            -4000 4000 between >p             \ ( rx. h. rz. )
            pos v.xyz!                         \ pos = (x, h, z); base sits on y=0
        }
    loop ;

: setup-camera ( - )
    %model one to the-cam
    the-cam {
        0. 1000. 4000. pos v.xyz!              \ up and back
        15. tilt !  0 pan !  0 roll !          \ look down slightly
    } ;

public

: main ( - )
    just
    setup-camera
    genlevel
    show> render-scene ;

main
