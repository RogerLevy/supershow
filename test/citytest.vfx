module
import %supershow%/src/supershow.vfx
import %supershow%/3d/model.vfx
import %supershow%/3d/render.vfx
import %supershow%/3d/cube.vfx
public

\ Stage 1 of the allrange port: a randomized cuboid "city" viewed from a static
\ camera. Validates the stage-based 3D renderer + depth sort + camera transform.
\ Tune setup-camera (pos / tilt / fov) if the city isn't framed well.

: genlevel ( - )
    100 for
        cube-mesh *model {
            50 50 50 scl s>v3                 \ uniform scale 50
            4 rnd 90 * >p pan !               \ random quarter-turn
            50 500 between                    \ random height h
            dup s>f scl v3d.y sf!             \ scl.y = h (tall building)
            -4000 4000 between swap
            -4000 4000 between  pos s>v3       \ pos = (x, h, z); base sits on y=0
        }
    loop ;

: setup-camera ( - )
    %model one to the-cam
    the-cam {
        0 1000 4000 pos s>v3                   \ up and back
        15. tilt !  0 pan !  0 roll !          \ look down slightly
    } ;

: main ( - )
    just
    setup-camera
    genlevel
    show> render-scene ;

main
