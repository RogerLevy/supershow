module
import %supershow%/src/supershow.vfx
import %supershow%/lib/colors.vfx
import %supershow%/addons/shapes.vfx
import %supershow%/sketchpad/sketchpad.vfx

0 value a
continuation: a!>  a >r swap to a execute r> to a ;
: a@+  a @  cell +to a ;

: 4@ @+ swap @+ swap @+ swap @ ;
: 4! >r 2swap r@ 2! r> 8 + 2! ;

\ ----------------------------------------------------

trait: %editable
    :: edit-render ( actor - ) drop ;
trait;

c: %actor strat ;  \ add strategy property, for the descriptor to render with

\ ----------------------------------------------------

3 cells descriptor: playfield
    \ [ x , y , strategy , ]
    
    :data>actor  a!>   a@+ a@+ at   %actor one { a@+ strat !   this } ;
    :actor>code  x @ >i "n," y @ >i "n," strat @ "name," ;
    :edit  me strat @ edit-render ;

    : ?size  strat @ >bmp @ ?dup if  bmpwh 2>p  else  16. 16.  then ;
    :pick-box  x 2@ ?size box-around ;
descriptor;

c: %playfield-type  %editable bmp hitbox 16 ;

: ~hitbox ( - )
    hitbox 8 + 2@ or -exit
    hitbox 4@  2swap bmp @ bmpwh 2>p 2 2 2/ 2- +atp   red rect
;

%playfield-type :: edit-render ( actor - ) 
    { x 2@ 2>i at } bmp @ cput 
    ~hitbox 
;
    
: playfield-type:  create %playfield-type dmake as ;

\ ----------------------------------------------------

bitmap %idir%\dat\gfx\trees.png
trees.png 64 64 tileset-from trees.ts

bitmap %idir%\dat\gfx\path.png

playfield-type: tree1  trees.ts 0 tile bmp !   26. 51. 15. 10. hitbox 4!
playfield-type: tree2  trees.ts 1 tile bmp !   18. 44. 33. 12. hitbox 4!
playfield-type: path1  path.png bmp !

