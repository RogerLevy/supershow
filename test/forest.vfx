module
import %supershow%/src/supershow.vfx
import %supershow%/lib/colors.vfx
import %supershow%/addons/shapes.vfx

0 value a
continuation: a!>  a >r swap to a execute r> to a ;
: a@+  a @  cell +to a ;

: 4@ @+ swap @+ swap @+ swap @ ;
: 4! >r 2swap r@ 2! r> 8 + 2! ;

\ ----------------------------------------------------

trait: %hitbox-haver  
    16 nprop hitbox
trait;

\ ----------------------------------------------------

c: %prototype  %actor proto:%prototype ;

: prototype: ( class <name> - ) create dmake as  this proto ! ;

\ ----------------------------------------------------

c: %playfield-entity  %prototype %hitbox-haver ;

: playfield-entity:  %playfield-entity prototype: ;

: ~hitbox ( - )
    me %hitbox-haver is? -exit
    hitbox 8 + 2@ or -exit
    hitbox 4@  2swap bmp @ bmpwh 2>p 2 2 2/ 2- +atp   red rect
;

%playfield-entity :: draw
    x 2@ 2>i at  bmp @ cput  ~hitbox ;

playfield-entity: nul  0 0 0 0 hitbox 4!
playfield-entity: lock-marker  0 0 0 0 hitbox 4!

3 cells descriptor: playfield.desc
    \ [ x , y , prototype , ]
    
    :data>actor  a!>   a@+ a@+   a@+ one-copy { 2>p x 2!  this } ;
    :actor>code  x @ >i "n,"   y @ >i "n,"   proto @ "name," ;

    : ?size  bmp @ ?dup if  bmpwh 2>p  else  16. 16.  then ;
    
    :pick-box  
        next @ ?dup if >proto @ lock-marker = if  0 0 0 0 exit then then
        x 2@ ?size box-around 
    ;

descriptor;
   
\ ----------------------------------------------------

bitmap %idir%\dat\gfx\trees.png
trees.png 64 64 tileset-from trees.ts

bitmap %idir%\dat\gfx\path.png

playfield-entity: tree1  trees.ts 0 tile bmp !   26. 51. 15. 10. hitbox 4!
playfield-entity: tree2  trees.ts 1 tile bmp !   18. 44. 33. 12. hitbox 4!
playfield-entity: path1  path.png bmp !


