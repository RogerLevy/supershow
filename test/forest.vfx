private

: ~tree ( a - )
    a!>   @a+ @a+ at   @a+ >bmp @ cput ;

public

: ~forest  1 batch>  [: ~tree ;] forest each ;

\ ----------------------------------------------------
\ World integration
\ - Attachment point: forest.sys
\ - Provide Sprite records
\ - Provide Hitbox records

\ Static read-only data, so a single scratch record per kind suffices (a cohort
\ consumes each box/sprite before asking for the next).
%box-params    object forest-box
%sprite-params object forest-sprite

: row-size ( proto - w. h. )  
    >bmp @ ?dup if bmpwh 2>p else 16. 16. then ;

\ forest row = [ x:int , y:int , proto:addr ]
: row>box ( row - %box-params )
    a!> forest-box {
        a id !  1 msk !  1 lyr !  
        @a+ @a+ 2>p  @a+ row-size  box-around  x1 4!
        0. z1 !  64. z2 !
    this } ;

: row>sprite ( row - %sprite-params )
    a!> forest-sprite {
        a id !
        @a+ @a+ 2>p x 2!   0. z !
        @a+ dup >bmp @  bmp !   >prio @  prio !
    this } ;

c: %forest %system ;
%forest :: render  ~forest ;
%forest :: entity-count  ( - n )          forest #items ;
%forest :: entity-box    ( n - %box-params )     forest el@ row>box ;
%forest :: entity-sprite ( n - %sprite-params )  forest el@ row>sprite ;
%forest manager: forest.sys manager;