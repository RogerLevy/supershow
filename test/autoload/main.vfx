module [autoload-test]
import %supershow%/src/supershow.vfx

\ ---- Assets ----------------------------------------------------------------

bitmap %idir%/dat/gfx/icons1.png
icons1.png  16 16 tileset-from  icons1.ts

16 ttf-font %idir%/dat/fonts/Habbo.ttf

shader %idir%/dat/glsl/default.fs

sample %idir%/dat/smp/snd-02.ogg

\ ---- Display ---------------------------------------------------------------

: render
    cls
    Habbo.ttf
    0 0 at    s" Autoload test" print
    0 20 at   s" bitmap: icons1.png" print
    0 40 at   s" tileset: icons1.ts" print
    0 60 at   s" font: Habbo.ttf" print
    0 80 at   s" shader: " print
        ['] default.fs >body -> handle @ al_use_shader
        64 0 +at if s" OK" else s" FAILED" then print
        0 al_use_shader drop
    0 100 at  s" sample: snd-02.ogg" print
    vga-8x8 fnt!
    0 120 at
    8 0 do  icons1.ts i tile put  16 0 +at  loop ;

: main
    just
    show> render ;

main
