\ JSON level loader demo — scrolling multi-layer level + spawned actors.
\ Arrow keys scroll the camera (clamped to level bounds). The level is declared
\ as an embedded, auto-loading JSONFILE asset; build-level turns it into named
\ layer tilemaps (leveldemo-<layer>, e.g. leveldemo-big) and reset spawns its actors.

module
import %supershow%/src/supershow.vfx
import %supershow%/addons/shapes.vfx

bitmap %idir%/assets/gfx/greyzebes.png
greyzebes.png 16 16 tileset greyzebes.ts

JSONFILE %idir%/assets/levels/leveldemo.json  

0 value camx        \ camera origin (fixed pixels)
0 value camy

leveldemo.json level the-level

class: %blip  derive %actor  class;

%blip :: draw ( - )
    0 batch> $ff3030ff rgba8  6. circf ;

: scroll ( - )
    <right> held? if  4. +to camx  then
    <left>  held? if  -4. +to camx  then
    <down>  held? if  4. +to camy  then
    <up>    held? if  -4. +to camy  then
    camx camy the-level clamp-cam  to camy to camx
;

: think ( - )  step  scroll ;

: scrolled  camx@ camy@ 2negate 2p>f  1e 1e 0e  transform ;

: ~render ( - )
    camx camx!  camy camy!
    the-level render
    m{ scrolled sprites m}
;

: main ( - )
    the-level reset
    show> think ~render
;

main
