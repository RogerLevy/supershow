module
import %supershow%/src/supershow.vfx
import %supershow%/addons/shapes.vfx
public

bitmap %idir%/assets/gfx/sparkle.png

0 value cursor       \ orbiting target actor

class: %eyeball  %actor derive
    prop clr :int  \ iris color (rgba8 value)
    prop kxt :xt   \ xt: ( - flag ) button/key test
    prop lid :int  \ 0=open .. 15=closed
    prop lx :fixed \ local x offset from owner (pixels)
    prop ly :fixed \ local y offset from owner (pixels)
    prop owner :ref %actor    \ owner actor address or 0
class;

private

: trigger? ( - flag )   kxt @ ?execute ;

: ~lids ( - )
    {: | n cx cy :}
    lid @ to n
    at@ to cy to cx
    $c8a080ff rgba8
    cx 15 -`  cy 15 -`     at  30. n >p rectf
    cx 15 -`  cy 15 + n -` at  30. n >p rectf ;

\ Owner-relative positioning: eyeball.x = owner.x + lx, eyeball.y = owner.y + ly
\ If eyeballs needed to drift locally (e.g., float), you'd swap lx/ly with x/y
\ at the right moment rather than using them directly. Document this for future.
: eyeball-physics ( - )
    physics>
        owner @ -exit
        owner @ >x 2@  lx 2@  2+  x 2! ;

: ?close  trigger? -exit begin lid @ 15 < while yield 2 lid +! repeat ;
: ?open   trigger? ?exit begin lid @ 0 > while yield -2 lid +! repeat ;

%eyeball :: start ( - )
    eyeball-physics
    0 task>
        begin ?close ?open yield again ;

    \ act> 
    \     trigger? if  lid @ 15 < if 2 lid +! then
    \     else    lid @ 0>  if -2 lid +! then
    \     then ;

2variable laggard

: target ( - x. y. )
    <lmb> held? if mouse 2>p else cursor -> x 2@ then ;

: lag  laggard 2@ target 0.3 2plerp laggard 2! ;

: iris ( - x. y. ) 
    laggard 2@  x 2@ 2- angof  laggard 2@  x 2@ dist 10. min  vec ;

%eyeball :: draw ( - )
    0 batch>
    15 color  15. circf
    at@p
    clr @ rgba8  iris +atp  5. circf
    0 color  3. circf
    atp
    ~lids ;

public

\ Blink strategies: one per key. ' blink-q? stored in kxt, called each frame.
\ The strategy pattern means no subclassing — one class, 14 behaviors.
: blink-1?   <Q> held? ;
: blink-2?   <W> held? ;
: blink-3?   <E> held? ;
: blink-4?   <R> held? ;
: blink-5?   <T> held? ;
: blink-6?   <Y> held? ;
: blink-7?   <A> held? ;
: blink-8?   <S> held? ;
: blink-9?   <D> held? ;
: blink-10?  <F> held? ;
: blink-11?  <G> held? ;
: blink-12?  <H> held? ;
: blink-13?  <J> held? ;
: blink-14?  <K> held? ;

class: %sparkle  %actor derive class;

%sparkle :: start 
    sparkle.png bmp !
    act>  
        time 0.23 0.2 rnd + >= if me unload exit then
        0.09 vy +! ;

class: %cursor  %actor derive class;

%cursor :: start ( - )
    act>
        time 90. p*  100.  vec  160. 120. 2+  x 2!
        this 0 0 from  %sparkle one { 2.0 rnd 1.0 - vx !  this start } ;

0 value controller   \ owner actor providing reference position

: start-eyes ( - )
    $c8a080ff backdrop !

    -30 30 at  %actor spawn to controller
    160 120 at  %cursor spawn to cursor
    
    %eyeball one { ['] blink-1? kxt !   $ffff55ff clr !   64.  12. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-2? kxt !   $ffff55ff clr !  320.  12. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-3? kxt !   $0000ffff clr !  160.  96. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-4? kxt !   $0000ffff clr !  224.  96. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-5? kxt !   $00aa00ff clr !  128. 160. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-6? kxt !   $00aa00ff clr !  256. 160. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-7? kxt !   $ff8000ff clr !   64.  64. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-8? kxt !   $ff8000ff clr !   64. 128. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-9? kxt !   $ff8000ff clr !   32.  96. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-10? kxt !  $ff8000ff clr !   96.  96. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-11? kxt !  $55ff55ff clr !  320.  64. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-12? kxt !  $5555ffff clr !  320. 128. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-13? kxt !  $ff55ffff clr !  288.  96. lx 2!  controller owner !  this start }
    %eyeball one { ['] blink-14? kxt !  $ff5555ff clr !  352.  96. lx 2!  controller owner !  this start }

    work> step lag
    show> sprites
;

public

: main  start-eyes ;

main

cr
