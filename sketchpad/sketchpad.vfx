\ =============================================================================
\ Sketchpad — visual editor for tables (and, phase 2, scenes)
\ =============================================================================
\ design <table>   open a DATA: table for editing (table mode)
\ open <file>      open a scene (.json)            -- phase 2
\ save             write the current target        (ctrl+s)
\ saveas <file>    scene only                       -- phase 2
\
\ GUI: click=pick, dbl-click=jump-to-source (table), drag=move, ctrl+drag=copy,
\      del=delete, space+drag=pan, ctrl+s=save, ctrl+r=reload (table).
\ The clickable area of each actor comes from the table's pick-box hook.
\ =============================================================================

module [sketchpad]
import %supershow%/src/supershow.vfx
import %idir%/table-edit.vfx
import %supershow%/addons/shapes.vfx
import %supershow%/lib/help.vfx

private

\ ---- mode -------------------------------------------------------------------
1 constant +table
2 constant +scene
0 value mode
: in-table? ( - flag )  mode +table = ;

\ ---- state ------------------------------------------------------------------
0 value selected                 \ picked actor (0 = none)
0 value camx   0 value camy      \ camera origin, fixed pixels
0 value pressx  0 value pressy   \ screen pos at mouse-down (click vs drag)
0 value moved?                   \ has this drag passed the threshold
0 value copy-pending?            \ ctrl was down at mouse-down
0 value last-click-ms            \ for double-click detection
0 value last-actor
0 value panning?
0 value pan-lastx  0 value pan-lasty

1   constant drag-threshold      \ px of movement before a press becomes a drag
350 constant dclick-ms

\ ---- camera / mouse ---------------------------------------------------------
\ Pure translate camera: screen delta == world delta, so mickey moves actors 1:1.
: mouse-world ( - x. y. )  pmouse camx camy 2+ ;

\ ---- picking ----------------------------------------------------------------
: pick ( - actor|0 )
    0
    [: mouse-world  me the-table pick-box pt-rect? if  drop me  then ;] each-active
;

\ ---- copy / move ------------------------------------------------------------
: copy-selected ( - actor )  selected  one-copy ;   \ clone, stays on stage
: do-move ( - )  selected -exit  pmickey selected >x 2+! ;

: copy-it ( - )  copy-selected  dup selected insert-over  to selected ;

: bring-to-front ( - )  selected dup >parent @ push ;
: send-to-back ( - )  selected dup >parent @ unshift ;

\ ---- jump to source (table mode) --------------------------------------------
\ TODO: upgrade to work like LOCATE (configured editor + exact row, not block start).
: jump-to-source ( - )
    {: | zparams[ 256 ] :}
    
    the-table >src-line @  1 +  selected dup >parent @ indexof + 
    the-table >srcpath$ count
    f" -g %s:%n" zparams[ zplace

    console@  z" code"  zparams[  wd@ >zpad 
    1 ShellExecute drop
;

\ ---- pan on space + LMB drag (after GreySplatter try-pan) --------------------
: ?pan ( - flag )
    {: | mx my :}
    <space> held? <lmb> held? and 0= if  0 to panning?  0 exit  then
    mouse to my to mx
    panning? not if  mx to pan-lastx  my to pan-lasty  -1 to panning?  then
    pan-lastx mx -  >p +to camx
    pan-lasty my -  >p +to camy
    mx to pan-lastx  my to pan-lasty
    -1
;

\ ---- click / drag / double-click --------------------------------------------
: moved-far? ( - flag )
    mouse {: mx my :}
    mx pressx - abs  my pressy - abs  max  drag-threshold >
;

: on-press ( - )
    mouse to pressy to pressx
    0 to moved?
    ctrl? to copy-pending?
    pick to selected
;

: ?start-drag ( - )
    moved? ?exit
    moved-far? -exit
    -1 to moved?
    copy-pending? if  copy-it  0 to copy-pending?  then
;

: on-click ( - )                 \ a press that released without dragging
    selected -exit
    mstime last-click-ms -  dclick-ms <   selected last-actor =  and
    in-table? and if  jump-to-source  then
    mstime to last-click-ms  selected to last-actor
;

: ?mouse ( - )
    <lmb> pressed? if  on-press exit  then
    <lmb> held?    if  ?start-drag  moved? if do-move then  exit  then
    <lmb> letgo?   if  moved? not if on-click then  then
;

\ ---- key actions ------------------------------------------------------------
: do-save ( - )  in-table? if  write-back  then ;
: ?delete ( - )  <del> pressed? if  selected ?dup if  unload  0 to selected  then  then ;
: ?save   ( - )  ctrl? <S> pressed? and if  do-save  then ;
: ?reload ( - )  in-table? ctrl? <R> pressed? and and if  reload-table  then ;
: ?order  ( - )  <f> pressed? if bring-to-front then   <b> pressed? if send-to-back then ;
: ?home   ( - )  <home> pressed? if 0 to camx 0 to camy then ;

: input ( - )
    ?pan ?exit
    ?mouse  ?delete  ?save  ?reload  ?order  ?home
;

\ ---- render -----------------------------------------------------------------
: ~actors ( - )  [: me render  me the-table edit-update ;] each-active ;

: ~selection ( - )
    selected -exit
    selected the-table pick-box  {: x1 y1 x2 y2 :}
    15 color
    x1 y1 atp  x2 y2 x1 y1 2- rect
;

: ~edit ( - )
    m{  camx negate p>f  camy negate p>f  1e 1e 0e transform
        ~actors  ~selection
    m}
;

\ ---- commands ---------------------------------------------------------------
public

command : design ( - <table> )
    \ Open a DATA: table for editing (table mode).
    bl parse evaluate  edit-table  +table to mode
    show>  input  sweep  ~edit
;
