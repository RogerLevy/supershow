module [allegro5.utils]
import allegro5
public

\ =============================================================================
\ Color and position
\ =============================================================================

\ Color

ec-cell ppenr \ fixed
ec-cell ppeng \ fixed
ec-cell ppenb \ fixed
ec-cell ppena \ fixed
ec-cell ppenx \ fixed
ec-cell ppeny \ fixed

: rgba@sf
    ppenr@ p>f f>sf
    ppeng@ p>f f>sf
    ppenb@ p>f f>sf
    ppena@ p>f f>sf    
;

: rgba ( r. g. b. a. - )
    ppena! ppenb! ppeng! ppenr! ;

1. 1. 1. 1. rgba

: c>p  $ff and >p 0.5 + 255 / ; 
: p>c  255 * 0.5 + >i ;

: rgba8 ( n - )  
    dup c>p >r 8 >>
    dup c>p >r 8 >> 
    dup c>p >r 8 >> 
    c>p r> r> r> rgba ;

: rgba8@ ( - n )
    ppenr@ p>c 24 <<
    ppeng@ p>c 16 << or
    ppenb@ p>c 8 << or
    ppena@ p>c or ;

\ Position
: at ( x y - ) >p ppeny! >p ppenx! ;
: atp ( x. y. - ) ppeny! ppenx! ;
: penx@ ( - x ) ppenx@ >i ;
: peny@ ( - y ) ppeny@ >i ;
: at@ ( - x y ) penx@ peny@ ;
: at@p ( - x. y. ) ppenx@ ppeny@ ;
: at@f ( - f:x f:y ) ppenx@ p>f ppeny@ p>f ;
: +at ( x y - ) 2>p at@p 2+ atp ;
: +atp ( x. y. - ) at@p 2+ atp ;
: <at  you { ppenx@ ppeny@ } ppeny! ppenx! ;  \ hard-inherit pen position

\ =============================================================================
\ Drawing primitives
\ =============================================================================

: draw-bitmap ( albmp n - )
    over if at@f al_draw_bitmap else 2drop then ;

: *subbmp ( albmp w h - albmp' )
    at@ 2swap al_create_sub_bitmap ?dup 
    0= abort" al_create_sub_bitmap error" ;

: -albmp ( albmp - )
    ?dup -exit al_destroy_bitmap ;

: screen ( - )
    rgba@sf al_clear_to_color ;

variable backdrop  $000000ff backdrop !

redef : cls ( - )
    backdrop @ -exit
    e{ backdrop @ $ff or rgba8 screen e} ;

\ =============================================================================
\ Matrix stack
\ =============================================================================

|| create mstk 16 cells 16 * allot
|| create m2 16 cells allot
|| variable mp
|| variable tx variable ty
|| : m mp @ 15 and 16 cells * mstk + ; 

: m{ ( - a )
    m dup   1 mp +!   m swap al_copy_transform ;

: m} ( a - )
    mstk - 16 cells / mp !   m al_use_transform ;

: transform ( f:x f:y f:sx f:sy f:a - )
    m2 al_build_transform  m2 m al_compose_transform  m m2 al_copy_transform
    m al_use_transform ;

: identity ( - )
    m al_identity_transform  m al_use_transform ;

: 2p*m ( x. y. - x. y. )
    2p>f ty sf! tx sf!  m tx ty al_transform_coordinates
    tx sf@ f>p ty sf@ f>p ;

: inverse ( - )
    m al_invert_transform ;

: translate3d ( f:x f:y f:z - )
    m al_translate_transform_3d  m al_use_transform ;

: rotate3d ( f:cx f:cy f:cz f:angle - )
    m al_rotate_transform_3d  m al_use_transform ;

: scale3d ( f:sx f:sy f:sz - )
    m al_scale_transform_3d  m al_use_transform ;

\ =============================================================================
\ Stencil-buffer quad clipping
\ =============================================================================
\ Requires display created with ALLEGRO_STENCIL_SIZE set (e.g., 8)

\ Stencil clipping resets the Allegro clip rect for a clean mask setup, so clip{
\ stashes the ambient rect (e.g. the TV border's scissor) and clip} restores it
\ -- otherwise drawing after the scope (sprites) escapes the border. A stack, not
\ one slot, because clip scopes nest (workzone): each scope restores the rect that
\ was ambient at ITS entry.
|| aligned-page clipstk
|| variable clipsp   clipstk clipsp !

|| : save-cliprect ( - )      \ push the current Allegro clip rect
    clipsp @ dup cell+ dup cell+ dup cell+ al_get_clipping_rectangle
    4 cells clipsp c+! ;

|| : restore-cliprect ( - )   \ pop and reinstate the saved clip rect
    -4 cells clipsp c+!
    clipsp @ 4@ al_set_clipping_rectangle ;

: clip{ ( x. y. w. h. - )
    ec>
    2swap atp
    save-cliprect
    $FF glStencilMask  \ Clear stencil to 0 (enable writes first, reset clipping rect)
    al_reset_clipping_rectangle
    \ Clear stencil AND depth together: on a combined depth-stencil buffer (used
    \ whenever a 3D program shares the display), clearing just one plane can
    \ desync the driver's compression/fast-clear metadata for the pair, corrupting
    \ later depth-test results once 3D rendering resumes. Depth test is off during
    \ 2D drawing, so clearing depth here has no effect on this scope's own drawing.
    GL_STENCIL_BUFFER_BIT GL_DEPTH_BUFFER_BIT or glClear
    GL_STENCIL_TEST glEnable  \ Enable stencil test
    GL_ALWAYS 1 $FF glStencilFunc  \ Always pass, write 1 to stencil
    GL_KEEP GL_KEEP GL_REPLACE glStencilOp
    $FF glStencilMask
    ALLEGRO_WRITE_MASK 0 al_set_render_state \ Disable color writes for mask
    $FFFFFFFF rgba8  \ Draw mask rectangle (writes 1 to stencil where drawn)
    at@f   at@p 2+ 2p>f   rgba@sf al_draw_filled_rectangle
    ALLEGRO_WRITE_MASK ALLEGRO_MASK_RGBA al_set_render_state \ Re-enable color writes
    GL_EQUAL 1 $FF glStencilFunc  \ Only pass where stencil == 1
    GL_KEEP GL_KEEP GL_KEEP glStencilOp
    0 glStencilMask ;

: clip} ( - )
    GL_STENCIL_TEST glDisable
    $FF glStencilMask
    restore-cliprect ;

\ =============================================================================
\ Text
\ =============================================================================

\ Variables

\ || variable rmargin
variable line-spacing  8 line-spacing !
variable default-font
: default-font@  default-font @ ;
: default-font!  default-font ! ;

\ Text rendering

: mltext ( a len w - )
    {: a len w | lh zstr :}
    a len or -exit
    a len *zbuf to zstr
    w s>f f>sf to w
    line-spacing @ s>f f>sf to lh 
    default-font@  rgba@sf  at@f w lh 0 zstr al_draw_multiline_text 
    zstr free throw ;

: print ( a len - )
    winw penx@ - mltext ;

: print2 ( a len line-spacing - )
    line-spacing @ >r line-spacing !
    print
    r> line-spacing ! ;

: textw ( a n - n )
    *zbuf >r  default-font@  r@  al_get_text_width  r> free throw ;  

: textbox ( a n - x y w h )
    \ TODO: Support multiline text (need to use al_do_multiline_text)
    {: | buf[ 16 ] :}
    *zbuf >r
    default-font@  r@  buf[ dup cell+ dup cell+ dup cell+ al_get_text_dimensions
    r> free throw
    buf[ @+ swap @+ swap @+ swap @ ;

: fnt|default ( font|0 - font )   dup 0= if drop default-font@ then ;

: glyph ( n font|0 - )
    swap >r fnt|default rgba@sf at@f r> al_draw_glyph ;

: glyph+ ( n font|0 - )
    2dup glyph  fnt|default swap 0 al_get_glyph_advance 0 +at ;