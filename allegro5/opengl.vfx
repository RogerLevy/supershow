\ OpenGL bindings (opengl32.dll, stdcall on Windows)
public

extern stdcall void glDepthRange( double nearVal, double farVal );
extern stdcall void glEnable( int cap );
extern stdcall void glDisable( int cap );
extern stdcall void glClear( int mask );
extern stdcall void glStencilFunc( int func, int ref, int mask );
extern stdcall void glStencilOp( int sfail, int dpfail, int dppass );
extern stdcall void glStencilMask( int mask );
extern stdcall void * glGetString( int name );
extern stdcall int glGetError( );
extern stdcall int glIsEnabled( int cap );
extern stdcall void glGetIntegerv( int pname, void * params );
extern stdcall void glViewport( int x, int y, int w, int h );
extern stdcall void glTexParameteri( int target, int pname, int param );
extern stdcall void glTexParameterf( int target, int pname, float param );
extern stdcall void glBindTexture( int target, int texture );
extern stdcall void glGenTextures( int n, void* textures );
extern stdcall void glDeleteTextures( int n, void* textures );
extern stdcall void glPixelStorei( int pname, int param );

\ OpenGL 1.2+ functions not exported from opengl32.dll — loaded at runtime
0 value _pfn-glActiveTexture
0 value _pfn-glTexImage3D
0 value _pfn-glTexSubImage3D

: glActiveTexture ( texture - )
    _pfn-glActiveTexture  1  NXCALL drop ;

: glTexImage3D ( data type format border depth height width internalformat level target - )
    _pfn-glTexImage3D  10  NXCALL drop ;

: glTexSubImage3D ( data type format depth height width zoffset yoffset xoffset level target - )
    _pfn-glTexSubImage3D  11  NXCALL drop ;

: init-gl-extensions ( - )
    z" glActiveTexture"   al_get_opengl_proc_address  to _pfn-glActiveTexture
    z" glTexImage3D"      al_get_opengl_proc_address  to _pfn-glTexImage3D
    z" glTexSubImage3D"   al_get_opengl_proc_address  to _pfn-glTexSubImage3D ;

