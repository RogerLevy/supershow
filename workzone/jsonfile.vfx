REQUIRE %vfxland5%/supershow/traits.vfx
REQUIRE %vfxland5%/supershow/autoload.vfx
REQUIRE %vfxland5%/cjson/cjson2.vfx

public

class: %jsonfile
    %asset derive
    is-a %autoload
    is-a %loadable
    prop json :addr

    : _load-json ( - )
        this @data parse-json json ! ;

    :: on-startup ( - )
        ." Loading JSON data " this .name cr
        _load-json ;

class;

: JSONFILE ( <path> - )
    bl parse 2dup -path %jsonfile ASSET { embed _load-json } ;