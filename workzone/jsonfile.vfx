REQUIRE %supershow%/supershow/traits.vfx
REQUIRE %supershow%/supershow/autoload.vfx
REQUIRE %supershow%/cjson/cjson.vfx

public

\ %jsonfile / JSONFILE were promoted into the engine (src/autoload.vfx). Define
\ here only if the engine layer isn't already present.
[undefined] %jsonfile [if]
class: %jsonfile
    %asset derive
    is-a %autoload
    is-a %loadable
    prop json :addr

    : _load-json ( - )
        this @data parse-json json ! ;

    :: on-startup ( - )
        ." Loading JSON data " this .name cr
        _load-json ;

class;

: JSONFILE ( <path> - )
    bl parse 2dup -path %jsonfile ASSET { embed _load-json } ;
[then]