((
An icon in this system is an element that opens something when double-clicked.
Some examples of icons:
    - Open file in another application
    - Load file and edit in Workspace
    - Start a Workspace application or applet (such as a dialog to create a widget)
))

scope

bitmap: %idir%/gui-icons.png
gui-icons.png 20 20 tileset: gui-icons.ts
: gui-icon  gui-icons.ts swap tile ;

: shell-open ( fp len - )
    >zpad   0 "open" rot  0 0 SW_SHOWNORMAL ShellExecute drop ;


\ Icon Font
private:
    create _habbo.ttf
    here s" %idir%\habbo.ttf" file,
    here swap - constant /habbo.ttf
private;
0 value habbo.ttf

: init-icon-font
    _habbo.ttf /habbo.ttf memfile@  \ not to be freed or else CRASH
        0 16 ALLEGRO_TTF_MONOCHROME al_load_ttf_font_f to habbo.ttf ;
     
init-icon-font

%element subclass: %icon
    cstring-prop srcpath$
    :: clickbox  abspos 20. 20. box ;

    private: 
        create gui-icons wordlist +order definitions
            : vfx  0 ;
            : txt  0 ;
            : figj  1 ;
        previous definitions

        : file-icon  ext gui-icons find-in dup if execute then gui-icon ;

        create file-actions wordlist +order definitions
            : vfx  shell-open ;
            : txt  shell-open ;
            : figj  desktop { load-figure add } ;
        previous definitions

        : file-action ( fp len ) 
            2dup ext file-actions find-in ?dup if execute else 2drop then ;

        : label  e{ habbo.ttf fnt! 0 20 +at srcpath$ count -path print e} ;
        : icon  srcpath$ count file-icon put ;
        : arrow  parent @ {: p :} p %icon is? -exit p white-connector ;
    private;

    :: _draw
        at-me icon arrow white label ;
    :: dclick ( btn - ) 
        lmb = -exit
        srcpath$ count file-action ;
class;

: add-icons ( - )
    {: | dialog :}
    0 z" Select files" z" *.*"
    ALLEGRO_FILECHOOSER_MULTIPLE ALLEGRO_FILECHOOSER_FILE_MUST_EXIST or
    al_create_native_file_dialog to dialog
    display dialog al_show_native_file_dialog drop
    dialog al_get_native_file_dialog_count for
        dialog i al_get_native_file_dialog_path zcount
        desktop { center } 0 i 40 * 2+ at %icon make { srcpath$ place me } desktop push
    loop
    dialog al_destroy_native_file_dialog ;
