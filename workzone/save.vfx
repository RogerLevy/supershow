\ =============================================================================
\ Save/Load System for Element Trees
\ =============================================================================

require %vfxland5%/forge/nibs-json.vfx

\ -- Serialization ------------------------------------------------------------

0 value serializing-root?

\ Serialize element with children recursively
defer _element>json
: element>json ( element is-root? - cjson )
    {: el is-root? | cjson children-arr :}
    is-root? to serializing-root?
    el *json to cjson
    false to serializing-root?

    \ Add children array if element has children
    \ Skip children only for external elements that are not the root
    el #children 0> el external? not is-root? or and if
        cjson-new-array to children-arr
        el >lowest @
        el #children for
            dup { temporary? } not if
                dup .summary cr
                dup false _element>json 0 children-arr cjson-add-object
            then
            >next @
        loop
        drop
        children-arr "children" cjson cjson-add-array
    then
    cjson ;
['] element>json is _element>json

\ -- Deserialization ----------------------------------------------------------

\ Deserialize JSON to element, reconstructing hierarchy
defer _json>element
: json>element ( cjson - element )
    {: cjson :}

    \ Get class name and instantiate
    cjson "class" j>s evaluate make {
        \ Read properties into the new element
        cjson this read-props

        \ Cache the script field if there is one
        cjson "script" ?j>z ?dup if
            zcount *lstring script !
        then

        \ Recursively create children
        cjson "children" ?j>j ?dup if
            jcount for
                dup i j>j _json>element this push
            loop drop
        then
    this } ;

['] json>element is _json>element

\ -- High-level API -----------------------------------------------------------

: save-gui ( element path len - )
    {: el path len :}
    len 0= abort" SAVE-GUI : Path is empty!"
    path len f" SAVE-GUI %s" type cr
    path len [: >r  el true element>json "root" r> cjson-add-object ;] serjson ;

: load-root ( json - element )
    "root" j>j json>element ;

: load-autoloads ( json - )
    "autoloads" ?j>j ?dup if
        [: j>s ['] .evaluate catch if 2drop then ;] jeach
    then ;

: load-gui ( json - element )
    dup load-autoloads load-root ;
