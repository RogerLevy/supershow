\ ==============================================================================
\ Workspace IDE
\ ==============================================================================

\ -- Dependencies --------------------------------------------------------------

REQUIRE %supershow%/supershow/traits.vfx
REQUIRE %supershow%/supershow/bitmap.vfx
REQUIRE %supershow%/supershow/sprites.vfx
REQUIRE %supershow%/supershow/tileset.vfx
REQUIRE %supershow%/supershow/autoload.vfx
REQUIRE %idir%/shapes.vfx
REQUIRE %idir%/arrow.vfx
REQUIRE %idir%/colors.vfx
\ REQUIRE %idir%/gui.vfx    \ For now, rely on micros.vfx to load this due to a current limitation of NIBS
REQUIRE %idir%/micros.vfx
REQUIRE %idir%/painter.vfx
REQUIRE %idir%/togglebox.vfx
REQUIRE %idir%/icon.vfx

\ -- Bookmark -----------------------------------------------------------------

class: %bookmark
    %label derive
    prop dx :fixed <save
    prop dy :fixed <save

    :: handy?  true ;

    || 2. constant m

    :: clickbox ( - x1 y1 x2 y2 )
        abspos m m 2- w 2@ m m 2 2 2* 2+ box ;

    :: _draw
        _update-box
        m >i negate dup +at
        light-green w 2@ m m 2 2 2* 2+ rectf
        black w 2@ m m 2 2 2* 2+ rect
        m m 2>i +at
        black _draw-text ;
    
    :: _mousedown ( btn - ) drop ;

    :: click ( btn - )
        lmb = -exit
        \ bolted? not shift? not and ?exit
        dx 2@ desktop >x 2! ;

    : bookmark,
        you [:
            desktop -> x 2@ dx 2!
        ;] s" Bookmark" option ;

    :: _context-menu ( menu - )
        as>
        bookmark,
        common-options, ;
class;

\ -- Main Loop ----------------------------------------------------------------

: handle-dhud-toggle
    <tilde> pressed? shift? and -exit
    dhud -exit
    dhud { opened? if this close else this open then } ;

: saveas...
    0 z" Save workspace as..." z" *.wsj" save-dialog
    dup if 
        -ext f" %s.wsj" sessionpath$ place -1
    else 
        2drop 0
    then ;

: loadws
    {: | zbuf[ 1024 ] :}
    0 z" Load Workspace" z" *.json;*.wsj" load-dialog
    dup if 
        \ save-all
        -ext f" %s.wsj" load-session
    else
        2drop 
    then 
;

: saveas?  shift? sessionpath$ c@ 0= or ;

: ?load  <o> pressed? ctrl? and -exit loadws ;

: ?save  <s> pressed? ctrl? and -exit saveas? if saveas... -exit then save-all ;

require %idir%/overview.vfx

: workspace
    display al_hide_mouse_cursor
    2 user-zoom !
    show>
        overview @ if
            draw-overview
        else
            session ?dup if 0 0 at draw then
            0 0 at session gui-overlay
            draw-cursor
        then
    work>
        get-mouse
        overview @ if
            ?overview-toggle
            overview @ if overview-nav then
        else
            desktop ?dup if decay-gui then
            session ?dup if process-gui then
            handle-dhud-toggle
            update-dhud
            ?save ?load
            ?overview-toggle
        then ;

workspace

\ -- Misc ---------------------------------------------------------------------

[:
    default-sticky,
    you { bolted? } ?exit
    you dhud descendant? ?exit
    you [: abspos this dhud push x 2! ;] s" Desktop Sticky" option
;] is sticky,

[:
    dup hud descendant? if
        {
            desktop relpos
            this desktop push
            x 2!
        }
    else 
        drop
    then
;] is cloned

: wide
    display ALLEGRO_FRAMELESS true al_set_display_flag drop
    display -1920 0 al_set_window_position
    display ALLEGRO_MAXIMIZED true al_set_display_flag drop
    display 1920 2 * 1060 al_resize_display drop
    display ALLEGRO_FRAMELESS true al_set_display_flag drop
;

redef : switch ( n - )
    0 9 clamp session el@ to desktop
    0 to the-dhud ; 

: absmouse ( - x y ) 
    pmouse desktop >x 2@ 2- 2>i ;

: tidy 
    [: [ here ]  { temporary? if this unload then  literal this each } ;] session each ;

\ -- Instructions---------------------------------------------------------------

cr
cr
." Workspace Controls: " cr
."  Tab - Toggle using/designing mode (hold+click for temporary toggle)" cr
."  Tilde - Toggle the global HUD" cr
."  LMB - designing: select, drag   using: use" cr
."  Ctrl + LMB - clone" cr
."  Shift + LMB - designing: use  (deprecated)" cr
."  RMB - designing: context menu" cr
."  Shift+RMB - designing: inspect" cr
."  Del - designing: delete selected elements" cr
cr

