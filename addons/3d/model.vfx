module

\ 3D model system, ported from Ramen's 3dpack (model.f + 3dpack.f).
\
\ Coordinates are floats (see lib/v3d.vfx): no 16.16 overflow ceiling, and
\ Allegro's transform/primitive APIs are float-native. Per the VFX FFI
\ convention, pointer/int args ride the DATA stack and `float` args ride the
\ x87 FLOAT stack -- so a vector is pushed for an Allegro call with `3sf@`
\ (components onto the float stack) while the transform pointer stays on data.

import %supershow%/src/supershow.vfx
import allegro5
import %supershow%/lib/v3d.vfx
import %supershow%/lib/colors.vfx
reexport [v3d]      \ model API exposes v3d positions/scales; callers need its ops
reexport [colors]   \ models are authored with named color words
public

\ ---- primitive-type aliases ----
ALLEGRO_PRIM_LINE_LIST      constant LINE_LIST
ALLEGRO_PRIM_LINE_STRIP     constant LINE_STRIP
ALLEGRO_PRIM_LINE_LOOP      constant LINE_LOOP
ALLEGRO_PRIM_TRIANGLE_LIST  constant TRIANGLE_LIST
ALLEGRO_PRIM_TRIANGLE_STRIP constant TRIANGLE_STRIP
ALLEGRO_PRIM_TRIANGLE_FAN   constant TRIANGLE_FAN
ALLEGRO_PRIM_POINT_LIST     constant POINT_LIST

\ ---- transform buffers (ALLEGRO_TRANSFORM = 4x4 floats = 64 bytes) ----
64 constant s/transform
: transform: ( <name> - )  create here s/transform allot al_identity_transform ;
transform: p        \ projection
transform: t        \ scratch model rotation
transform: t2       \ scratch model compose
transform: camt     \ camera transform (identity until a camera writes it)
transform: modelmat \ object->world for the current model (captured by modelview, for lighting)
create axis s/v3d allot

\ ---- angle helper ----
0.0174532925e fconstant (deg>rad)
: deg>rad ( f: deg - rad )  (deg>rad) f* ;

\ ---- float floor / wrap (true floor, so negative coords wrap seamlessly) ----
: ffloor ( f: x - floor )
    fdup ftrunc  fover fover f< if 1e f- then  fswap fdrop ;
: fwrap ( f: x m - x-floor[x/m]*m )
    fover fover f/ ffloor f* f- ;

\ ---- projection setup ----
80 value fov
|| 0e fvalue focal
|| 0e fvalue aspect
: 3d ( - )
    fov s>f deg>rad 2e f/ ftan to focal
    \ aspect from the actual render target (the display backbuffer), so it stays
    \ correct in fullscreen (monw x monh) instead of stretching to a fixed game ratio
    al_get_target_bitmap dup al_get_bitmap_width s>f al_get_bitmap_height s>f f/ to aspect
    p al_identity_transform
    p 0e 0e -1e al_translate_transform_3d
    p  aspect focal f* fnegate  focal  1e
       aspect focal f*  focal fnegate  32768e  al_perspective_transform
    p al_use_projection_transform
    ALLEGRO_DEPTH_TEST 1 al_set_render_state
    1e al_clear_depth_buffer ;

: 2d ( - )
    p al_identity_transform
    p 0e 0e -16384e  gamew s>f gameh s>f 16384e  al_orthographic_transform
    p al_use_projection_transform
    ALLEGRO_DEPTH_TEST 0 al_set_render_state ;

\ ---- mesh data (the vertex/index buffers; distinct from the %model object) ----
\ layout (5 cells): vptr vcount iptr icount primtype
\ vptr/vcount are adjacent (>vertices 2@), iptr/icount are adjacent (>indices 2@)
: >vertices ( mesh - a )  ; immediate
: >vcount   ( mesh - a )  cell+ ;
: >indices  ( mesh - a )  2 cells + ;
: >icount   ( mesh - a )  3 cells + ;
: >primtype ( mesh - a )  4 cells + ;
: mesh ( primtype - )  0 , 0 , 0 , 0 , , ;   \ use after `create name`

\ ---- custom vertex format: ALLEGRO_VERTEX (x y z u v r g b a) + face normal (nx ny nz) ----
\ The flat-shading shader needs a per-face normal but the mesh data carries none, so we
\ append one to each vertex (the ALLEGRO_VERTEX prefix is kept intact, so uv/color stay
\ available for the TODO textured path). The normal is left zero by `v,` and filled in at
\ build time by `gen-normals`. It rides in al_user_attr_0 (a FLOAT_3 user attribute).

/ALLEGRO_VERTEX 3 cells +  constant s/modelvertex     \ 36 + 12 = 48 bytes per vertex

|| : >vnormal ( vtx - a )  36 + ;

|| create mvtx-vdecl
    ALLEGRO_PRIM_POSITION    , ALLEGRO_PRIM_FLOAT_3 ,  0 ,
    ALLEGRO_PRIM_TEX_COORD   , ALLEGRO_PRIM_FLOAT_2 , 12 ,
    ALLEGRO_PRIM_COLOR_ATTR  , 0                    , 20 ,
    ALLEGRO_PRIM_USER_ATTR   , ALLEGRO_PRIM_FLOAT_3 , 0 >vnormal ,
    0 , 0 , 0 ,

|| 0 value mvtx-decl    \ ALLEGRO_VERTEX_DECL*; built lazily once the display exists

|| : mvtx-decl@ ( - decl )
    mvtx-decl ?dup ?exit
    mvtx-vdecl s/modelvertex al_create_vertex_decl  dup to mvtx-decl ;

\ ---- vertex / index builders ----
\ A vertex is an ALLEGRO_VERTEX record (x y z u v r g b a) plus a 3-float normal slot.
\ v, takes 16.16-fixed coords (kept small in the data files) and the current pen color
\ (set by a color word) for the four color components; the normal is zeroed here.
: f, ( f: x - )  f>sf , ;
: v, ( px. py. pz. pu. pv. - )
    {: px py pz pu pv :}
    px p>f f,  py p>f f,  pz p>f f,  pu p>f f,  pv p>f f,
    rgba@sf  >r >r >r >r  r> , r> , r> , r> ,
    0e sf, 0e sf, 0e sf, ;          \ normal placeholder -- filled by gen-normals

\ ---- face-normal generation (build time, once per mesh; never per frame) ----
\ For each triangle, write the unit object-space face normal into all three of its
\ vertices (flat shading). Handles indexed and non-indexed TRIANGLE_LIST; no-ops on
\ any other primtype (e.g. the grid's LINE_LIST). Winding assumed CCW-outward: if a
\ model lights inverted, swap the cross operands below.
|| : nth-vtx  ( mesh n - vtx )  s/modelvertex *  swap >vertices @ + ;
|| : face-normal ( va vb vc - )
    {: va vb vc | n :}
    vb va v-                  \ e1 = vb - va  (scratch)
    vc va v-                  \ ( e2 e1 ) -> vcross does dest x src = e1 x e2
    swap vcross vnormalize to n
    n va >vnormal v!
    n vb >vnormal v!
    n vc >vnormal v! ;

: gen-normals ( mesh - )
    {: m | ip :}
    m >primtype @ TRIANGLE_LIST <> if exit then
    m >indices @ if
        m >indices @ to ip
        m >icount @ 3 / 0 ?do
            m  ip i 3 * cells +           @ nth-vtx
            m  ip i 3 * cells + cell+     @ nth-vtx
            m  ip i 3 * cells + 2 cells + @ nth-vtx
            face-normal
        loop
    else
        m >vcount @ 3 / 0 ?do
            m  i 3 *     nth-vtx
            m  i 3 * 1 + nth-vtx
            m  i 3 * 2 + nth-vtx
            face-normal
        loop
    then ;


: vertices: ( mesh - mesh start )  here  2dup swap >vertices !  white ;
: ;vertices ( mesh start - )       udup  here swap -  s/modelvertex /  swap >vcount !  gen-normals ;
: indices:  ( mesh - mesh start )  here  2dup swap >indices ! ;
: ;indices  ( mesh start - )       udup  here swap -  cell /  swap >icount !   gen-normals ;


\ ---- model object ----
class: %model  %actor derive
    v3d-prop pos
    v3d-prop scl
    v3d-prop vel        \ 3D velocity (3D physics adds this to pos)
    prop tilt :fixed
    prop pan  :fixed
    redef prop roll :fixed
    prop msh  :addr     \ pointer to mesh data (vertices/indices/primtype)
    prop tex  :int

    template { 
        1. 1. 1. scl v.xyz! 
        : simple-motion-3d   vel pos v+! ;
        ['] simple-motion-3d phys !
    }
class;

\ The following assume `this` is bound to a %model (call via draw-model).
: texture@ ( - bmp )  tex @ ;   \ 0 = untextured; bmpid->ALLEGRO_BITMAP* is a TODO

: modelview ( - )
    t al_identity_transform
    t  0e 0e 1e  roll @ p>f deg>rad   al_rotate_transform_3d
    t  0e 1e 0e  pan  @ p>f deg>rad   al_rotate_transform_3d
    1e 0e 0e axis 3sf!
    t  axis v.x  axis v.y  axis v.z  al_transform_coordinates_3d
    t  axis 3sf@  tilt @ p>f deg>rad  al_rotate_transform_3d
    t2 al_identity_transform
    t2 scl 3sf@ al_scale_transform_3d
    t2 t al_compose_transform
    t2 pos 3sf@ al_translate_transform_3d
    t2 modelmat s/transform move        \ t2 is now object->world; stash it before the camera folds in
    t2 camt al_compose_transform
    t2 al_use_transform ;

\ ---- per-model uModel upload ----
\ Goes straight to glUniformMatrix4fv rather than al_set_shader_matrix: Allegro's by-name
\ uniform lookup + deferred-uniform bookkeeping ran ~23us/call, which at one call per model
\ dominated the whole frame (100 models -> ~2.3ms). The direct upload is ~free.
\ The location is cached once against the program current at first call (the flat shader, set
\ by `shade`). That's correct while a single shader owns uModel; a second uModel-using shader
\ would need the cache keyed per program.
|| variable _prog
|| 0 value uModel-loc
|| false value uModel-cached?
: model-matrix! ( transform - )            \ transform = object->world (modelmat)
    uModel-cached? not if
        init-gl-extensions
        GL_CURRENT_PROGRAM _prog glGetIntegerv
        z" uModel" _prog @ glGetUniformLocation  to uModel-loc
        true to uModel-cached?
    then
    0 1 uModel-loc glUniformMatrix4fv ;     \ ( value transpose count location )

: ~model
    msh @ -exit
    msh @ >indices @ if
        msh @ >vertices @  mvtx-decl@  texture@  msh @ >indices 2@  msh @ >primtype @
            al_draw_indexed_prim drop
    else
        msh @ >vertices 2@  >r  mvtx-decl@  texture@  0  r>  msh @ >primtype @
            al_draw_prim drop
    then ;

\ draw the primitive -- modelview is assumed already applied (by render)
%model :: draw ( - )
    ~model ;

\ 3D render entry: overrides actor:render (no 2D pen) -- just transform + draw
%model :: render ( - )
    msh @ -exit  modelview  this draw ;

