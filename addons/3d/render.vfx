module
import %supershow%/src/supershow.vfx
import %supershow%/addons/3d/model.vfx
import allegro5
reexport [model]    \ render's API is built on the model pack; expose it to importers
public

\ Stage-based 3D renderer: draws the %model actors on the stage, depth-sorted
\ back-to-front (we don't rely on a depth buffer). Reuses the same sorted-actors>
\ machinery SPRITES uses, keyed on distance from the camera.

\ ---- camera ----
create campos s/v3d allot      \ camera world position, mirrored here for the sort
0 value the-cam                 \ the camera %model (set by the program)

\ Build camt as the INVERSE of the camera's world placement (this = camera).
: camt-rotations ( - )      \ apply the inverse camera rotations to camt
    camt 0e 0e 1e  roll @ p>f deg>rad fnegate  al_rotate_transform_3d
    camt 0e 1e 0e  pan  @ p>f deg>rad fnegate  al_rotate_transform_3d
    camt 1e 0e 0e  tilt @ p>f deg>rad fnegate  al_rotate_transform_3d ;

: camera-transform ( - )
    camt al_identity_transform
    camt  pos v3d.x sf@ fnegate  pos v3d.y sf@ fnegate  pos v3d.z sf@ fnegate
        al_translate_transform_3d
    camt-rotations ;

: update-camera ( - )
    the-cam ?dup -exit
    { camera-transform  pos 3@ campos 3! } ;

\ ---- camt save/restore + wrapped variant (for the infinite grid floor) ----
create camt-save-buf s/transform allot
: camt-save ( - )     camt camt-save-buf s/transform move ;
: camt-restore ( - )  camt-save-buf camt s/transform move ;

0e fvalue gwrap
: wrap-camt ( f: wrap - )    \ rebuild camt from the-cam, XZ position wrapped mod wrap
    to gwrap
    the-cam {
        camt al_identity_transform
        camt  pos v3d.x sf@ gwrap fwrap fnegate
              pos v3d.y sf@ fnegate
              pos v3d.z sf@ gwrap fwrap fnegate
            al_translate_transform_3d
        camt-rotations
    } ;

\ ---- spawning ----
: between ( lo hi - n )  over - 1+ rnd + ;
: *model ( mesh - model )  %model one  dup >r >msh !  r> ;

\ ---- depth-sorted draw ----
\ key = distance from camera
\ non-%model actors (e.g. %smoother) sort first and aren't drawn.
: depth-key ( actor - n )
    dup %model is? not if drop 0 exit then
    -> pos campos v3dist  0 65535 clamp  ; \ 65535 swap - ;

: draw-models ( - )  ['] depth-key sorted-actors> this %model is? if this render then ;

: render-scene ( - )
    3d  update-camera  draw-models ;
