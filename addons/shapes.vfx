module [shapes]
import [supershow.actor]
import allegro5

public

ec-cell thickness
0.5 thickness!

: thick ( n. - )
    thickness! ;

: circ ( radius. - )
    thickness@ p>f f>sf >r   at@f p>f rgba@sf r> al_draw_circle ;

: circf ( radius. - )
    at@f p>f rgba@sf al_draw_filled_circle ;

: oval ( radiusx. radiusy. - )
    thickness@ p>f f>sf >r   at@f 2p>f rgba@sf r> al_draw_ellipse ;

: ovalf ( radiusx. radiusy. - )
    at@f 2p>f rgba@sf al_draw_filled_ellipse ;

: line ( x. y. - )
    thickness@ p>f f>sf >r   at@f   2p>f  rgba@sf r> al_draw_line ;

: rect ( w. h. - )
    thickness@ p>f f>sf >r   at@f   at@p 2+ 2p>f   rgba@sf r> al_draw_rectangle ;

: rectf ( w. h. - )
    at@f   at@p 2+ 2p>f   rgba@sf al_draw_filled_rectangle ;

|| : f>c  255e f* 0.5e f+ f>s ;

: f>rgba8 ( f:r f:g f:b f:a - n )
    f>c
    f>c 8 << or
    f>c 16 << or
    f>c 24 << or ;

: pixel@ ( bmp x y - rgba8 )
    {: b x y | buf[ 16 ] :}
    buf[ b x y al_get_pixel
    buf[ 4f@ f>rgba8 ;

|| : 2sf!+ ( a f:x f:y - a' )
    fswap sf!+ sf!+ ;

ec-cell ppenu
ec-cell ppenv

: uv ( u. v. - )
    ppenv! ppenu! ;

|| : vertex ( a x. y. - a' )
    2p>f 2sf!+
    0e sf!+
    ppenu@ p>f sf!+  ppenv@ p>f sf!+
    ppenr@ p>f sf!+  ppeng@ p>f sf!+  ppenb@ p>f sf!+  ppena@ p>f sf!+ ;

: poly ( poly -- )
    {: poly | vtxs[ 1152 ] :}
    vtxs[
    poly -> pg.n @ 0 ?do
        poly i pg.vert 2@  at@p 2+  vertex
    loop
    drop
    vtxs[ 0 0 0 poly -> pg.n @ ALLEGRO_PRIM_LINE_LOOP al_draw_prim drop ;

: polyf ( poly -- )
    {: poly | vtxs[ 1152 ] :}
    vtxs[
    poly -> pg.n @ 0 ?do
        poly i pg.vert 2@  at@p 2+  vertex
    loop
    drop
    vtxs[ 0 0 0 poly -> pg.n @ ALLEGRO_PRIM_TRIANGLE_FAN al_draw_prim drop ;

: pixel ( - )
    at@f rgba@sf al_draw_pixel ;

|| : fvertex ( f:x f:y f:u f:v a - a' )
    {: f: x f: y f: u f: v :}
    x sf!+  y sf!+
    0e sf!+
    u sf!+  v sf!+
    ppenr@ p>f sf!+  ppeng@ p>f sf!+  ppenb@ p>f sf!+  ppena@ p>f sf!+ ;

\ : vdump ( a n - )
\     for
\         9 for sf@+ f. loop cr
\     loop ;tm

: texrectf ( bmp w h - )
    {: bmp iw ih | f: x f: y f: w f: h f: u f: v vtxs[ 256 ] :}
    iw ih 2s>f to h to w
    ppenu@ ppenv@ p>f to v p>f to u
    at@f to y to x
    vtxs[
        x y           u v fvertex
        x y h f+      u v h f+ fvertex
        x w f+ y h f+ u w f+ v h f+ fvertex
        x w f+ y      u w f+ v fvertex
    drop
    vtxs[ 0 bmp id>albmp 0 4 ALLEGRO_PRIM_TRIANGLE_FAN al_draw_prim
    0= abort" al_draw_prim failure" ;
