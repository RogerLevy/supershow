public

variable clock  clock on
variable gamelife
0d 2value gametime

class: %actor
    %node derive

    is-a %drawable
    is-a %unloadable
    is-a %xy

    prop en <readonly
    prop vx :fixed <save  prop vy :fixed <save

    prop lyr :int       \ collision layer (bitmask: what I am)
    prop msk :int       \ collision mask (bitmask: what I collide with)

    prop beha :xt
    prop phys :xt
    prop time :fixed                \ secs
    prop prio :int <save            \ 0 = behind BG, <>0 = in front of BG   
    prop id :int

    template { -1 id ! }

    static autoclass                \ flag

    prop unloaded <readonly

    \ EC_MAX_SIZE nprop ec
    \ template { ec clear-ec }
class;

\ =============================================================================
\ Actor management
\ =============================================================================

\ : actor# ( %actor - n ) 
\     -> id @ ;

: free? ( actor - flag ) 
    >en @ 0= ;

: exists? ( actor - flag )
    dup -exit
    dup valid-object? not if drop 0 exit then
    >en @ ;

: init-actor ( actor - )
    { at@ 2>p x 2! } ;

0 %actor :construct ( - )
    \ node:construct 
    this init-actor ;

\ =============================================================================
\ Actor logic
\ =============================================================================

\ Actor benching (disabling when there's an error)
c: %actor benched ;  \ controls behavior and physics
: benched? ( actor - ) -> benched @ ;
: bench ( actor - ) -> benched on ;
: ?benched  benched @ if r> drop then ;
: resurrect ( actor - ) { benched off   this start } ;

\ Step
: +gametime ( - )
    clock @ if
        gametime usdelta 0 d+ to gametime  
    then
    1 gamelife +! ;

: behave  beha @ ?oexec ;
: physics  phys @ ?oexec ;
: +time  ?benched pdelta time +! ;

\ =============================================================================
\ Actor scripting
\ =============================================================================

continuation: act> ( - ) ( - ) 0 time !  beha ! ; 
continuation: physics> ( - ) ( - ) ( xt ) phys ! ;

: simple-motion ( - )
    physics> vx 2@ x 2+!  ;

\ =============================================================================
\ Template
\ =============================================================================

%actor template {
    prio on
    -1 lyr !  -1 msk !    \ collide with everything by default
    simple-motion
}

\ =============================================================================
\ Collision mask filtering
\ =============================================================================

: cmask? ( actor actor -- flag )
    >r -> lyr @  r> -> msk @  and 0<> ;

\ =============================================================================
\ Scripting utilities
\ =============================================================================

: *{ ( class - <code> } )
    \ Parse-ahead instantiation for serialized objects/actors
    \ Allows property settings between *{ } that can be picked up by START
    s" (one) { " evaluate
    '}' parse' evaluate  1 >in +!
    s" this start }" evaluate ; immediate

: passed? ( n. - flag ) time @ <= dup if 0 time ! then ;

: from ( %actor x y - ) rot as> x 2@ 2>i 2+ at  ; \ this actor# priority ;

redef : halt  beha off  0 0 vx 2! ;

: morph ( class - )
    >r x 2@ vx 2@
    default this s/node move
    r> cla !
    vx 2! x 2! start ;

: vanish  y @ 16384. or y ! ;

: appear  y @ 16384. invert and y ! ;

%actor object dummy

: freemove ( actor - )
    ?dup -exit
    as> halt simple-motion act>
        <left> held? if -2. x +! then
        <right> held? if 2. x +! then
        <up> held? if -2. y +! then
        <down> held? if 2. y +! then ;

\ =============================================================================
\ Actor Inspection
\ =============================================================================

: .status ( - )
    benched @ if ." (BENCHED) " exit then
    en @ 0= if ." (FREE) " then ;

%actor :: .summary ( %actor - )
    11 push-foreground ." [ "
    \ id @ dup 0 >= if ." #" . else drop this .name then
    this .data
    cla @ .data
    .status
    ." at: " x 2@ 2>i swap . . 
    ." ] " pop-attribute ;
