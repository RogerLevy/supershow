\ =============================================================================
\ Filesystem Change Monitor
\ =============================================================================

\ : supershow-process-dirchange ( NOTIFY_INFO - )
\     cell+ @ case
\         FILE_ACTION_ADDED of
\             ." FILE_ACTION_ADDED" cr
\             %totem -> dependents list-count for
\                 list-next {
\                     changed-file this -> default-dir$ count strin? if
\                         changed-file '.' ending this -> extension$ count s= if
\                             ." New file discovered!" cr
\                             changed-file this manifest o.
\                         then
\                     then
\                 }
\             loop drop
\         endof
\         FILE_ACTION_MODIFIED of
\             ." FILE_ACTION_MODIFIED" cr
\             changed-file -path sfind if
\                 ." Reloading file!" cr
\                 >body reload
\             else
\                 drop
\             then
\         endof
\     endcase ;

\ =============================================================================
\ Initialization
\ =============================================================================

: init-supershow ( - )
    ." Initializing Supershow..." cr
    hold off
    user-zoom off
    refit
    \ init-bitmaps
    \ init-tilesets
    \ init-samples
    init-autoloads
    \ init-crt
    debug @ if
\        ['] supershow-process-dirchange is process-dirchange
    else
        display al_hide_mouse_cursor
    then 
    show> sprites step ;

init-supershow

: boot-supershow ( - )
    init-supershow 
    run-main ;

' boot-supershow is boot

\ : load-project ( - )
\     create-autoclasses
\     ['] load-default-dir script-classes each
\     %scene load-default-dir
\     s" modes.vfx" ?included ;

