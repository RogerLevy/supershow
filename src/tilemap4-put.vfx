module [tilemap]
import supershow
import allegro5
import array

class: %tilemap
    is-a %drawable
    is-a %dimensional
    prop ta :ref %array
    prop ts :ref %tileset
class;

private

0  value cur-ts
0  value lm

: nr ( - )  lm  peny@ cur-ts -> th @ +  at ;

: put+ ( tile-rel - )
    dup $FFFFFFFF = if  drop  else
        dup $FF000000 and
        cur-ts -> baseid @  rot $FFFFFF and  +  or  put
    then
    cur-ts -> tw @  0  +at ;

public

%tilemap :: draw
    ts @ to cur-ts
    begin-batch
    h @ 0 do
        penx@ to lm
        w @ 0 do
            j  w @ *  i +  ta @ el@  put+
        loop
        nr
    loop
    end-batch 
    0 0 at ;

\ Address of tile (col, row) in tilemap array — clamped to valid range
: spot ( col row %tilemap - a )
    { 0 0`` this dims 1 1 2-`` 2clamp   w @ * + ta @ slot } ;

\ Pixel (fixed-point) coords → tile col, row
: xy>cr ( x. y. %tilemap - col row )
    >ts @ >tw 2@ 2/ 2>i ;

\ Tile col, row to pixel (fixed)
: cr>xy ( col row %tilemap - x. y. )
    >ts @ >tw 2@ 2* ;


: init-tilemap-renderer ;