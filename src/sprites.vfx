\ =============================================================================
\ Actor sprite support
\ =============================================================================
public

class: %actor
    is-a %_bitmap
class;

%actor :: draw ( - )
    bmp @ -exit  bmp @ cput ;

%actor :: render ( - )
    x 2@ 2>i at this draw ;

: ?pillory ( - )
    this benched? if
        $ff5555ff rgba8 s" !" print
    then ;

create actor-buf  MAX_NODES cells allot
|| 0 value actor-buf#

fast{
|| 0 value sxt
continuation: sorted-actors> ( xt - ) ( - )
    sxt >r to sxt
    0 to actor-buf#
    [: me actor-buf actor-buf# cells + !  1 +to actor-buf# ;] each-active
    actor-buf actor-buf# rot rsort
    actor-buf actor-buf# cells bounds ?do  i @ { sxt execute }  cell +loop
    r> to sxt ;
fast}

\ NOTE: %actors can override RENDER, but assuming the game calls SPRITES
\ to render the stage, or uses bitmap holding, they must only draw bitmaps (or text via PRINT).
\ WARNING: Without bitmap holding enabled, performance on OpenGL tanks.

: backsprites ( - )
    ec> 1 batch> [: >prio @ ;] sorted-actors> prio @ ?exit this render ?pillory ;

: sprites ( - )
    ec> 1 batch> [: >prio @ ;] sorted-actors> prio @ -exit this render ?pillory ;

\ =============================================================================
\ Frame animation
\ =============================================================================

trait: %animator
    prop anm :addr <readonly
    prop a.ts :ref %tileset <readonly
    prop a.spd :fixed
    prop a.ofs :fixed
    prop a.done 
    prop a.flp
trait;

c: %actor %animator ;
c: %flipbook ts:%tileset data:a len spd:p flp ;

private
: anm-spd  a.spd @  anm @ >spd @ p* ;
: anm-len  anm @ >len @ ;
: anm-ts   a.ts @ ;
: anm-flp  a.flp @  anm @ >flp @ xor ;
: anm-data anm @ >data @ ;
: ?baseid  anm-ts dup if 0 tile then ;
: the-frame  a.ofs @ >i cells  anm-data + @  ?baseid +  anm-flp xor ;
: ?done  a.ofs @ anm-spd + anm-len >p >= -exit  a.done on ;
public

: cycle ( flipbook spd. - ) \ to stop, say `anm off`
    a.spd !  dup anm !  { ts @ } a.ts !  0 a.ofs !  a.done off  
    the-frame bmp ! ;

: flipbook: ( ts <name> - )
    create %flipbook dmake { ts !  1.0 spd !  here data ! ;

: flipbook; ( - )
    here data @ - cell / len ! } ;

: ,, ( n # - )
    for dup , loop drop ;

: range, ( from to - )
    2dup < if 1 + swap do i , loop
    else swap do i , -1 +loop then ;

: advance-animation ( spd. - bmpid )    
    anm-spd p*  a.ofs @ +  anm-len >p mod a.ofs !
    ?done  the-frame ;

: animate ( - )
    hold @ ?exit actives> anm @ -exit 1.0 advance-animation bmp ! ;


