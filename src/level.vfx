\ =============================================================================
\ JSON level loader
\   - tile-grid string codec (custom token format)
\   - %level: named layer tilemaps built from a resident cjson "master"
\   - build / load (instantiate) / start-level / reset / draw
\ A level's "actors" array is a scene actors array (see scene.vfx) — objects
\ are reused as-is; the only new data is the tilemap layers.
\ =============================================================================

module [supershow]
import [cjson]

private

\ ---- tile-grid string codec --------------------------------------------------
\ Whitespace-separated cell tokens:
\   "_"            -> empty cell ($FFFFFFFF)
\   [h][v]<index>  -> optional X-flip (bit 24), optional Y-flip (bit 25),
\                     then a decimal tileset index in the low 24 bits.
\ This matches the runtime cell layout the renderer reads (src/tilemap.vfx).

0 value dst        \ fill destination (cell address)
0 value room       \ cells remaining in the target tilemap
0 value sp         \ scan pointer
0 value se         \ scan end

: str>n ( a u - n )  0 0 2swap >number 2drop drop ;

: write-cell ( cell - )
    room 0= if drop exit then
    dst !  dst cell+ to dst  room 1 - to room
;

: skip-ws ( - )
    begin
        sp se < if sp c@ bl <= else 0 then
    while
        sp 1 + to sp
    repeat
;

: tok-end ( - addr )
    sp begin
        dup se < if dup c@ bl > else 0 then
    while 1 + repeat
;

: tok>cell ( a u - cell )
    over c@ [char] _ = if  2drop  $FFFFFFFF exit  then
    0 >r
    over c@ [char] h = if  r> $01000000 or >r  1 /string  then
    dup 0> if  over c@ [char] v = if  r> $02000000 or >r  1 /string  then  then
    str>n  r> or
;

public

: parse-tilemap ( a u tm - )
    {: a u tm | tokend :}
    tm >ta @ >data @ to dst
    tm >w 2@ * to room
    a to sp   a u + to se
    begin
        skip-ws  sp se <
    while
        tok-end to tokend
        sp  tokend sp -  tok>cell  write-cell
        tokend to sp
    repeat
;

: tm-pxw ( tilemap - n )  { w @  ts @ >tw @ * } ;
: tm-pxh ( tilemap - n )  { h @  ts @ >th @ * } ;

private

\ Create a named %tilemap (mirrors the `tilemap` defining word in autoload.vfx)
: define-layer-tm ( levelname len cols rows - tilemap )
    swap f" %n %n tilemap %s" .evaluate   lastbody ;

public

trait: %layer
    prop prx     :fixed          \ parallax
    prop en                      \ free-slot (editor pool)
    prop vis                     \ visible (games + editor honor this)
    prop visx    :int            \ static pixel x offset (visual only)
    prop visy    :int            \ static pixel y offset (visual only)
    32 nprop name$ :cstring      \ layer name (preserved across editor save/load)
trait;

class: %tilemap
    is-a %layer
class;

class: %level
    32 nprop name$ :cstring
    is-a %loadable
    is-a %drawable
    prop layers  :ref %array
    prop pxw     :int            \ level pixel bounds (for camera clamp)
    prop pxh     :int
    prop src :ref %jsonfile
class;

\ JSON int defaulting to ON (-1) when the key is absent, so layers with no "vis"
\ key are visible. Shared by the game loader and the editor.
: ?j>on ( layerj key - flag )  2dup ?get-item if  j>n  else  2drop -1  then ;

\ ---- shared layer-JSON decoders (build-layer here + build-layer-slot in gs) ---

\ Resolve a layer's tileset: its "tileset" word, else the word derived from the
\ "tilesetfile" path (<base>.ts).
: layer-tileset ( layerj - tileset )
    dup "tileset" ?j>z ?dup if  nip zcount evaluate  exit  then
    "tilesetfile" ?j>z ?dup 0= abort" Layer JSON has no tileset or tilesetfile field."
    zcount -path -ext f" %s.ts" evaluate ;

\ A layer's name: its "name", else "layer<idx>".
: layer-name ( layerj idx - a u )
    swap "name" ?j>z ?dup if  nip zcount  else  f" layer%n"  then ;

\ Apply a layer's view props (parallax / offsets / repeat / visibility) to tm.
: layer-view! ( layerj tilemap - )
    {: layerj tm :}
    layerj "parallax" ?j>p  dup 0= if drop 1.0 then  tm >prx !
    layerj "visx"   ?j>n  tm >visx !
    layerj "visy"   ?j>n  tm >visy !
    layerj "repeat" ?j>n  tm >rpt !
    layerj "vis"    ?j>on  tm >vis ! ;

private

: build-layer ( lev-name lev-len idx layerj - tilemap )
    {: lev-name lev-len idx layerj | cols rows tm :}
    layerj "cols" j>n to cols
    layerj "rows" j>n to rows
    layerj idx layer-name lev-name lev-len  f" %s-%s"  cols rows define-layer-tm to tm
    \ name$ on the runtime tilemap mirrors what the editor round-trips to JSON,
    \ so a level loaded at runtime reports the same layer names it was saved with.
    layerj idx layer-name tm >name$ place
    layerj layer-tileset  tm >ts !
    layerj tm layer-view!
    tm >en on
    tm
;

: build-level ( jsonfile level - )
    {: jf lvl | root layersj n mw mh :}
    lvl { 
        jf src !
        jf >json @ to root
        jf body>name -ext name$ place

        root "layers" j>j to layersj
        layersj jsize to n
        n %int %array dmake layers !

        n for
            this body>name  i  layersj i j>j  build-layer   ( tilemap )
            i layers @ el!
        loop

        \ find size of the level for camera bounds
        \ let the level override with explicit "w"/"h" (pixels), if present.
        0 to mw  0 to mh
        n for
            i layers @ el@            ( tilemap )
            dup tm-pxw mw max to mw
                tm-pxh mh max to mh
        loop
        mw pxw !  mh pxh !
        root "w" ?j>n ?dup if pxw ! then
        root "h" ?j>n ?dup if pxh ! then    
    } 
    lvl on-built
;

public

: layer ( level i - tilemap )  
    swap >layers @ el@ ;

\ ---- tilemap -> token-string encoder (inverse of parse-tilemap) -------------

private

create nul 0 c,

0 value enc-buf                       \ cached auto-grow lstring, reused per call

: cell>tok ( cell lstr - )            \ append one cell's token (no separator)
    {: cell lstr :}
    cell $FFFFFFFF = if  s" _" lstr lappend  exit  then
    cell $01000000 and if  s" h" lstr lappend  then
    cell $02000000 and if  s" v" lstr lappend  then
    cell $FFFFFF and  f" %n"  lstr lappend ;

public

\ Encode a tilemap's cells back into the whitespace token string, returning a
\ NUL-terminated zstring (in a reused buffer; valid until the next call).
: encode-tiles ( tilemap - zstr )
    {: tm | d n :}
    enc-buf 0= if  s" " *lstring to enc-buf  then
    enc-buf lclear
    tm >ta @ >data @ to d
    tm >w 2@ * to n
    n for
        i if  s"  " enc-buf lappend  then
        d i cells + @  enc-buf cell>tok
    loop
    nul 1 enc-buf lappend                 \ NUL terminator
    enc-buf ldata@ ;

|| : json@  >src @ >json @ ;

\ Overwrite each layer's "tiles" string in the level's source cjson from the
\ live tilemaps, then write the whole document to disk. Everything the editor
\ doesn't model (tileset names, parallax, dims, the actors array, unknown keys)
\ is preserved untouched.
: save-level ( level path len - )
    {: lvl path len | layersj :}
    lvl json@ "layers" j>j to layersj
    layersj jsize for
        lvl i layer  encode-tiles              ( zstr )
        layersj i j>j "tiles" j>j  swap        ( tiles-item zstr )
        jset-string
    loop
    lvl json@ path len write-json ;

|| : refill-layer ( layerj tilemap - )
    2dup layer-view!  
    swap "tiles" j>s rot parse-tilemap ;

\ Refill the layer tilemaps from the master cjson — tiles + view props (no
\ actors, no stage reset). Use this on its own when you just need the layers
\ restored (e.g. an editor that doesn't instantiate the level's actors).
: refill-tilemaps ( level - )
    {: lvl | layersj :}
    lvl json@ "layers" j>j to layersj
    layersj jsize for
        layersj i j>j   lvl i layer refill-layer
    loop
;

\ Instantiate the level: fill tilemaps from the master cjson, 
\ and instantiate (but do NOT start) the level's actors.
%level :: load
    this refill-tilemaps
    src @ >json @ "actors" ?j>j ?dup if jmany then
;

: action ( - ) 
    actives> this start ;

: clamp-cam ( camx. camy. level - camx. camy. )
    { 0 0``  pxw 2@ gamew gameh 2- 0 0 2max 2>p``  2clamp } ;

ec-cell camx
ec-cell camy

: draw-layer ( level i - )      \ draw one layer; caller decides visibility
    layer {
        camx@ prx @  p*  visx @ >p - pfloor
        camy@ prx @  p*  visy @ >p - pfloor
        gamew >p  gameh >p
        this draw-view
    }
;

: ?draw-layer ( level i - )
    {: lvl n :}
    lvl n layer { en @ vis @ and } if
        lvl n draw-layer
    then
;

%level :: draw
    layers @ #items for
        this i ?draw-layer 
    loop
;

%level :: render
    0 0 at  this draw ;