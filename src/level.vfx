\ =============================================================================
\ JSON level loader
\   - tile-grid string codec (custom token format)
\   - %level: named layer tilemaps built from a resident cjson "master"
\   - build / enter (instantiate) / start-level / reset / draw
\ A level's "actors" array is a scene actors array (see scene.vfx) — objects
\ are reused as-is; the only new data is the tilemap layers.
\ =============================================================================

module [supershow]
import [cjson]

private

\ ---- tile-grid string codec --------------------------------------------------
\ Whitespace-separated cell tokens:
\   "_"            -> empty cell ($FFFFFFFF)
\   [h][v]<index>  -> optional X-flip (bit 24), optional Y-flip (bit 25),
\                     then a decimal tileset index in the low 24 bits.
\ This matches the runtime cell layout the renderer reads (src/tilemap.vfx).

0 value dst        \ fill destination (cell address)
0 value room       \ cells remaining in the target tilemap
0 value sp         \ scan pointer
0 value se         \ scan end

: str>n ( a u - n )  0 0 2swap >number 2drop drop ;

: write-cell ( cell - )
    room 0= if drop exit then
    dst !  dst cell+ to dst  room 1 - to room
;

: skip-ws ( - )
    begin
        sp se < if sp c@ bl <= else 0 then
    while
        sp 1 + to sp
    repeat
;

: tok-end ( - addr )
    sp begin
        dup se < if dup c@ bl > else 0 then
    while 1 + repeat
;

: tok>cell ( a u - cell )
    over c@ [char] _ = if  2drop  $FFFFFFFF exit  then
    0 >r
    over c@ [char] h = if  r> $01000000 or >r  1 /string  then
    dup 0> if  over c@ [char] v = if  r> $02000000 or >r  1 /string  then  then
    str>n  r> or
;

public

: string>tilemap ( a u tm - )
    {: a u tm | tokend :}
    tm >ta @ >data @ to dst
    tm >w 2@ * to room
    a to sp   a u + to se
    begin
        skip-ws  sp se <
    while
        tok-end to tokend
        sp  tokend sp -  tok>cell  write-cell
        tokend to sp
    repeat
;

: tm-pxw ( tilemap - n )  { w @  ts @ >tw @ * } ;
: tm-pxh ( tilemap - n )  { h @  ts @ >th @ * } ;

private

\ Create a named %tilemap (mirrors the `tilemap` defining word in autoload.vfx)
: new-layer-tm ( cols rows a u - tilemap )
    f" tilemap %s" .evaluate   lastbody ;

public

trait: %layer
    prop prx     :fixed          \ parallax
    prop en                      \ free-slot (editor pool)
    prop vis                     \ visible (games + editor honor this)
    prop visx    :int            \ static pixel x offset (visual only)
    prop visy    :int            \ static pixel y offset (visual only)
    32 nprop name$ :cstring      \ layer name (preserved across editor save/load)
trait;

class: %tilemap
    is-a %layer
class;

class: %level
    32 nprop name$ :cstring
    prop layers  :ref %array
    prop src     :addr           \ resident cjson root (the master)
    prop pxw     :int            \ level pixel bounds (for camera clamp)
    prop pxh     :int
class;

\ JSON int defaulting to ON (-1) when the key is absent, so layers with no "vis"
\ key are visible. Shared by the game loader and the editor.
: ?j>on ( layerj key - flag )  2dup ?get-item if  j>n  else  2drop -1  then ;

private

create lname-buf 64 allot       \ scratch for a layer's bare name (see build-layer)

: build-layer ( lev-name lev-len idx layerj - tilemap )
    {: lev-name lev-len idx layerj | cols rows tm :}
    layerj "cols" j>n to cols
    layerj "rows" j>n to rows
    \ The layer's bare name is optional in the JSON (older gs saves omit it), so
    \ fall back to "layer<idx>". Copy it into lname-buf because it's used twice:
    \ once to mint the tilemap's dict word "<level>-<layer>", and again to fill
    \ the tilemap's own name$ field below. (The fallback goes through f"'s
    \ rotating buffer, so the stable copy avoids it being clobbered.)
    layerj "name" ?j>z
    ?dup if  zcount  else  idx f" layer%n"  then
    lname-buf place
    \ Mint the named tilemap, then set name$ to the bare name so the runtime
    \ matches what the editor stores: gs round-trips name$ <-> the JSON "name",
    \ so a level loaded at runtime reports the same layer names it was saved with.
    lname-buf count  lev-name lev-len  f" %s-%s"  cols rows 2swap  new-layer-tm to tm
    lname-buf count  tm >name$ place
    layerj "tileset" j>s evaluate  tm >ts !
    layerj "parallax" ?j>p  dup 0= if drop 1.0 then  tm >prx !
    layerj "visx"   ?j>n  tm >visx !
    layerj "visy"   ?j>n  tm >visy !
    layerj "repeat" ?j>n  tm >rpt !
    layerj "vis"    ?j>on  tm >vis !
    tm >en on
    tm
;

public

: build-level ( cjson|jsonfile - level )
    {: param | lvl root layersj n mw mh :}
    %level dmake to lvl
    param dup %jsonfile is? if  -> json @  then  to root
    lvl {
        root src !
        param %jsonfile is? if
            param body>name -ext name$ place
        else
            root "name" ?j>z ?dup 0= abort" Level JSON has no name field."
            zcount name$ place
        then
        root "layers" j>j to layersj
        layersj jsize to n
        n %int %array hmake layers !
        n 0 ?do
            name$ count  i  layersj i j>j  build-layer   ( tilemap )
            i layers @ el!
        loop
        \ camera bounds: default to the largest layer's pixel extent, then let
        \ the level override with explicit "w"/"h" (pixels), if present.
        0 to mw  0 to mh
        n 0 ?do
            i layers @ el@            ( tilemap )
            dup tm-pxw mw max to mw
                tm-pxh mh max to mh
        loop
        mw pxw !  mh pxh !
        root "w" ?j>n ?dup if pxw ! then
        root "h" ?j>n ?dup if pxh ! then    
    }
    lvl
;

: layer ( level i - tilemap )  swap >layers @ el@ ;

\ ---- tilemap -> token-string encoder (inverse of string>tilemap) -------------

private

create nul 0 c,

0 value enc-buf                       \ cached auto-grow lstring, reused per call

: cell>tok ( cell lstr - )            \ append one cell's token (no separator)
    {: cell lstr :}
    cell $FFFFFFFF = if  s" _" lstr lappend  exit  then
    cell $01000000 and if  s" h" lstr lappend  then
    cell $02000000 and if  s" v" lstr lappend  then
    cell $FFFFFF and  f" %n"  lstr lappend ;

public

\ Encode a tilemap's cells back into the whitespace token string, returning a
\ NUL-terminated zstring (in a reused buffer; valid until the next call).
: encode-tiles ( tilemap - zstr )
    {: tm | d n :}
    enc-buf 0= if  s" " *lstring to enc-buf  then
    enc-buf lclear
    tm >ta @ >data @ to d
    tm >w 2@ * to n
    n 0 ?do
        i if  s"  " enc-buf lappend  then
        d i cells + @  enc-buf cell>tok
    loop
    nul 1 enc-buf lappend                 \ NUL terminator
    enc-buf ldata@ ;

\ Overwrite each layer's "tiles" string in the level's source cjson from the
\ live tilemaps, then write the whole document to disk. Everything the editor
\ doesn't model (tileset names, parallax, dims, the actors array, unknown keys)
\ is preserved untouched.
: save-level ( level path len - )
    {: lvl path len | layersj :}
    lvl >src @ "layers" j>j to layersj
    layersj jsize 0 ?do
        lvl i layer  encode-tiles              ( zstr )
        layersj i j>j "tiles" j>j  swap        ( tiles-item zstr )
        jset-string
    loop
    lvl >src @ path len write-json ;

|| : refill-layer ( tilemap layerj - )  "tiles" j>s rot string>tilemap ;

\ Refill the layer tilemaps from the master cjson (tile data only — no actors,
\ no stage reset). Use this on its own when you just need the tiles loaded
\ (e.g. an editor that doesn't instantiate the level's actors).
: refill-tilemaps ( level - )
    {: lvl | layersj :}
    lvl >src @ "layers" j>j to layersj
    layersj jsize 0 ?do
        lvl i layer
        layersj i j>j
        refill-layer
    loop
;

\ Instantiate the level: fill tilemaps from the master cjson, clear the stage,
\ and instantiate (but do NOT start) the level's actors.
: enter ( level - )
    {: lvl :}
    lvl refill-tilemaps
    just
    lvl >src @ "actors" ?j>j ?dup if j>many then
;

: action! ( - ) actives> this start ;

: reset ( level - )  enter  action! ;

: clamp-cam ( level camx. camy. - camx. camy. )
    {: lvl camx camy :}
    camx  0  lvl >pxw @ gamew - 0 max >p  clamp
    camy  0  lvl >pxh @ gameh - 0 max >p  clamp
;

: draw-layer ( level i camx. camy. - )      \ draw one layer; caller decides visibility
    {: lvl i camx camy | parallax :}
    lvl i layer {
        0 0 at
        prx @ to parallax
        camx parallax p*  visx @ >p -
        camy parallax p*  visy @ >p -
        gamew >p  gameh >p
        this draw-view
    }
;

: ~level ( level camx. camy. - )
    {: lvl camx camy :}
    lvl >layers @ #items 0 ?do
        lvl i layer { en @ vis @ and } if
            lvl i camx camy draw-layer
        then
    loop
;

\ Draw all actors offset by the camera (so actors and tiles scroll together).
: ~actors ( camx. camy. - )
    {: camx camy :}
    m{
        camx negate p>f  camy negate p>f  1e 1e 0e  transform
        sprites
    m}
;
