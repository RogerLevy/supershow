public

variable gamemode

class: %mode
    prop drw :xt
    prop beha :xt
    prop stg
    prop _zoom :int
    prop _tv :int
class;

0 %mode :construct ( - )
    0 _zoom !
    -1 _tv !
    gamemode @ ?dup if
        dup >_zoom @  _zoom !
            >_tv @    _tv !
    then ;

%mode object default-mode
default-mode gamemode !

|| variable catchup

: process-work ( - )
    gamemode @ -> beha @ ?execute ;

: process-show ( - )
    0 al_use_shader drop
    gamemode @ -> drw @ draw-tv ;

: supershow ( - )
    gamemode @ >r                  \ run the frame under the CURRENT mode (gs etc. use their own)
    [:
        catchup @ if
            catchup off
            process-work update-delta process-input
        then
        [: process-work process-show ;] time-xt n>f
        1e tps f/ 1000000e f* f>= if \ frame took more than a system tick
            1 catchup ! \ process the game logic an extra time after presenting
        then
    ;] catch
    r> gamemode !
    throw ;

\ If called in the same function, call in this order: show> then work>
\ Otherwise you'll get visual glitches.

: work> ( <code;> - )
    r> gamemode @ -> beha ! show> supershow ;

redef : show> ( <code;> - )
    r> gamemode @ -> drw ! show> supershow ;

:noname ( - addr )  gamemode @ >_zoom ; is user-zoom
:noname ( - addr )  gamemode @ >_tv  ; is tv

\ Engineer's cartridge/ldp calls reset-mode on (re)load so a freshly-loaded game
\ runs in the pristine default-mode, not whatever mode the previous program left
\ active (e.g. the editor's own mode).
:noname ( - )  default-mode gamemode ! ; is reset-mode
