\ =============================================================================
\ Tile Collision & Reading
\ =============================================================================
\
\ tmslide -- AABB sweep+pushout against a tilemap grid.
\   Moves the scoped actor, sliding along solid tile edges.
\   Usage:  -3 -8 3 0  my-tilemap  ['] my-filter  ['] my-response  tmslide
\   filter-xt:   ( meta - solid? )
\   response-xt: ( col row dir - )  dir = BIT_FLR/BIT_CEL/BIT_WLT/BIT_WRT
\   pushed? is set true if any pushout occurred.
\
\ tread? / tread> -- Detect and iterate tiles under a rectangle.
\
\ The actor must be scoped (via { } or as>) before calling.
\ =============================================================================

require %idir%/checks.vfx
require %idir%/utilities.vfx
require %idir%/actor.vfx
require %idir%/udlr.vfx

public
0 value pushed?

\ =============================================================================
\ Internal state
\ =============================================================================

private

\ Shared tile dimensions (set by both tmslide and tread setups)
0 value _tw   0 value _th

\ tmslide state
0 value the-map
0 value the-ts
0 value the-filter
0 value the-response
0 value px    0 value py        \ starting top-left of hitbox (fixed)
0 value nx    0 value ny        \ new top-left after velocity (fixed)
0 value _mbw  0 value _mbh      \ hitbox w, h (integer pixel offsets: x2-x1, y2-y1)

: ?respond ( col row dir - )
    the-response if  the-response execute  else  2drop drop  then ;

\ tread state
0 value _map
0 value _lc   0 value _tc      \ left col, top row
0 value _rc   0 value _br      \ right col, bottom row
0 value _xt
0 value _meta
0 value _flag

\ =============================================================================
\ Shared helpers
\ =============================================================================

\ Fixed-point position to tile column/row (left/top edge)
: >col ( x. - col )  >i _tw / ;
: >row ( y. - row )  >i _th / ;

\ Right/bottom edge to tile column/row.
\ Back off one fixed-point unit so exact tile boundaries stay in the
\ previous tile (matching the float roundup-1 convention of the old code).
: >col- ( x. - col )  1 - >i _tw / ;
: >row- ( y. - row )  1 - >i _th / ;

\ Set probe globals for a tile
: set-probe ( col row - )
    dup to probe-row   _th * _th 2 / + >p to probe-y
    dup to probe-col   _tw * _tw 2 / + >p to probe-x ;

\ =============================================================================
\ tmslide helpers
\ =============================================================================

\ Get tile metadata via the-map; empty tile ($FFFFFFFF) returns 0
: get-meta ( col row - meta )
    the-map tile@ dup $FFFFFFFF = if drop 0 exit then meta ;

\ Pre-check directional bit, then call user filter.
\ Drops meta and returns false if the bit test fails.
: ?solid ( meta bit - solid? )
    over and 0= if drop false exit then
    the-filter execute ;

\ =============================================================================
\ Push-out
\ Each pushes the actor out of the penetrated tile edge and zeroes
\ the velocity component in that direction.
\ =============================================================================

: push-up ( - )
    ny _mbh >p +  _th >p mod  negate  +to ny
    0. vy ! ;

: push-down ( - )
    ny  _th >p mod  negate  _th >p +  +to ny
    0. vy ! ;

: push-left ( - )
    nx _mbw >p +  _tw >p mod  negate  +to nx
    0. vx ! ;

: push-right ( - )
    nx  _tw >p mod  negate  _tw >p +  +to nx
    0. vx ! ;

\ =============================================================================
\ Directional sweeps
\ Each checks whether the leading edge crossed a tile boundary,
\ then iterates every tile column (or row) the hitbox spans.
\ On the first solid tile found, it pushes out and exits.
\ =============================================================================

: check-down ( - )
    py _mbh >p + >row-   ny _mbh >p + >row-  = ?exit
    ny _mbh >p + >row-
    px _mbw >p + >col-  px >col
    {: brow rcol lcol :}
    rcol 1 + lcol ?do
        i brow 2dup set-probe get-meta
        BIT_FLR ?solid if
            true to pushed?  true to floor?
            brow to hit-row  i to hit-col
            push-up  i brow BIT_FLR ?respond  unloop exit
        then
    loop ;

: check-up ( - )
    py >row   ny >row  = ?exit
    ny >row
    px _mbw >p + >col-  px >col
    {: trow rcol lcol :}
    rcol 1 + lcol ?do
        i trow 2dup set-probe get-meta
        BIT_CEL ?solid if
            true to pushed?  true to ceiling?
            trow to hit-row  i to hit-col
            push-down  i trow BIT_CEL ?respond  unloop exit
        then
    loop ;

: check-right ( - )
    px _mbw >p + >col-   nx _mbw >p + >col-  = ?exit
    nx _mbw >p + >col-
    ny _mbh >p + >row-  ny >row
    {: rcol brow trow :}
    brow 1 + trow ?do
        rcol i 2dup set-probe get-meta
        BIT_WLT ?solid if
            true to pushed?  true to rwall?
            i to hit-row  rcol to hit-col
            push-left  rcol i BIT_WLT ?respond  unloop exit
        then
    loop ;

: check-left ( - )
    px >col   nx >col  = ?exit
    nx >col
    ny _mbh >p + >row-  ny >row
    {: lcol brow trow :}
    brow 1 + trow ?do
        lcol i 2dup set-probe get-meta
        BIT_WRT ?solid if
            true to pushed?  true to lwall?
            i to hit-row  lcol to hit-col
            push-right  lcol i BIT_WRT ?respond  unloop exit
        then
    loop ;

: sweep-vertical ( - )
    vy @ 0= ?exit
    vy @ 0< if check-up else check-down then ;

: sweep-horizontal ( - )
    vx @ 0= ?exit
    vx @ 0< if check-left else check-right then ;

\ =============================================================================
\ tread helpers
\ =============================================================================

: tread-setup ( x1 y1 x2 y2 tilemap - )
    to _map
    _map -> ts @  dup -> baseid @ pile!
    dup -> tw @ to _tw  -> th @ to _th
    {: x1 y1 x2 y2 :}
    x @ x1 >p + >i _tw / to _lc
    y @ y1 >p + >i _th / to _tc
    x @ x2 >p + >i _tw / to _rc
    y @ y2 >p + >i _th / to _br ;

: tile-meta ( col row - meta )
    _map tile@ dup $FFFFFFFF = if drop 0 exit then meta ;

\ =============================================================================
\ Public API
\ =============================================================================

public

\ Slide the scoped actor against tilemap collision.
\ x1 y1 x2 y2 are relative hitbox corners (integer offsets from actor origin).
\ filter-xt:   ( meta - solid? ) narrow-phase filter; called only for tiles
\   that pass the directional BIT_* pre-check.
\ response-xt: ( col row dir - ) called on each pushout; dir = BIT_FLR/CEL/WLT/WRT.
\   Pass 0 for no response.
\ Sets pushed? floor? ceiling? lwall? rwall? hit-col hit-row.
: tmslide ( x1 y1 x2 y2 tilemap filter-xt response-xt - ) ( meta - solid? ) ( col row dir - )
    to the-response  to the-filter  to the-map
    the-map -> ts @ to the-ts
    the-ts -> baseid @ pile!
    the-ts -> tw @ to _tw
    the-ts -> th @ to _th
    {: x1 y1 x2 y2 :}
    x2 x1 - to _mbw   y2 y1 - to _mbh
    x @ x1 >p + to px   y @ y1 >p + to py
    px vx @ + to nx      py vy @ + to ny
    false to pushed?
    clear-collision-state
    sweep-vertical sweep-horizontal
    nx px - x +!
    ny py - y +! ;

\ Common filters
: solid? ( meta - solid? )  0<> ;

\ Corner-open checks: true if the tile at col/row is passable in the direction
\ of the current wall/floor hit. Relies on lwall?/rwall?/floor?/ceiling? state.
|| : hwall-open? ( col row - flag )
    get-meta
    rwall? if BIT_WLT and 0= else BIT_WRT and 0= then ;
|| : vwall-open? ( col row - flag )
    get-meta
    floor? if BIT_FLR and 0= else BIT_CEL and 0= then ;

\ Nudge the actor around tile corners after tmslide.
\ Use the same hitbox corners as the tmslide call.
\ fudge: snap tolerance (integer pixels).
\ Only nudges when the adjacent corner tile is open (real corner, not flat wall).
\ Must be called right after tmslide (reads _tw/_th and the-map from that call).
: cut-corners ( x1 y1 x2 y2 fudge - )
    {: x1 y1 x2 y2 fudge | off1 off2 step fp wcol wrow :}
    1 >p to step
    fudge >p to fp
    lwall? rwall? or if
        rwall? if x @ x2 >p + >col else x @ x1 >p + >col- then  to wcol
        y @ y1 >p + _th >p mod  to off1
        y @ y2 >p + _th >p mod  to off2
        \ top edge near next row boundary → check bottom corner, nudge down
        _th >p off1 - fp <= if
            wcol  y @ y2 >p + >row-  hwall-open? if
                _th >p off1 - step min  y +!
            then
        then
        \ bottom edge near prev row boundary → check top corner, nudge up
        off2 fp <= if
            wcol  y @ y1 >p + >row  hwall-open? if
                off2 step min  negate  y +!
            then
        then
    then
    floor? ceiling? or if
        floor? if y @ y2 >p + >row else y @ y1 >p + >row- then  to wrow
        x @ x1 >p + _tw >p mod  to off1
        x @ x2 >p + _tw >p mod  to off2
        \ left edge near next col boundary → check right corner, nudge right
        _tw >p off1 - fp <= if
            x @ x2 >p + >col-  wrow  vwall-open? if
                _tw >p off1 - step min  x +!
            then
        then
        \ right edge near prev col boundary → check left corner, nudge left
        off2 fp <= if
            x @ x1 >p + >col  wrow  vwall-open? if
                off2 step min  negate  x +!
            then
        then
    then ;

\ Scan tiles under a rectangle, call filter for each non-empty tile.
\ filter-xt: ( meta - match? )
\ Probe globals are set before each call.
\ Returns true if any tile matched.
\ Sets hit-tile, hit-col, hit-row for the last matching tile.
: tread? ( x1 y1 x2 y2 tilemap filter-xt - flag )
    to _xt  tread-setup
    false to _flag
    _br 1 + _tc ?do
        _rc 1 + _lc ?do
            i j 2dup set-probe tile-meta to _meta
            _meta if
                _meta _xt execute if
                    true to _flag
                    _meta to hit-tile
                    i to hit-col  j to hit-row
                then
            then
        loop
    loop
    _flag ;

\ Iterate non-empty tiles under a rectangle.
\ Body receives ( col row tile# ) for each non-empty tile.
\ Probe globals are set before each call.
\ Exits early if the actor is freed during iteration.
continuation: tread> ( x1 y1 x2 y2 tilemap - ) ( col row tile# - )
    to _xt  tread-setup
    _br 1 + _tc ?do
        _rc 1 + _lc ?do
            i j 2dup set-probe
            _map tile@ dup $FFFFFFFF <> if
                i j rot _xt execute
                this free? if unloop unloop exit then
            else drop then
        loop
    loop ;
