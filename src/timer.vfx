require %idir%/checks.vfx
require %idir%/stage.vfx

\ =============================================================================
\ Timer actors
\ =============================================================================

class: %timer 
    %actor derive 
    prop xt1 :addr
    prop dur :fixed 
class;

: clear-timers ( -- )
    actives> this %timer is? -exit this unload ;

|| : act-timer
    act> dur @ passed? -exit this unload xt1 @ >r ;
    
|| : (timer) ( time. xt -- )
    xt1 ! 0 max dur ! act-timer ;

continuation: timer> ( time. - ) ( - )
    ( xt ) %timer one { (timer) } ;
