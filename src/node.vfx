public

512 ?constant s/node
16384 ?constant MAX_NODES

class: %node
    s/node field-space
    is-a %dltree
    is-a %poolable
class;

\ Node pool

MAX_NODES %node array nodes

%node object free-nodes

[: free-nodes push ;] nodes each
%node >template { free-nodes pool ! }

: recycle ( node - )
    dup dlremove  dup >pool @ push ;

: copy-node ( node-src node-dest - )
    over %node is? not abort" COPY-NODE: Source is not a %node."
    dup %node is? not abort" COPY-NODE: Dest is not a %node."
    {
        ( obj ) %node -> next-ofs @ +   this dup sizeof   %node -> next-ofs @ /string   move   \ preserve node links
    } 
;

