public

defer tv
defer user-zoom

private

\ Standalone defaults for tv and user-zoom — overridden by mode.vfx when it gets loaded
variable __tv        __tv on
variable __user-zoom

' __tv        is tv
' __user-zoom is user-zoom

: z ( - n ) zoom @ ;

: refit ( - )  \ find biggest integer scaling that fits display
    fullscreen? if 
        monw monh 2s>f f/
        appw apph 2s>f f/
        f> if
            monh apph /
        else
            monw appw /
        then
        zoom ! 
    else
        winw winh 2s>f f/
        appw apph 2s>f f/
        f> if
            winh apph /
        else
            winw appw /
        then
        zoom !         
    then
;

: fs-w  appw z * ;
: fs-h  apph z * ;
: border-xy  monw 2 / monh 2 / fs-w 2 / fs-h 2 / 2- ;
: tv-xy  border-xy`` 2 z * dup`` 2- ;
: tv-xy2  border-xy`` 2 z * dup`` 2+ fs-w fs-h 2+ ;

: clip-screen ( - )
    border-xy fs-w fs-h al_set_clipping_rectangle ;

: border ( - )
    identity
    0 0 winw winh al_set_clipping_rectangle
    cls

    tv-xy 2s>f`` 
    tv-xy2 2s>f``
    0.25e f>ds 0.25e f>ds 0.25e f>ds 1e f>ds```` al_draw_filled_rectangle

    border-xy 2s>f`` 
    fs-w 1 + fs-h 1 + border-xy 2+ 2s>f``
    0e f>ds 0e f>ds 0e f>ds 1e f>ds````  
    6e f>ds` al_draw_rectangle
    
    border-xy 2s>f`` z z 2s>f`` 0e` transform
    clip-screen ;

: ?border
    fullscreen? tv @ and if
        user-zoom @ ?dup if zoom ! else refit then
        border
    else
        identity
        user-zoom @ ?dup if zoom ! then
        0e 0e z s>f fdup 0e transform
    then ;

: draw-tv ( xt - ) ?border ?execute ;
