\ =============================================================================
\ Scene save/load — flat JSON actor serialization
\ =============================================================================

module [supershow.actor]
import [cjson]

public

\ =============================================================================
\ Saving
\ =============================================================================

|| 0 value _arr

|| : (collect-actor) ( - )
    this *json 0 _arr cjson-add-object ;

|| : build-actors-array ( root - )
    {: root :}
    cjson-new-array to _arr
    ['] (collect-actor) each-active
    _arr "actors" root cjson-add-array ;

: save-scene ( path len - )
    ['] build-actors-array serjson ;

\ =============================================================================
\ Loading
\ =============================================================================

\ Instantiate + configure an actor from its JSON object. Does NOT start it —
\ starting is a separate phase so all actors exist (resolvable by id) first.
: json>actor ( cjson - actor )
    {: cjson :}
    cjson "class" j>s evaluate one
    dup cjson swap read-props ;

\ Instantiate every actor in a JSON array, without starting them.
: j>many ( jarray - )
    [: json>actor drop ;] jeach-fast ;

: load-scene ( path len - )
    {: path len :}
    path len load-json 
    dup 0= abort" load-scene: file not found or parse error"
    dup "actors" j>j j>many
    destroy-json ;
