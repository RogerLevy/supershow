module [supershow.core]
	import engineer
	reexport [engineer]
	import allegro5
	reexport [allegro5.utils]
	import cjson
	reexport [cjson]
	public
	include checks               \ Validations
	include %idir%/../lib/mersenne.vfx  \ RNG
	include utilities            \ Math helpers, audio, and misc utilities
	include traits               \ Object traits
	include asset                \ Base asset
	include node
	include border               \ TV border / framing transform (deferred tv/zoom)
	include mode                 \ Game modes: frame dispatch, show>/work>, zoom/tv

module [supershow.assets]
	import bitmap
	reexport [bitmap]
	import tileset
	reexport [tileset]
	import-as %idir%/tilemap.vfx tilemap
	reexport [tilemap]

\ Everything the actor system and the editor (sketchpad) share. Kept as its own
\ resident module so sketchpad/shapes can import [supershow.actor] instead of the
\ full [supershow] umbrella — that breaks the supershow -> sketchpad -> supershow
\ cycle (sketchpad is debug-included below, after this module is fully declared).
module [supershow.actor]
	import allegro5
	import core
	reexport [core]
	import [assets]
	reexport [assets]

	\ Actor system
	import %idir%/../lib/rsort.vfx
	include actor
	include stage                \ Actor/sprite system
	include mode-stage           \ Bind mode system's stage to `actors` (actor half of mode)
	include task                 \ Cooperative multitasking
	include timer
	include sprites
	include smoothing            \ per-actor field easing toward targets
	include tween                \ time-based property tweening w/ easing functions
	include dialog
	include udlr                 \ Movement utilities
	include collision            \ Shape intersection primitives
	include cgrid                \ Broad-phase AABB collision grid
	include tilecol              \ Tilemap slide collision & tile reading
	include scene                \ JSON scene save/load
	include table                \ Flat source-defined data tables + editor codec
	include world                \ Systems layer: %system denizens, cohorts, world/registry; defines `just`

module [supershow]
	import core
	reexport [core]
	import [actor]
	reexport [actor]
	import allegro5

	import assets
	reexport [assets]
	import waveplay             \ Audio engine
	reexport [waveplay]
	import shader               \ Shaders
	reexport [shader]
	import-as %idir%/spritebank.vfx spritebank   \ Batched sprite renderer
	reexport [spritebank]

	include tweak                \ Persistent variable control
	\ include crt                \ CRT shader  \ TODO: Shader doesn't compile on OpenGL 3.0?
	include autoload
	include level                \ JSON level loader (tilemap layers + scene actors)
	include runtime


\ =============================================================================
\ Tools
\ =============================================================================

debug @ [if]
    include %idir%/tools.vfx                \ Development tools
    
	import %supershow%/sketchpad/sketchpad.vfx  \ Table/stage editor
	reexport [sketchpad]
    \ s" sketchpad" <f12> func
[then]