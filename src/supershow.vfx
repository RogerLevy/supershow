module [supershow.core]
	import engineer
	public
	include checks               \ Validations
	include utilities            \ Math helpers, audio, and misc utilities
	include traits               \ Object traits
	include asset                \ Base asset
	include %idir%/../lib/mersenne.vfx  \ RNG
	include node

module [supershow.assets]
	import bitmap
	reexport [bitmap]
	import tileset
	reexport [tileset]
	import-as %idir%/tilemap.vfx tilemap
	reexport [tilemap]

module [supershow]
	import engineer
	reexport [engineer]
	import allegro5
	reexport [allegro5.keys]
	import core
	reexport [core]	
	import assets 
	reexport [assets]
	import waveplay             \ Audio engine
	reexport [waveplay]
	import shader               \ Shaders
	reexport [shader]
	import-as %idir%/spritebank.vfx spritebank   \ Batched sprite renderer
	reexport [spritebank]

	\ Actor system
	import %idir%/../lib/rsort.vfx
	include actor
	include stage                \ Actor/sprite system
	include timer
	include sprites
	include udlr                 \ Movement utilities
	include collision            \ Shape intersection primitives
	include cgrid                \ Broad-phase AABB collision grid
	include tilecol              \ Tilemap slide collision & tile reading

	\ ?
	include border               \ TV border / ininclude 
	include mode                 \ Game modes w/ separate logic and rendering
	include tweak                \ Persistent variable control	
	\ include crt                \ CRT shader  \ TODO: Shader doesn't compile on OpenGL 3.0?
	include autoload    
	include runtime    
