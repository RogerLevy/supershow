public

trait: %autoload
    :: on-startup ( - ) ;
    :: on-turnkey-save ( - ) ;
trait;

create autoloads /list allot&erase 

|| : init-autoloads ( - )
    autoloads list-count for
        list-next on-startup
    loop drop ;

|| : save-autoloads ( - )
    autoloads list-count for
        list-next on-turnkey-save
    loop drop ;

' save-autoloads AtSave

: >autoload-path  expand >abspath ;

[defined] %asset [if]
class: %asset
    prop data  :lstring

    : embed ( fp len - )
        2dup lslurp data !  >autoload-path srcpath$ place ;

    : asset ( name len class - asset ) ( - asset )
        >r screate r> dmake 
        dup autoloads add-to ;

    : @data ( asset - a len )
        -> data @ lcount ;
class;
[then]

[defined] %bitmap [if]
class: %bitmap
    is-a %autoload

    || : does-bitmap ( - ) 
        does> >bmp @ ;

    || : _load-albmp ( - )
        this @data memfile@ dup
            0 al_load_bitmap_f albmp !
        -memfile ;

    :: on-startup ( - )
        this body> >name count f" Loading bitmap %s" .info
        _load-albmp ;
class;

redef : bitmap ( <path> - ) ( - bmpid )
    bl parse 
    2dup fexists? not abort" File not found"
    2dup -path sfind nip if 2drop exit then
    2dup -path %bitmap asset does-bitmap { 
        ( fp len ) embed
        _load-albmp 
        this add-bitmap bmp !
    } ;

[then]

[defined] %tileset [if]
class: %tileset
    is-a %autoload

    :: on-startup ( - )
        this body> >name count f" Slicing tileset %s" .info
        this update-tileset ;
class;

: tileset ( bmpid tilew tileh <name> - ) ( - tileset )
    bl parse 2dup sfind nip if 2drop 2drop drop exit then
    %tileset asset {
        tw 2! bmp !
        _slice-tileset
    } ;

[then]

[defined] [supershow.waveplay] [if]
class: %sample
    derive %asset
    is-a %autoload
    prop id :int
    prop alsmp
    16 nprop ident :cstring

    || : does-sample ( - ) 
        does> -> id @ sound ;

    || : _load-alsmp ( - alsmp )
        this @data memfile@ dup
            ident count >zpad al_load_sample_f alsmp !
        -memfile ;

    :: on-startup ( - )
        this body> >name count f" Loading sample %s" .info
        _load-alsmp
        alsmp @ id @ set-sample ;

class;

%sample :destruct  alsmp @ al_destroy_sample ;

: sample ( <path> - ) ( - )
    \ oggs only for now
    bl parse 
    2dup fexists? not abort" File not found"
    2dup -path -ext f" *%s*" sfind nip if 2drop exit then
    2dup -path -ext f" *%s*" %sample asset does-sample {
        2dup '.' ending -1 /string ident place 
        ( fp len ) embed
        _load-alsmp
        alsmp @ add-sample id !
    } ;

[then]

class: %font
    derive %asset
    is-a %autoload
    prop alfont :addr         \ ALLEGRO_FONT*
    prop size :int            \ TTF point size; 0 = bitmap font
    16 nprop ident :cstring   \ filename hint (".ttf" or ".png")

    || : does-font  does> -> alfont @ default-font! ;

    || create char-range  0 ,  255 ,

    || : _load-ttf ( - )
        this @data memfile@
        ident count >zpad  size @  0  al_load_ttf_font_f  alfont ! ;
        \ NOTE: memfile intentionally not closed — al_load_ttf_font_f holds reference

    || : _load-bitmap-font ( - )
        this @data memfile@ dup
            0 al_load_bitmap_f  swap -memfile
        1` char-range`  al_grab_font_from_bitmap  alfont ! ;

    :: on-startup ( - )
        this body> >name count f" Loading font %s" .info
        size @ if _load-ttf else _load-bitmap-font then ;

class;

%font :destruct  alfont @ al_destroy_font ;

: ttf-font ( size <path> - ) ( - )
    {: sz :}
    bl parse
    2dup fexists? not abort" File not found"
    2dup -path sfind nip if 2drop exit then
    2dup -path %font asset does-font {
        ( fp len ) embed
        sz size !
        s" .ttf" ident place
        _load-ttf
    } ;

: bitmap-font ( <path> - ) ( - )
    bl parse
    2dup fexists? not abort" File not found"
    2dup -path sfind nip if 2drop exit then
    2dup -path %font asset does-font {
        ( fp len ) embed
        0 size !
        s" .png" ident place
        _load-bitmap-font
    } ;

0 value active-shader

class: %shader
    derive %asset
    is-a %autoload
    prop handle :addr   \ ALLEGRO_SHADER*
    prop data2 :lstring

    : shade ( shader|0 - )
        {: s :}
        s dup if -> handle @ then 
        al_use_shader 0= abort" al_use_shader() error!" 
        s to active-shader ;

    || : _load-shader ( - )
        \ Body: [vs-bytes + 0c][fs-bytes + 0c]
        data @ lcount drop  data2 @ lcount drop  load-shader handle ! ;

    :: on-startup ( - )
        this body> >name count f" Loading shader %s" .info
        _load-shader ;

class;

%shader :destruct  handle @ al_destroy_shader ;


: shader ( <name> <vs-path> <fs-path> - ) ( - )
    bl parse  bl parse  bl parse
    {: nm-a nm-n vs-a vs-n fs-a fs-n :}
    vs-a vs-n fexists? not abort" Vertex shader file not found"
    fs-a fs-n fexists? not abort" Fragment shader file not found"
    nm-a nm-n sfind nip if exit then
    nm-a nm-n %shader asset {
        vs-a vs-n lslurp 0 c, data !
        fs-a fs-n lslurp 0 c, data2 !
        _load-shader
    } ;


[defined] %jsonfile [if]
    
class: %jsonfile
    is-a %autoload
    \ is-a %loadable

    || : _load-json ( - )
        this @data parse-json json ! ;

    :: on-startup ( - )
        this body> >name count f" Loading JSON %s" .info
        _load-json ;
class;

: JSONFILE ( <path> - ) ( - jsonfile )
    bl parse
    2dup fexists? not abort" File not found"
    2dup -path sfind nip if 2drop exit then
    2dup -path %jsonfile asset { embed _load-json } ;

%jsonfile :destruct  json @ destroy-json ;

[then]

[defined] %tilemap [if]
class: %tilemap
    is-a %autoload

    :: on-startup ( - )
        w @ h @ * %int %array hmake  ta !
        snapshot-cells @ if
            data-snapshot @  ta @ >data @  snapshot-cells @ cells  move
        then ;

    :: on-turnkey-save ( - )
        align here data-snapshot !
        ta @ >data @  w @ h @ * dup snapshot-cells !
        cells  dup allot  here over -  swap move ;

class;

: tilemap ( w h <name> )
    {: def-w def-h :}
    create %tilemap dmake {
        def-w def-h * %int %array hmake ta !
        def-w w !   def-h h !
        this autoloads add-to
    } 
;

[then]

: teardown-autoload ( autoload - )
    dup body>name f" Tearing down %s..." .info 
    destruct 
;

: teardown-autoloads ( - )
    s" Tearing down registered autoloads..." .info
    \ Get everything on the stack:
    autoloads list-count for
        list-next swap 
    loop drop 
    \ So that we can destroy them in reverse order, for safety:
    autoloads list-count nip for 
        teardown-autoload 
    loop 
;

[defined] %level [if]

class: %level
    is-a %autoload
class;

: level ( jsonfile <name> - ) ( - level )
    create %level dmake build-level ;

[then]