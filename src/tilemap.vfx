module [supershow.tilemap]
import supershow.core
import supershow.tileset
import supershow.bitmap
import allegro5
import array

class: %tilemap
    is-a %drawable
    is-a %dimensional
    is-a %iterable
    prop ta :ref %array
    prop ts :ref %tileset
    prop snapshot-data :addr
    prop snapshot-size :int
    prop rpt
class;

%tilemap :destruct
    ta @ destruct ;

private

\ Vertex decl: [x:s16 y:s16] @0 + [u:s16 v:s16] @4 = 8 bytes/vertex
create vdecl-arr
    ALLEGRO_PRIM_POSITION        , ALLEGRO_PRIM_SHORT_2 , 0 ,
    ALLEGRO_PRIM_TEX_COORD_PIXEL , ALLEGRO_PRIM_SHORT_2 , 4 ,
    ALLEGRO_PRIM_COLOR_ATTR ,      0 ,                    8 ,
    0 , 0 , 0 ,

24 constant s/vertex
6  constant v/tile   \ TRIANGLE_LIST: 2 tris per quad

0  value tmvbuf
0  value prim-decl
0  value cur-ts
variable #drawn

fast{
\ Store int16 n at address a, return a+2
: sw!+ ( a n - a' )  over w!  2 + ;

0 value x0 0 value y0 0 value x1 0 value y1 
0 value u0 0 value v0 0 value u1 0 value v1 
\ Write 6 vertices for one tile quad (TRIANGLE_LIST, CCW)
: +quad ( a x0 y0 x1 y1 u0 v0 u1 v1 - a' )
    to v1 to u1 to v0 to u0 to y1 to x1 to y0 to x0
    x0 sw!+ y0 sw!+ u0 sw!+ v0 sw!+ 16 +    \ TL
    x1 sw!+ y0 sw!+ u1 sw!+ v0 sw!+ 16 +    \ TR
    x1 sw!+ y1 sw!+ u1 sw!+ v1 sw!+ 16 +    \ BR
    x0 sw!+ y0 sw!+ u0 sw!+ v0 sw!+ 16 +    \ TL
    x1 sw!+ y1 sw!+ u1 sw!+ v1 sw!+ 16 +    \ BR
    x0 sw!+ y1 sw!+ u0 sw!+ v1 sw!+ 16 + ;  \ BL

: albmpxy  $164 + 2@ ;
\ : albmpx  $164 + @ ;
\ : albmpy  $168 + @ ;
\ : albmpx  al_get_bitmap_x ;
\ : albmpy  al_get_bitmap_y ;

0 value the-id

\ Write 6 vertices for one non-empty tile
\ Upper byte of tile-rel: flip flags (bit 0 = H flip, bit 1 = V flip)
: tile-verts ( a col row tile-rel - a' )
    {: a col row tile-rel | albmp u0 v0 u1 v1 :}
    the-id  tile-rel $FFFFFF and  +  id>albmp albmpxy  to v0 to u0
    u0 v0 cur-ts >tw 2@ 2+  to v1 to u1
    tile-rel $01000000 and if  u1 u0 to u1 to u0  then   \ H flip
    tile-rel $02000000 and if  v1 v0 to v1 to v0  then   \ V flip
    a  col row``  2dup 1 1 2+``  u0 v0``  u1 v1``  +quad ;

: _flush-tiles ( ptr - )
    tmvbuf - s/vertex / #drawn !
    #drawn @ if
        tmvbuf` prim-decl` cur-ts >bmp @ id>albmp` 
        0` #drawn @` ALLEGRO_PRIM_TRIANGLE_LIST` al_draw_prim drop
    then ;

: _draw-tiles-view ( sc0 sr0 sc1 sr1 - )
    {: sc0 sr0 sc1 sr1 | src :}
    sc0 sc1 >=  sr0 sr1 >= or  ?exit   \ nothing visible (off either edge)
    tmvbuf 
    sr1 sr0 ?do
        sc0 i w @ * + ta @ slot to src
        sc1 sc0 ?do
            src @
            dup $FFFFFFFF = if drop else i j rot tile-verts then
            cell +to src
        loop
    loop
    _flush-tiles ;

\ Repeating variant: span is NOT clamped to the map; each tile is positioned at
\ its true (col,row) but its cell is fetched wrapped (umod) so the map tiles
\ infinitely across the viewport. Used by visual-only decoration layers.
: _draw-tiles-wrap ( sc0 sr0 sc1 sr1 - )
    {: sc0 sr0 sc1 sr1 :}
    sc0 sc1 >=  sr0 sr1 >= or  ?exit
    tmvbuf
    sr1 sr0 ?do
        sc1 sc0 ?do
            i w @ umod  j h @ umod w @ * +  ta @ slot @
            dup $FFFFFFFF = if drop else i j rot tile-verts then
        loop
    loop
    _flush-tiles ;

: cur-tw cur-ts >tw @ ;
: cur-th cur-ts >th @ ;

: draw-wrapped ( sx. sy. w. h. - ) \ tiles infinitely
    {: sx sy pvw pvh :}
    ts @ -exit
    ts @ to cur-ts
    cur-ts >baseid @ to the-id
    at@p  pvw  pvh  clip{
        m{
            at@p  sx sy 2-  2p>f
            cur-tw s>f  cur-th s>f  0e  transform
            sx >i cur-tw / 1 -                      \ no clamp; extend low edge by 1
            sy >i cur-th / 1 -
            sx >i pvw >i + 1 - cur-tw / 1 + 
            sy >i pvh >i + 1 - cur-th / 1 + 
            _draw-tiles-wrap
        m}
    clip} ;

public

%tilemap :: draw-view  ( sx. sy. w. h. - )
    rpt @ if draw-wrapped exit then
    {: sx sy pvw pvh | _tw _th sc0 sr0 sc1 sr1 :}
    ts @ -exit
    ts @ to cur-ts
    cur-ts >baseid @ to the-id
    cur-ts >tw @ to _tw   cur-ts >th @ to _th
    sx >i _tw / 0 max to sc0
    sy >i _th / 0 max to sr0
    sx >i pvw >i + 1 - _tw / 1 + w @ min to sc1
    sy >i pvh >i + 1 - _th / 1 + h @ min to sr1
    at@p  pvw  pvh  clip{
        m{
            at@f  sy p>f f-  fswap  sx p>f f-  fswap
            _tw s>f  _th s>f  0e  transform
            sc0 sr0 sc1 sr1 _draw-tiles-view
        m}
    clip} ;

%tilemap :: draw ( - )
    0 0  w 2@  ts @ >tw 2@ 2*   2>p this draw-view ;

    \ ts @ to cur-ts
    \ cur-ts >baseid @ to the-id
    \ m{
    \     at@f  cur-ts >tw @ s>f  cur-ts >th @ s>f  0e  transform
    \     0 0 w @ h @ _draw-tiles-view
    \ m} ;


: resize-tilemap ( new-w new-h tilemap - )
    {: new-w new-h tm | old-w old-h old-ta new-ta min-cols min-rows :}
    new-w 0 <= new-h 0 <= or abort" resize-tilemap: w and h must be > 0"
    tm >w @  to old-w
    tm >h @  to old-h
    tm >ta @ to old-ta
    new-w old-w min  to min-cols
    new-h old-h min  to min-rows
    new-w new-h * %int %array hmake  to new-ta
    min-rows 0 ?do
        old-w i * old-ta slot
        new-w i * new-ta slot
        min-cols cells  move
    loop
    old-ta destroy
    new-ta  tm >ta !
    new-w   tm >w  !
    new-h   tm >h  ! ;

: set-tilemap ( src-addr len stride tilemap - )
    {: src-a len stride tm :}
    stride  len stride /  tm  resize-tilemap
    src-a  tm >ta @ >data @  len cells  move ;

: fill-tilemap ( n tilemap - )
    {: n tm | d cnt :}
    tm >ta @ >data @ to d
    tm >ta @ >item-count @ to cnt
    cnt 0 do  n  d i cells +  !  loop ;

: clear-tilemap ( tilemap - )
    $FFFFFFFF swap fill-tilemap ;

: tilemap-count ( tilemap - addr w h )
    { ta @ >data @  w @  h @ } ;

\ Cell address for (col,row): wraps when the map repeats, else clamps to edges.
: tile-addr ( col row %tilemap - addr )
    { rpt @ if  swap w @ umod  swap h @ umod
            else  0 0`` this dims 1 1 2-`` 2clamp  then
      w @ * +  ta @ slot } ;

: tile! ( n col row %tilemap - )  tile-addr ! ;

: tile@ ( col row %tilemap - n )  tile-addr @ ;

: clone-tilemap ( src dest - )
    {: src dest :}
    src >w @  src >h @  dest  resize-tilemap
    src >ta @ >data @
    dest >ta @ >data @
    src >w @ src >h @ * cells  move ;

: put-tilemap ( src dest-x dest-y dest - )
    {: src dx dy dest | dw dh dc dr wrap? :}
    dest >w @ to dw   dest >h @ to dh
    dest >rpt @ to wrap?
    src >h @ 0 do
        i dy + to dr
        wrap?  dr 0 >= dr dh < and  or if
            src >w @ 0 do
                i dx + to dc
                wrap?  dc 0 >= dc dw < and  or if
                    i j src tile@
                    dup $FFFFFFFF <> if
                        dc dr dest tile!
                    else drop then
                then
            loop
        then
    loop ;

: paste-tilemap ( src dest-x dest-y dest - )
    {: src dx dy dest | dw dh dc dr wrap? :}
    dest >w @ to dw   dest >h @ to dh
    dest >rpt @ to wrap?
    src >h @ 0 do
        i dy + to dr
        wrap?  dr 0 >= dr dh < and  or if
            src >w @ 0 do
                i dx + to dc
                wrap?  dc 0 >= dc dw < and  or if
                    i j src tile@
                    dc dr dest tile!
                then
            loop
        then
    loop ;

: slice-tilemap ( src x y w h dest - )
    {: src sx sy sw sh dest :}
    sw sh dest resize-tilemap
    sh 0 do
        sw 0 do
            i sx +  j sy +  src tile@
            i  j  dest tile!
        loop
    loop ;

: shift-tilemap ( dx dy tilemap - )
    {: dx dy tm | cols rows old-ta new-ta :}
    tm >w @ to cols   tm >h @ to rows
    tm >ta @ to old-ta
    cols rows * %int %array hmake  to new-ta
    rows 0 do
        cols 0 do
            i dx -  cols mod  cols +  cols mod
            j dy -  rows mod  rows +  rows mod
            cols * +  old-ta slot @
            i  j cols * +  new-ta slot !
        loop
    loop
    old-ta destroy
    new-ta  tm >ta ! ;

\ floor(pixels / tile-size). Floors toward -inf so coords west/north of the
\ origin land in the right cell — a truncating >i would map all of [-tw,0) to 0.
|| : pcell ( p. tsize - cell )  65536 *  >r  s>d  r> fm/mod nip ;

\ Pixel (fixed-point) coords → tile col, row
: xy>cr ( x. y. %tilemap - col row )
    >ts @ >tw 2@
    {: px py tilew tileh :}
    px tilew pcell  py tileh pcell ;

\ Tile col, row to pixel (fixed)
: cr>xy ( col row %tilemap - x. y. )
    >ts @ >tw 2@ 2* ; 


\ \ Pixel (fixed-point) coords → tile col, row
\ : xy>cr ( x. y. %tilemap - col row )
\     { ts @ if ts @ >tw 2@ 2/ 2>i else 2drop 0 0 then } ;

\ \ Tile col, row to pixel (fixed)
\ : cr>xy ( col row %tilemap - x. y. )
\     { ts @ if >ts @ >tw 2@ 2* else 2drop 0 0 then } ; 

: teardown-tilemap-renderer
    tmvbuf free drop ;

: init-tilemap-renderer ( - )
    s" Initializing tilemap renderer..." .info
    2 MB allocate throw  to tmvbuf
    tmvbuf
    2 MB s/vertex / 0 do
        1e 1e 1e 1e dup 8 + 4f!
        s/vertex +
    loop drop
    vdecl-arr  s/vertex  al_create_vertex_decl  to prim-decl ;

%tilemap :: each ( xt - ) ( ... ? - ... ) 
    ta @ each ;

%tilemap :: !each ( xt - ) ( ... ? - ?' ... ) 
    ta @ !each ;

%tilemap :: .items ( - )
    ta @ .items ;

fast}


