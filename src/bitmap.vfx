module [supershow.bitmap]
import core
import allegro5
public

65536 ?constant #bitmaps

class: %bitmap
    derive %asset
    is-a %saveable
    is-a %_bitmap
    prop albmp
    prop touched
    prop mtime :int          \ last-checked source-file mtime (hot-reload)
class;

%bitmap :destruct   albmp @ -albmp ;

%bitmap object dummy.bmp
|| : dummies,  #bitmaps for dummy.bmp , loop ;

create bitmaps %addr array{ dummies, array} drop

: bitmap@  $FFFF and bitmaps el@ ;
: bitmap!  $FFFF and bitmaps el! ;

variable next-bmp#  1 next-bmp# !

: alloc-bmp# ( - bmpid ) next-bmp# @   1 next-bmp# +! ;
: add-bitmap ( bitmap - bmpid ) 
    alloc-bmp# >r 
    r@ over >bmp !
    r@ bitmap! r> ;

: id>albmp ( bmpid - albmp ) 
    bitmap@ -> albmp @ ;

: id>bmp ( bmpid - bitmap ) 
    bitmap@ ;

: albmp>id ( albmp - bmpid | 0 )
    \ Find bitmap ID given an Allegro bitmap pointer
    \ Returns 0 if not found
    next-bmp# @ 1 do
        dup i bitmap@ -> albmp @ = if
            drop i unloop exit
        then
    loop
    drop 0 ;

: bmp>parent ( bmpid - bmpid' )  
    id>albmp al_get_parent_bitmap albmp>id ;

: is-subbmp? ( bmpid - flag )
    id>albmp dup -exit al_is_sub_bitmap 0<> ;

: ?bmp>parent ( bmpid - bmpid|bmpid' )
    dup is-subbmp? if bmp>parent then ;

: bitmap-file ( bmpid - a n ) 
    ?bmp>parent id>bmp -> srcpath$ count ;

\ : ?nullbmp  dup 0= abort" BITMAP-FILE : Bitmap is null!" ;
\ : ?subbmp  dup al_is_sub_bitmlap if al_get_parent_bitmap then ;

: wrap-bitmap ( albmp - bitmap )
    %bitmap make { albmp ! this } ;

\ ---- source-file hot-reload --------------------------------------------------

\ Source-file modification time, via Allegro's fs entry (0 if unreadable).
: file-mtime ( a n - n )
    >zpad al_create_fs_entry dup 0= if drop 0 exit then
    dup al_get_fs_entry_mtime swap al_destroy_fs_entry ;

\ Has the bitmap's source file changed since we last looked? Records the current
\ mtime on the %bitmap, so the first sighting just baselines (returns false) and
\ a tileset shared by several callers reloads only once per change.
: source-changed? ( bmpid - flag )
    ?bmp>parent {: bmpid | bm mt prev :}
    bmpid id>bmp to bm
    bmpid bitmap-file file-mtime to mt
    mt 0= if false exit then              \ unreadable -> treat as unchanged
    bm >mtime @ to prev
    mt bm >mtime !
    prev 0= if false exit then            \ first sighting: baseline only
    mt prev <> ;

\ Reload the bitmap's pixels from its source file: load a fresh albmp, swap it
\ into the parent %bitmap, free the old one.
: reload-bitmap ( bmpid - )
    ?bmp>parent {: bmpid | bm new old :}
    bmpid id>bmp to bm
    bmpid bitmap-file >zpad al_load_bitmap to new
    new 0= ?exit
    bm >albmp @ to old
    new bm >albmp !
    old al_destroy_bitmap ;

: bmpwh ( bmpid - w h )
    id>albmp ?dup if dup albmpw swap albmph else 0 0 then ;

: bmpw ( bmpid - w )
    bmpwh drop ;

: bmph ( bmpid - h )
    bmpwh nip ;

: bmpxy ( bmp - x y ) 
    id>albmp dup al_get_bitmap_x swap al_get_bitmap_y ;

: put ( bmpid - ) 
    \ draw a sprite; takes a bitfield $F000IIII 
    ?dup -exit
    dup id>albmp swap 24 rshift draw-bitmap ;

: cput ( bmpid - ) 
    \ draw sprite with center as the origin
    dup dup bmpwh -2 -2 2/ +at put bmpwh 2 2 2/ +at ;

%bitmap :: save
    touched @ -exit
    bmp @ id>albmp 0= ?exit  \ Skip if no valid Allegro bitmap
    bmp @ is-subbmp? if
        \ For sub-bitmaps, touch parent and exit
        touched off
        bmp @ bmp>parent ?dup if
            id>bmp >touched on
        then
        exit
    then
    \ Normal bitmap - save it
    touched off
    bmp @ bitmap-file expand >zpad   bmp @ id>albmp al_save_bitmap
        0= abort" Error saving bitmap"
    bmp @ bitmap-file f" Saved bitmap to %s" type cr ;

: save-bitmaps
    \ Do 2 passes - allows touched sub-bitmaps to touch
    \ their parent bitmaps which are then saved once in the second pass
    2 for ['] save bitmaps each loop ;


\ =============================================================================
\ Texture filtering
\ =============================================================================

: tfilter! ( filter-constant bmpid - )
    id>albmp dup 0= if 2drop exit then
    al_get_opengl_texture
    GL_TEXTURE_2D swap glBindTexture
    GL_TEXTURE_2D GL_TEXTURE_MIN_FILTER rot dup >r glTexParameteri
    GL_TEXTURE_2D GL_TEXTURE_MAG_FILTER r> glTexParameteri ;

: tfilter ( filter-constant - )
    next-bmp# @ 1 do dup i tfilter! loop drop ;

: font-tfilter! ( filter-constant font - )
    {: filter font | glyph[ /ALLEGRO_GLYPH ] :}
    font 0 'A' glyph[ al_get_glyph 0= if exit then
    glyph[ ALLEGRO_GLYPH.bitmap @ dup 0= if drop exit then
    dup al_get_parent_bitmap ?dup if nip then
    al_get_opengl_texture
    GL_TEXTURE_2D swap glBindTexture
    GL_TEXTURE_2D GL_TEXTURE_MIN_FILTER filter glTexParameteri
    GL_TEXTURE_2D GL_TEXTURE_MAG_FILTER filter glTexParameteri ;

: aniso! ( level bmpid - )
    id>albmp dup 0= if 2drop exit then
    al_get_opengl_texture
    GL_TEXTURE_2D swap glBindTexture
    s>f GL_TEXTURE_2D GL_TEXTURE_MAX_ANISOTROPY rot 
    dup 0= if drop 1 then
    glTexParameterf ;

: aniso ( level - )
    next-bmp# @ 1 do dup i aniso! loop drop ;

\ =============================================================================
\ Backward compatibility
\ =============================================================================

\ aka >albmp id>albmp
aka bmptotem id>bmp
