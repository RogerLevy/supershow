module [supershow.core]
public

require %idir%/checks.vfx

trait: %object
    :: start ( - ) ;
trait;

trait: %loadable
    :: load ( - ) ;
trait;

trait: %unloadable
    :: unload ( - ) ;
trait;

trait: %saveable
    redef :: save ( - ) stub ;
    :: saveas ( path len ) stub ;
trait;

trait: %usable
    :: use ( - ) ;
trait;

trait: %drawable
    :: draw ( - ) ;       \ pen-relative; caller positions, object draws
    :: render ( - ) draw ; \ engine-facing; object positions itself, manages batch state
    :: draw-view ( sx. sy. w. h. - )
        {: sx sy vpw vph :}
        at@p  vpw  vph  clip{
            sx sy 2negate +atp
            draw
        clip} ;
trait;

trait: %dimensional
    prop w :int
    prop h :int

    :: dims ( - w h ) w 2@ ;
trait;

trait: %poolable
    prop pool :ref %lifo
trait;

trait: %xy
    prop x :fixed <save
    prop y :fixed <save
trait;

trait: %_bitmap 
    prop bmp :int <save
trait;