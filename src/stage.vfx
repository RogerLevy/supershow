\ ------------------------------------------------------------------------------
\ Stage - Actor System
\ ------------------------------------------------------------------------------

public

class: %stage
    %node derive
class;

defer stg@ ( - stage )

\ =============================================================================
\ Actor Access Words
\ =============================================================================

public

|| 0 value xt
continuation: actives> ( - ) ( - )
    xt >r to xt
    [: { en @ if xt execute then } ;] stg@ each
    r> to xt ;

: each-active ( xt - ) ( - )
    xt >r to xt
    [: { en @ if xt execute then } ;] stg@ each
    r> to xt ;

\ =============================================================================
\ Actor Errors
\ =============================================================================

|| redef create buf 256 allot

|| : restore-sp ( a - )
    \ Restore SP. If debug mode is on, report stack imbalances.
    debug @ if
        \ Compare SP to previous SP.
        \ The data stack grows downward.
        dup sp@ cell+ cell+ > if
            [:
            ." Positive stack imbalance in logic for actor " this .summary cr
            .rs .s
            ;] lstrout dup lcount .warn lfree
        then
        dup sp@ cell+ cell+ < if
            [:
            ." Negative stack imbalance in logic for actor " this .summary cr
            .rs .s
            ;] lstrout dup lcount .warn lfree
        then
    then
    sp! ;

\ =============================================================================
\ Find actors
\ =============================================================================

class: %actor
    24 nprop tag$ :cstring <save
class;

|| 0 value xt

|| : (find) ( 0 %actor - 0|actor )
    dup -> en @ 0= if drop exit then
    { xt execute if enough drop this then } ;

continuation: who> ( - actor|0 ) ( - f )
    ( xt ) to xt
    0 ['] (find) stg@ each ;

|| 0 value $
: tagged ( $ - actor|0 )
    to $ who> $ count tag$ count s= ;

|| 0 value z$
: findtag ( z$ - actor|0 )
    to z$ who> z$ zcount tag$ count s= ;

\ =============================================================================
\ Stage processing
\ =============================================================================

\ : priority ( n - )
\     nextpri! ;

|| : (behave)
    actives>
        ?benched
        sp@ >r
        ['] behave catch if
            dup err_bailed = if drop else
                this swap bench
            then
        then
        r> restore-sp ;

|| : (move)
    actives>
        ?benched
        sp@ >r
        ['] physics catch if
            dup err_bailed = if drop else
                this swap bench
            then
        then
        r> restore-sp ;

|| : (step) ( - )
    (behave)
    (move)
    +gametime ;

%actor :: unload ( - )
    unloaded on ; 

: sweep ( - )
    actives>  unloaded @ -exit  unloaded off  en off  this recycle ;

: step ( - )
    hold @ ?exit
    ['] (step) catch
    sweep
    ?dup if 
        hold on
        .throw 
    then 
;

\ =============================================================================
\ Stage management
\ =============================================================================

: clear-stage ( - )
    ['] unload stg@ each sweep ;

: just ( - )
    ." JUST : Clearing all actors!" cr
    clear-stage gamew 2 / gameh 2 / at  ;

: transfer ( actor stage - )
    push ;

: stage-init ( actor stage - )
    udup push  { -1 rnd id !   en on } ;

: one-in ( class stage - actor )
    >r >r free-nodes pop r> over construct dup r> stage-init ;

: one ( class - actor )
    stg@ one-in ;

: spawn ( class - actor )
    one dup start ;

\ Default stage
%stage object actors
' actors is stg@

\ =============================================================================
\ Script Classes
\ =============================================================================

|| : filebase@ ( - a len )
    CurrSourceName -path -ext >lowercase ;

|| : >classbase ( class - a len )
    body>name >pad count >lowercase ?-% ;

\ `module` calls `private` in actor scripts so this is no longer needed:
\ || : (actor-definition) ( class - )
\     >classbase filebase@ s= if private then ;

\ %actor :derive ( source-class derived-class - )
\     nip (actor-definition) ;

|| : hide-if-autoclass ( class - )
    \ Hide autoclass to fix LOCATE
    \ otherwise it would take us to the call to load-autoclasses
    \ even if it's been defined in a script
    dup -> autoclass @ if >name hidename else drop then ;

%actor :reopen ( class - )
    \ Hide generated autoclass when defining an actor class.
    \ This will cause a new class to be created. (see above for rationale)
    \ TODO: There's a better way: modify the class's source file string.
    \       (Hopefully there's a string pointer we can change.)
    \       This will prevent any dangling references to autoclasses.
    hide-if-autoclass ;

|| : find-class ( a len - class | %actor )
    ?-% f" %%%s"
    sfind if execute else drop %actor then ;

|| 0 value c
|| : init-by-class ( class - )
    to c
    actives> this c is? if this resurrect then ;

\ =============================================================================
\ Tools
\ =============================================================================

: .stage ( - )
    [: .summary cr ;] stg@ each ;

\ || cstring update-name$
\ : update ( - [<class>] )
\     \ Live update actor class
\     \ Activates honing mode with custom command (see HONE-CLASS)
\     \ If not class is given, updates the current object's class
\     {: | class0 :}
\     bl parse
\     dup if
\         sfind not if
\             drop pad count f" _%s" sfind not
\             abort" Class not found!"
\         then
\         execute to class0
\         pad count update-name$ place
\     else
\         2drop
\         this valid-object? not abort" ME is not a valid object - nothing to update!"
\         cla @ to class0
\         class0 body>name update-name$ place
\     then
    
\     update-name$ count f" %s.vfx" fexists? if
\         update-name$ count f" ?hone %s.vfx" >hone
\     else
\         update-name$ count f" ?hone scripts\%s.vfx" >hone
\     then
\     this { class0 init-by-class }
\     update-name$ count f" module [%s]" evaluate ;
