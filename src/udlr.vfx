private
create walkv's  1. , 0 ,   0 , -1. ,   -1. , 0 ,   0 , 1. , 

public
0 constant right
1 constant up
2 constant left
3 constant down

$08 constant BIT_FLR
$04 constant BIT_CEL
$02 constant BIT_WLT
$01 constant BIT_WRT

0 value lwall?
0 value rwall?
0 value floor?
0 value ceiling?

\ Probe context (set before each filter call, readable by filters)
0 value probe-x       \ fixed-point probe x
0 value probe-y       \ fixed-point probe y
0 value probe-col     \ tile column
0 value probe-row     \ tile row

\ Hit details (set by tmslide?/tread? on contact)
0 value hit-tile      \ tile metadata value at contact point
0 value hit-col       \ tile column of last hit
0 value hit-row       \ tile row of last hit
0 value hit-obj       \ other actor (for actor-vs-actor)

: clear-collision-state
    0 to lwall?  0 to rwall?  0 to floor?  0 to ceiling?
    0 to probe-x  0 to probe-y  0 to probe-col  0 to probe-row
    0 to hit-tile  0 to hit-col  0 to hit-row  0 to hit-obj ;

class: %actor
    prop dir :int <save
class;

: dirkeys? ( - f )
    <left> held? <right> held? or <up> held? or <down> held? or ;

: dirkeysup? ( - f )
    <left> letgo? <right> letgo? or <up> letgo? or <down> letgo? or ;

: pudlr4 ( - )
    <left> pressed? if  left dir !  exit then
    <right> pressed? if  right dir !  exit then
    <up> pressed? if  up dir !  exit then
    <down> pressed? if  down dir !  exit then ;

: sudlr4 ( - )
    <left> held? if  left dir !  exit then
    <right> held? if  right dir !  exit then
    <up> held? if  up dir !  exit then
    <down> held? if  down dir !  exit then ;

: dir>v  2 cells * walkv's + 2@ ;