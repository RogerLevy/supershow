\ Cooperative multitasking - translated from VFXLand4

public

create task-actor-list /list allot  task-actor-list /list erase

16 kb constant TASK_RSIZE

class: %actor
    prop task.sp
    prop task.rp
    prop task.ds
    prop task.rs
class;

%actor object host
host value task

: yield
    this dup
    sp@ task -> task.sp !
    rp@ task -> task.rp !
    host to task
    task -> task.rp @ rp!
    task -> task.sp @ sp!
    drop to this ;

: fyield ( f:n - f:n ) \ preserves a float on the data stack
    f>sf yield sf>f ;

: wait ( n. - )
    ?dup -exit
    p>f begin fyield fdelta f- fdup 0e f<= until fdrop ;  \ ??? delta equivalent

|| : (spin)
    begin yield again ;

|| : ?*stacks
    task.ds @ ?exit
    2048 allocate throw task.ds !
    TASK_RSIZE allocate throw task.rs !
    turnkey-mode @ if this task-actor-list add-to then ;

: perform ( n xt - )
    ?*stacks
    swap ( xt n ) task.ds @ 1024 + !
    task.ds @ 1024 + task.sp !
    this task.ds @ 1024 + cell+ !
    task.rs @ TASK_RSIZE + cell- cell- !
    task.rs @ TASK_RSIZE + cell- cell- task.rp !
    ['] (spin) task.rs @ TASK_RSIZE + cell- !
    act>
        this dup
        sp@ task -> task.sp !
        rp@ task -> task.rp !
        this to task
        task -> task.rp @ rp!
        task -> task.sp @ sp!
        drop to this ;

continuation: task> ( n - <code;> ) ( n - ... )
    perform ;

|| : reinit-task ( actor - )
    as>
    0 beha !
    0 task.sp !  0 task.rp !
    0 task.ds !  0 task.rs ! ;

: reinit-task-actors ( - )
    task-actor-list list-count for
        list-next
        dup InForth? if reinit-task else drop then
    loop drop ;

%actor :: unload
    task.ds @ free drop  
    task.rs @ free drop  
    this reinit-task
    actor:unload ;
