module
import supershow.core
import supershow.bitmap
import supershow.tileset
import allegro5
import supershow.shader
import array \ exposes SLOT

public

28 constant s/sbv       \ bytes per vertex
6  constant v/sbsprite  \ vertices per sprite quad (TRIANGLE_LIST)

\ Vertex declaration: [x:s16 y:s16] @0 + [u:s16 v:s16 layer:s16 _:s16] @4 + [color:4f] @12 = 28 bytes
create _sb-vdecl
    ALLEGRO_PRIM_POSITION   , ALLEGRO_PRIM_SHORT_2 , 0  ,
    ALLEGRO_PRIM_USER_ATTR  , ALLEGRO_PRIM_SHORT_4 , 4  ,
    ALLEGRO_PRIM_COLOR_ATTR , 0                    , 12 ,
    0 , 0 , 0 ,

4096 constant max-sb-sprites   \ max sprites per flush

class: %spritebank
    prop layer-size  :int    \ pixel size of each layer (square, power-of-2)
    prop max-layers  :int    \ number of layers in the texture array
    prop used-layers :int    \ how many layers have been registered
    prop gl-tex      :int    \ raw OpenGL texture array handle
    prop vbuf        :addr   \ CPU vertex buffer
    prop vptr        :addr   \ current write cursor (reset each frame)
    prop prim-decl   :addr   \ Allegro vertex declaration handle
    prop layer-map   :ref %array   \ bmpid → layer# (-1 = not registered)
class;

|| variable _gen-tex-tmp   \ scratch cell for glGenTextures / glDeleteTextures

%spritebank :destruct
    gl-tex @ if  gl-tex @  _gen-tex-tmp !  1 _gen-tex-tmp  glDeleteTextures  then
    vbuf @ if  vbuf @ free drop  then
    layer-map @ destroy ;

private

|| 0 value _sb-shader
|| 0 value _vp   \ vertex write cursor

create _sb-vs  s" %supershow%/src/glsl/spritebank.vs" file,  0 c,
create _sb-fs  s" %supershow%/src/glsl/spritebank.fs" file,  0 c,

fast{ optimising on

\ Write one vertex at _vp; x y u v layer are integer pixel coords
: +sbvtx ( x y u v layer - )
    _vp 8 +  w!          \ layer
    _vp 6 +  w!          \ v
    _vp 4 +  w!          \ u
    _vp 2 +  w!          \ y
    _vp      w!          \ x
    s/sbv +to _vp ;

public

: init-spritebank ( - )
    init-gl-extensions
    _sb-vs  _sb-fs  load-shader  to _sb-shader ;

: make-spritebank ( layer-size max-layers - bank )
    {: lsz maxl | bank :}
    %spritebank hmake  to bank
    lsz   bank >layer-size !
    maxl  bank >max-layers !
    \ Layer map: one cell per bitmap slot, initialized -1 (not registered)
    #bitmaps %int %array hmake  bank >layer-map !
    bank >layer-map @ >data @  #bitmaps cells  255  fill
    \ GL texture array
    1  _gen-tex-tmp  glGenTextures
    _gen-tex-tmp @  bank >gl-tex !
    GL_TEXTURE_2D_ARRAY  _gen-tex-tmp @  glBindTexture
    0  GL_UNSIGNED_BYTE  GL_RGBA  0
        maxl  lsz lsz  GL_RGBA8  0  GL_TEXTURE_2D_ARRAY  glTexImage3D
    GL_TEXTURE_2D_ARRAY  GL_TEXTURE_MIN_FILTER  GL_NEAREST  glTexParameteri
    GL_TEXTURE_2D_ARRAY  GL_TEXTURE_MAG_FILTER  GL_NEAREST  glTexParameteri
    GL_TEXTURE_2D_ARRAY  GL_TEXTURE_WRAP_S  GL_CLAMP_TO_EDGE  glTexParameteri
    GL_TEXTURE_2D_ARRAY  GL_TEXTURE_WRAP_T  GL_CLAMP_TO_EDGE  glTexParameteri
    \ GL_TEXTURE_2D_ARRAY GL_TEXTURE_BASE_LEVEL 0 glTexParameteri
    \ GL_TEXTURE_2D_ARRAY GL_TEXTURE_MAX_LEVEL 0 glTexParameteri
    \ CPU vertex buffer; pre-fill color (offset 12-27 per vertex) to white
    max-sb-sprites v/sbsprite * s/sbv *  allocate throw  bank >vbuf !
    bank >vbuf @  bank >vptr !
    max-sb-sprites v/sbsprite * 0 do
        1e  bank >vbuf @  i s/sbv * +  12 +  sf!
        1e  bank >vbuf @  i s/sbv * +  16 +  sf!
        1e  bank >vbuf @  i s/sbv * +  20 +  sf!
        1e  bank >vbuf @  i s/sbv * +  24 +  sf!
    loop
    \ Allegro vertex declaration
    _sb-vdecl  s/sbv  al_create_vertex_decl  bank >prim-decl !
    bank ;

: flip-rows ( src pitch h dst rowbytes - )
    {: src pitch h dst rb :}
    h 0 do
        src  pitch i *  +   dst  rb i *  +   rb  move
    loop ;

: add-to-bank ( bmpid bank - layer# )
    {: bmpid bank | albmp lyr lock tmp w h rb :}
    bank >used-layers @  dup bank >max-layers @ >= abort" spritebank full"  to lyr
    lyr  bmpid  bank >layer-map @ slot !
    bmpid id>albmp  to albmp
    albmp albmpw  to w   albmp albmph  to h
    w  bank >layer-size @  > abort" bitmap too wide for spritebank"
    h  bank >layer-size @  > abort" bitmap too tall for spritebank"
    w 4 *  to rb
    albmp  ALLEGRO_PIXEL_FORMAT_ABGR_8888  ALLEGRO_LOCK_READONLY  al_lock_bitmap  to lock
        lock 0= abort" al_lock_bitmap failed"
        rb h *  allocate throw  to tmp
        lock @  lock 8 + @  h  tmp  rb  flip-rows
        GL_TEXTURE_2D_ARRAY  bank >gl-tex @  glBindTexture
        tmp  GL_UNSIGNED_BYTE  GL_RGBA  1  h  w
            lyr 0 0  0  GL_TEXTURE_2D_ARRAY  glTexSubImage3D
        tmp free drop
    albmp al_unlock_bitmap
    lyr 1+  bank >used-layers !
    lyr ;

: add-tileset-to-bank ( tileset bank - )
    {: ts bank | lyr :}
    ts -> bmp @  bank add-to-bank  to lyr
    ts -> #tiles @ 0 do
        lyr  i ts -> baseid @ +  bank >layer-map @ slot !
    loop ;

public

0 value active-bank

: flush-bank ( - )
    {: | #v :}
    active-bank 0= if exit then
    active-bank >vptr @  active-bank >vbuf @  -  s/sbv /  to #v
    #v 0= if  0 to active-bank  exit  then
    _sb-shader  shade
    GL_TEXTURE0 1 +  glActiveTexture
    GL_TEXTURE_2D_ARRAY  active-bank >gl-tex @  glBindTexture
    1  z" tex_array"  int!
    active-bank >vbuf @  active-bank >prim-decl @  0  0  #v
        ALLEGRO_PRIM_TRIANGLE_LIST  al_draw_prim  drop
    0 shade
    GL_TEXTURE0  glActiveTexture
    0 to active-bank ;

: rebank ( bank - )
    to active-bank
    active-bank >vbuf @  active-bank >vptr ! ;

continuation: bank> ( bank - ) ( xt )
    swap to active-bank
    active-bank >vbuf @  active-bank >vptr !
    execute
    flush-bank ;

redef : albmpwh  9 cells + 2@ ;
: albmpxy  $164 + 2@ ;

: bput ( bmpid - )
    {: bmpid | lyr albmp bx by bw bh x0 y0 x1 y1 u0 v0 u1 v1 :}
    active-bank 0= if  bmpid put exit  then
    bmpid $FFFF and  active-bank >layer-map @ slot @  to lyr
    lyr -1 = if  active-bank  flush-bank  rebank  bmpid put exit  then
    bmpid id>albmp  to albmp
    albmp albmpwh  to bh to bw
    albmp albmpxy  to by to bx
    bx  to u0   bx bw +  to u1
    by  to v0   by bh +  to v1
    bmpid $1000000 and if  u0 u1  to u0  to u1  then  \ h-flip
    bmpid $2000000 and if  v0 v1  to v0  to v1  then  \ v-flip
    at@p 2>i  to y0  to x0
    x0 bw +  to x1
    y0 bh +  to y1
    active-bank >vptr @  to _vp
    x0 y0  u0 v0  lyr  +sbvtx   \ TL
    x1 y0  u1 v0  lyr  +sbvtx   \ TR
    x1 y1  u1 v1  lyr  +sbvtx   \ BR
    x0 y0  u0 v0  lyr  +sbvtx   \ TL
    x1 y1  u1 v1  lyr  +sbvtx   \ BR
    x0 y1  u0 v1  lyr  +sbvtx   \ BL
    _vp  active-bank >vptr ! ;

: bcput ( bmpid - )
    {: bmpid | bw bh :}
    bmpid id>albmp albmpwh  to bh  to bw
    at@p
    bw bh 2 2 2/ 2negate  +at
    bmpid bput
    atp ;

optimising off fast}