\ meant to be INCLUDEd - each INCLUDE creates a new help system for the current module

public

|| redef variable commands

redef : help ( - )
    cr 
    commands
    begin @ ?dup while
        dup cell+ 
            count 
            2dup 2 /string 15 atype
            50 out @ - spaces            
            + count 6 /string type cr 
    repeat ;

|| redef : command ( - )
    save-input
    commands link
    0 parse $, 
    refill 0= abort" COMMAND : Unexpected end of file"
    0 parse $, 
    restore-input drop ;

 