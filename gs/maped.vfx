\ GreySplatter — paint screen.
\ Draws the level under the camera, a ghost of the brush at the cursor, the
\ marquee, and an info line; polls input for painting / eyedrop / pan / marquee
\ / clipboard / layer + flip controls.

public

\ ---- input -------------------------------------------------------------------

0 value pan-lastx
0 value pan-lasty
0 value panning?

\ Pan on Space + LMB drag (matches the original's Space+drag). Returns true
\ when it handled the gesture, so the caller can stop. Initialises the anchor
\ on the first frame of the drag so there's no jump.
: try-pan ( - flag )
    {: | mx my :}
    <space> held? <lmb> held? and 0= if  0 to panning?  0 exit  then
    mouse to my to mx
    panning? not if  mx to pan-lastx  my to pan-lasty  -1 to panning?  then
    pan-lastx mx -  >p  camx +  camx!
    pan-lasty my -  >p  camy +  camy!
    mx to pan-lastx  my to pan-lasty
    clamp-camera  -1 
;

\ Round a fixed pixel coord to a multiple of t pixels (t = a tile dimension).
: down-tile ( n. t - n'. )  >p tuck p/ pfloor p* ;
: up-tile   ( n. t - n'. )  swap negate swap  down-tile  negate ;
: near-tile ( n. t - n'. )  dup 2 / >p  rot +  swap  down-tile ;

: cam-aligned? ( - flag )   \ camera sitting on the current layer's tile grid?
    camx tilew down-tile camx =  camy tileh down-tile camy =  and ;

\ shift+arrow: if the camera is off the current layer's tile grid, snap it onto
\ the grid -- toward the arrow on its axis, nearest on the other to finish the
\ alignment. If already aligned, step one grid cell as before.
: ?grid-move ( - )
    shift? -exit
    cam-aligned? if
        <left>  pressed? if  gridw negate >p  camx +  camx!  then
        <right> pressed? if  gridw        >p  camx +  camx!  then
        <up>    pressed? if  gridh negate >p  camy +  camy!  then
        <down>  pressed? if  gridh        >p  camy +  camy!  then
    else
        <left>  pressed? if  camx tilew down-tile camx!  camy tileh near-tile camy!  then
        <right> pressed? if  camx tilew up-tile   camx!  camy tileh near-tile camy!  then
        <up>    pressed? if  camy tileh down-tile camy!  camx tilew near-tile camx!  then
        <down>  pressed? if  camy tileh up-tile   camy!  camx tilew near-tile camx!  then
    then
    clamp-camera
;

: ?scroll ( - )
    shift? ?exit
    <left> held? if  camx -2. +  camx!  then
    <right> held? if  camx 2. +  camx!  then
    <up> held? if  camy -2. +  camy!  then
    <down> held? if  camy 2. +  camy!  then
;

-1 value rmb-startc
0  value rmb-startr

\ Shift+RMB drag: define selection rect interactively; on release copy to brush.
: do-rmb-marquee ( - )
    {: | col row :}
    shift? -exit
    <rmb> pressed? if
        mouse-cell to rmb-startr to rmb-startc
        rmb-startc rmb-startr  tile-sel 2!
        1 1  tile-sel 2 cells + 2!
    then
    rmb-startc 0< ?exit
    <rmb> letgo? if  copy-sel  -1 to rmb-startc  exit  then
    <rmb> held? -exit
    mouse-cell to row to col
    rmb-startc col min  rmb-startr row min
    tile-sel 2!
    rmb-startc col - abs 1 +  rmb-startr row - abs 1 +
    tile-sel 2 cells + 2!
;

: toggle-mute ( - )
    layer# scratch# < if  the-layer >vis toggle  then ;

: toggle-solo ( - )
    false
    scratch# for
        layer# i <> if  the-level i layer >vis @ or then 
    loop
    if
        scratch# for
            layer# i <> if  the-level i layer >vis off  then 
        loop
    else
        scratch# for
            layer# i <> if  the-level i layer >vis on  then 
        loop
    then 
    the-layer >vis on ;

: maped-input ( - )
    ctrl? if
        shift? if  <S> pressed? if save-as then  exit  then   \ Ctrl+Shift+S = save as
        <S> pressed? if save-current then
        <N> pressed? if new-level then
        <O> pressed? if open-dialog then
        <C> pressed? if copy-sel then
        <X> pressed? if copy-sel erase-sel then
        <E> pressed? if erase-sel then
        <R> pressed? if revert then
        exit
    then
    shift? if
        ?grid-move
        do-rmb-marquee
        do-marquee exit
    then
    try-pan ?exit
    <'> pressed? if  grid? not to grid?  then   \ toggle screen grid
    ?scroll
    <E> pressed? if eraser then
    <H> pressed? if fliph then
    <V> pressed? if flipv then
    <lmb> held?  if  mouse-cell at the-layer paint  then
    <rmb> held?  if  copy-brush-area  then
    <m> pressed? if  toggle-mute  then 
    <s> pressed? if  toggle-solo  then
;


\ ---- draw --------------------------------------------------------------------

: ~brush-ghost ( - )
    shift? ?exit
    <space> held? ?exit
    the-tileset the-brush >ts !
    mouse-cell cell-screen-xy atp
    the-brush draw
    15 color  brushw tilew *  brushh tileh *  2>p rect
;

: ~selection ( - )
    $ffffff80 rgba8
    selc selr cell-screen-xy atp
    selw tilew * >p  selh tileh * >p  rect 
;

: ~info ( - )
    vga-8x8 default-font!  15 color
    0 gameh 8 - at
    mouse-cell swap             \ ( row col ) -> cursor cell, col on top
    camy >i  camx >i
    brushh  brushw  layer# 1 +`
    the-layer >vis @ if f" layer %n  " else f" (layer %n)" then
    f" %s brush %n x %n  cam %n,%n  cell %n,%n" print
;

: ~border
    viewx viewy 2negate  center 2>p 2+  atp  14 color  view-pxw view-pxh 2>p rect ;

|| : ~layer-bound ( n - )
    {: n | par :}
    n slot { prx @ } to par
    \ pivot on the level centre, like draw-layer: visx + (0 - lc) - (cam - lc)*par + center
    n slot { visx @ >p  visy @ >p  level-center 2-  viewx viewy level-center 2-  par dup 2p*  2-  center 2>p 2+  atp }
    n layer-px  2>p rect ;

: ~layer-bounds ( - )
    layer# scratch# = ?exit
    $00ffff60 rgba8
    layer# ~layer-bound ;

\ Screen-grid overlay: vertical/horizontal lines every gridw/gridh world
\ pixels, offset by the camera (matching ~border's -cam origin).
: ~vgrid ( pxh - )
    {: pxh :}
    view-pxw gridw /  1 +  for
        i gridw * >p viewx -  dup  viewy negate  atp
        pxh >p viewy -  line
    loop ;

: ~hgrid ( pxw - )
    {: pxw :}
    view-pxh gridh /  1 +  for
        i gridh * >p viewy -  viewx negate  over  atp
        pxw >p viewx -  swap  line
    loop ;

: ~fixed-vgrid ( - )
    appw gridw + 2 / gridw umod
    appw gridw /  2 +  for
        dup  i gridw * +  >p  dup  0.  atp
        apph >p  line
    loop  drop
;

: ~fixed-hgrid ( - )
    apph gridh + 2 / gridh umod
    apph gridh /  2 +  for
        dup  i gridh * +  >p  0.  over  atp
        appw >p  swap  line
    loop  drop
;

: ~grid ( - )
    grid? 0= ?exit
    $ffff0080 rgba8
    fixed-grid @ if  ~fixed-vgrid  ~fixed-hgrid
               else  m{ center 2>p 2p>f 1e 1e 0e transform  \ scrolling grid follows the centred content
                        view-pxh ~vgrid  view-pxw ~hgrid  m}
    then
;

: ~maped ( - )
    ~world
    ~brush-ghost
    ~info
    ~grid
    ~border
    ~layer-bounds
    ~selection
;

: maped-frame ( - )  maped-input ~maped ;

' maped-frame to maped-xt
