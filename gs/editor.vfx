\ GreySplatter — Supershow level editor
\ Shared editor state, screen dispatcher, camera/mouse mapping, brush, save.
\ See gs/main.vfx for the program entry point.

private

\ ---- state -------------------------------------------------------------------

0    value the-level           \ the one open %level (v1: single level)
0    value layer#              \ active layer index
0    value camx                \ camera origin, fixed pixels
0    value camy
0    value scratch-camx        \ scratch-pad camera, stashed while a normal layer is active
0    value scratch-camy
0    value main-camx           \ normal camera, stashed while the scratch pad is active
0    value main-camy
0    value blink               \ frames left in the layer-select blink
0    value version             \ level file version, bumped on every save
true value info?               \ info overlay toggle
true value grid?               \ screen-grid overlay on/off (persisted in "editor")
320  value gridw               \ screen-grid cell size, pixels
240  value gridh

public command variable fixed-grid
    \ Fixes the grid to the camera

private

create tile-sel  0 , 0 , 1 , 1 ,   \ marquee: col , row , #cols , #rows

1 1 tilemap the-brush          \ clipboard tilemap (always >= 1x1)

create lvl-path$ 256 allot     \ path the level was loaded from (for save)

: selc   ( - n )  tile-sel @ ;
: selr   ( - n )  tile-sel cell+ @ ;
: selw   ( - n )  tile-sel 2 cells + @ ;
: selh   ( - n )  tile-sel 3 cells + @ ;

: sel-box   ( - col row w h ) tile-sel @+ swap @+ swap @+ swap @ ;

\ ---- fixed layer slots -------------------------------------------------------
\ 10 statically-named layer tilemaps, created once and refilled in place. Slots
\ 0..8 are the paintable layers; slot 9 is the hidden scratch pad (layer 10).
\ Loading never mints level-named tilemaps, so nothing is orphaned per level.

10 constant max-layers
max-layers 1 - constant scratch#      \ last slot = the scratch pad (layer 10)
save-order forth-public
128 128 tilemap gs-level0-layer0
128 128 tilemap gs-level0-layer1
128 128 tilemap gs-level0-layer2
128 128 tilemap gs-level0-layer3
128 128 tilemap gs-level0-layer4
128 128 tilemap gs-level0-layer5
128 128 tilemap gs-level0-layer6
128 128 tilemap gs-level0-layer7
128 128 tilemap gs-level0-layer8
128 128 tilemap gs-level0-layer9
restore-order

%int array: slots
    gs-level0-layer0 ,  gs-level0-layer1 ,  gs-level0-layer2 ,  gs-level0-layer3 ,
    gs-level0-layer4 ,  gs-level0-layer5 ,  gs-level0-layer6 ,  gs-level0-layer7 ,
    gs-level0-layer8 ,  gs-level0-layer9 ,
array;

: slot ( n - tilemap )  slots el@ ;

%level dmake to the-level                          \ the one persistent editor level
the-level { slots layers ! }                       \ its layers ARE the fixed slot pool

\ Seed each slot's default layer name; load overrides it, save writes it back.
:noname  max-layers for  i f" layer%n"  i slot >name$ place  loop ; execute

\ ---- tileset hot-reload ------------------------------------------------------
\ Poll each enabled slot's tileset; reload + re-slice when its source file's
\ mtime changes. The change check (source-changed?) lives on %bitmap, so a
\ tileset shared by several slots reloads only once per change.

0 value reload-timer            \ frames until the next poll

: ?reload-slot ( n - )
    {: n | tset :}
    n slot { en @ ts @ and } 0= ?exit
    n slot >ts @ to tset
    tset >bmp @ source-changed? if  tset reload-tileset  then ;

: ?hot-reload ( - )
    reload-timer 0> if  -1 +to reload-timer exit  then
    20 to reload-timer
    max-layers for  i ?reload-slot  loop ;

\ ---- screen dispatcher (editor-local, not mode.vfx) --------------------------

0 value cur-screen            \ xt of the active screen's per-frame word
0 value maped-xt              \ assigned by gs/maped.vfx
0 value tiles-xt              \ assigned by gs/tiles.vfx

: ->maped ( - )  maped-xt to cur-screen ;
: ->tiles ( - )  tiles-xt to cur-screen ;

: fit-display ( - )
    winw zoom @ /  dup to appw  to gamew
    winh zoom @ /  dup to apph  to gameh ;

\ ---- active layer / tileset accessors ----------------------------------------

: the-layer       ( - tilemap )   the-level layer# layer ;
: the-tileset     ( - tileset )   the-layer >ts @ ;
: tilew           ( - n )         the-tileset >tw @ ;
: tileh           ( - n )         the-tileset >th @ ;
: layer-parallax  ( - n. )        the-layer >prx @ ;
: the-layers      ( - array )     the-level >layers @ ;
: layer-count     ( - n )         the-level >layers @ #items ;
: brushw          ( - n )         the-brush >w @ ;
: brushh          ( - n )         the-brush >h @ ;

: blink! ( - )  18 to blink ;       \ flash the freshly-selected layer for a moment

\ Lazily create the scratch pad (slot 9) from the first real tileset, hidden.
: first-tileset ( - tileset|0 )
    scratch# for  i slot { en @ ts @ and } if  i slot >ts @ unloop exit  then  loop  0 ;

: ensure-scratch ( - )
    scratch# slot >en @ ?exit
    first-tileset dup 0= if drop exit then
    scratch# slot {
        128 128 this resize-tilemap   ts !
        1.0 prx !  this clear-tilemap  en on  vis off } ;

\ The scratch pad keeps its own camera; swap it in/out of camx/camy on entry/exit.
: enter-scratch ( - )  camx to main-camx  camy to main-camy  scratch-camx to camx  scratch-camy to camy ;
: leave-scratch ( - )  camx to scratch-camx  camy to scratch-camy  main-camx to camx  main-camy to camy ;

: set-layer ( n - )
    0 max  scratch# min  {: n :}
    n scratch# = if  ensure-scratch  scratch# slot >en @ 0= ?exit
                else n slot >en @ 0= ?exit  then
    layer# scratch# =  n scratch# =  <> if
        n scratch# = if enter-scratch else leave-scratch then  then
    n to layer#  blink! ;

: ?layer-keys ( - )
    <1> pressed? if 0 set-layer ->maped then
    <2> pressed? if 1 set-layer ->maped then
    <3> pressed? if 2 set-layer ->maped then
    <4> pressed? if 3 set-layer ->maped then
    <5> pressed? if 4 set-layer ->maped then
    <6> pressed? if 5 set-layer ->maped then
    <7> pressed? if 6 set-layer ->maped then
    <8> pressed? if 7 set-layer ->maped then
    <9> pressed? if 8 set-layer ->maped then
    <`> pressed? if scratch# set-layer ->maped then ;

: ?global-keys ( - )   \ screen-switch + info, active on every screen
    <F1> pressed? if ->maped then
    <F2> pressed? if ->tiles then
    <I>  pressed? if info? not to info? then
    ?layer-keys ;

: editor-frame ( - )  fit-display  ?global-keys  ?hot-reload  blink 0> if -1 +to blink then  cur-screen ?execute ;

\ ---- camera / mouse mapping --------------------------------------------------

: parallax+ ( x. y. - x. y. )  camx camy  layer-parallax dup  2p* 2+ ;
: parallax- ( x. y. - x. y. )  camx camy  layer-parallax dup  2p* 2- ;

\ Screen mouse -> the-layer cell (col,row), accounting for the layer's
\ parallax: world = mouse + cam * parallax.
: mouse-cell ( - col row )
    pmouse parallax+  the-layer xy>cr ;

\ Top-left screen pixel (fixed) of a cell on the active layer.
\ cr>xy returns integer world pixels (col*tw, row*th), so promote to fixed
\ before subtracting the fixed, parallax-scaled camera offset.
: cell-screen-xy ( col row - x. y. )
    the-layer cr>xy  2>p  parallax- ;

\ Editor camera clamp: generous bounds so the level can slide fully across the
\ viewport in either direction (works whether the level is larger OR smaller
\ than the viewport, so panning is never pinned). Units are logical pixels —
\ gamew is the post-zoom logical viewport, matching camx's units.
: clamp-camera ( - )
    camx  gamew negate >p  the-level >pxw @ >p  clamp to camx
    camy  gameh negate >p  the-level >pxh @ >p  clamp to camy ;

\ ---- editor view -------------------------------------------------------------

: blink-hide? ( - flag )  blink 0>  blink 6 mod 3 <  and ;

\ Draw the level for editing: on the scratch pad show only it (its own camera);
\ otherwise show all visible layers, blinking the freshly-selected one.
: ~world ( - )
    camx camx! camy camy!
    layer# scratch# = if  the-level scratch# draw-layer  exit  then
    blink-hide? if
        the-layer >vis @ >r  the-layer >vis off
        the-level render
        r> the-layer >vis !
    else
        the-level render
    then ;

\ ---- brush -------------------------------------------------------------------

: load-brush-1 ( cell - )   \ set the brush to a single given cell
    1 1 the-brush resize-tilemap
    the-brush >ta @ >data @ ! ;

: eraser ( - )  $FFFFFFFF load-brush-1 ;

\ Flip the brush: mirror cell positions AND toggle the flip flag per cell, so a
\ multi-cell brush mirrors correctly (not just per-tile flags).
: ?flip ( cell xor - cell' )  over $FFFFFFFF = if drop exit then  xor ;

: brush-cell ( col row - addr )   \ address of a brush cell
    brushw *  +  cells  the-brush >ta @ >data @ + ;

: fliph ( - )
    brushh for
        brushw 2 / for
            i j brush-cell`  brushw 1 - i -  j brush-cell` xchg
        loop
    loop
    [: $01000000 ?flip ;] the-brush !each ;

: flipv ( - )
    brushh 2 / for
        brushw for
            i j brush-cell`  i  brushh 1 - j - brush-cell` xchg
        loop
    loop
    [: $02000000 ?flip ;] the-brush !each ;

: paint ( dest - )   \ stamp the brush; Alt = put (skip empties), else paste (all); pen = col/row    
    >r the-brush at@ r> 
    alt? if  put-tilemap  else  paste-tilemap  then 
;

\ ---- selection -> clipboard --------------------------------------------------

: copy-sel ( - )   \ active layer's selected region -> brush
    the-layer  sel-box  the-brush  slice-tilemap ;

: copy-brush-area ( - )   \ copy brush-sized region at cursor into the brush
    the-layer  mouse-cell  brushw brushh  the-brush  slice-tilemap ;

: erase-sel ( - )   \ clear the selected region on the active layer
    selh for
        selw for
            $FFFFFFFF  selc i +  selr j +  the-layer  tile!
        loop
    loop 
;

\ ---- marquee selection (over the active layer) -------------------------------
\ Shift+drag sets the selection rect live; on release the selected region
\ becomes the brush.

-1 value sel-startc
0  value sel-startr

: do-marquee ( - )
    {: | col row :}
    shift? -exit
    <lmb> pressed? if  mouse-cell to sel-startr to sel-startc  then
    sel-startc 0< ?exit
    \ <lmb> letgo? if  copy-sel  -1 to sel-startc  exit  then
    <lmb> held? -exit
    mouse-cell to row to col
    sel-startc col min  sel-startr row min          ( left top )
    tile-sel 2!
    sel-startc col - abs 1 +  sel-startr row - abs 1 +   ( w h )
    tile-sel 2 cells + 2! 
;

\ ---- runtime tileset loading -------------------------------------------------

create gs-zbuf    1024 allot     \ scratch zstring for paths / bitmap evaluate
create gs-pathbuf  256 allot     \ picked tileset source path (counted)

\ ---- tilesetfile path <-> level-relative resolution --------------------------
\ Store a tileset path relative to the level file when the PNG lives under the
\ level's folder, so a project moves as a unit; fall back to absolute otherwise.

: level-dir ( - a u )   \ directory portion of the saved level path (trailing \)
    lvl-path$ count  2dup -path drop nip  over - ;

|| : abs-path? ( a u - flag )   \ Windows drive-qualified path ("X:...")?
    2 < if drop 0 exit then  1+ c@ [char] : = ;

|| : dotdot? ( a u - flag )     \ path starts with ".." (escapes the level dir)?
    2 < if drop 0 exit then  dup c@ [char] . =  swap 1+ c@ [char] . =  and ;

: resolve-tileset ( a u - a' u' )   \ make a stored tilesetfile absolute via level-dir
    2dup abs-path? if exit then
    level-dir f" %s%s" normalize ;

: tileset-path ( bmpid - a u )   \ level-relative when the PNG is under the level dir
    bitmap-file {: bmp-a bmp-u | rel-a rel-u :}
    lvl-path$ c@ 0= if  bmp-a bmp-u exit  then        \ never saved -> absolute
    level-dir  bmp-a bmp-u  >relpath  to rel-u to rel-a
    rel-u 0=             if  bmp-a bmp-u exit  then    \ failed (e.g. other drive)
    rel-a rel-u abs-path? if  bmp-a bmp-u exit  then   \ came back absolute
    rel-a rel-u dotdot?  if  bmp-a bmp-u exit  then    \ escapes the level dir
    rel-a rel-u ;

: tileset-loaded? ( name-a name-len - flag )
    sfind if >body @ %bitmap is? else drop 0 then ;

\ Load a PNG and slice a square tileset (16 tiles wide) under the given name,
\ unless a word of that name already exists.
: ensure-tileset ( path-a path-len name-a name-len - )
    {: path-a path-len name-a name-len | bmpid tw :}
    name-a name-len tileset-loaded? ?exit
    path-a path-len -path sfind nip not if 
        path-a path-len f" bitmap %s" .evaluate              \ define "<file>.<ext>" bitmap word
    then
    path-a path-len -path evaluate to bmpid
    name-a name-len -ext f" %s.ts" sfind nip not if
        bmpid  bmpw 16 / to tw                         \ tile size = width / 16 (square)
        bmpid  name-a name-len -ext  tw tw  f" %n %n tileset %s.ts" .evaluate 
    then
;

\ Pick a PNG via dialog; ensure its named tileset is loaded.
\ Returns ( path-a path-len name-a name-len | 0 0 0 0 ).
: pick-tileset ( - path-a path-len name-a name-len | 0 0 0 0 )
    {: | path-a path-len name-a name-len :}
    0 z" Select Tileset (16 wide)" z" *.png" load-dialog
    dup 0= if 2drop 0 0 0 0 exit then
    gs-pathbuf place
    gs-pathbuf count to path-len to path-a
    path-a path-len -path -ext f" %s.ts" to name-len to name-a
    path-a path-len name-a name-len ensure-tileset
    path-a path-len name-a name-len 
;

\ Load a level's tilesets from stored "tilesetfile" paths (if any). Layers
\ without one are assumed already defined (e.g. compiled into the program).
: preload-tilesets ( cjson - )
    {: cjson | layers fp[ 256 ] lyr :}
    cjson "layers" j>j to layers
    layers jsize for  
        layers i j>j to lyr
        lyr "tilesetfile" ?j>z ?dup if
            zcount resolve-tileset fp[ place
            lyr "tileset" ?j>z not if
                fp[ count 2dup -path ensure-tileset
            else
                fp[ count  lyr "tileset" j>s  ensure-tileset
            then
        then
    loop 
;

: hide-tilesets ( - )   \ hide each used tileset's word so preload re-slices it fresh
    max-layers for
        i slot { en @ ts @ and } if
            i slot >ts @ body> >name hidename
        then
    loop
;

\ ---- build the persistent level from a cjson root (over the fixed slots) ------

: build-layer-slot ( layerj n - )   \ configure + refill + enable slot n
    {: layerj n :}
    n slot {
        layerj "cols" j>n  layerj "rows" j>n  this resize-tilemap
        layerj layer-tileset  ts !
        layerj n layer-name$  name$ place
        layerj this layer-view!
        layerj "tiles" j>s  this parse-tilemap
        en on
    }
;

: layer-px ( n - wpx hpx )  slot { w @ h @ this cr>xy } ;

\ Pixel bounds for the current view: scratch layer dims on the scratch screen,
\ level dims otherwise.
: view-pxw ( - n )  layer# scratch# = if  scratch# layer-px drop  else  the-level >pxw @  then ;
: view-pxh ( - n )  layer# scratch# = if  scratch# layer-px nip   else  the-level >pxh @  then ;

: set-bounds ( - )   \ camera bounds = largest enabled paintable-layer extent
    {: | mw mh :}
    0 to mw  0 to mh
    scratch# for
        i slot { en @ ts @ and } if  i layer-px  mh max to mh  mw max to mw  then
    loop
    the-level { mw pxw !  mh pxh ! } ;

: load-scratch ( cjson - )   \ slot 9 from the separate "scratchlayer" field (hidden in games)
    "scratchlayer" ?get-item ?dup if
        scratch# build-layer-slot  scratch# slot >vis off
    else
        scratch# slot >en off
    then ;

: load-editor ( cjson - )   \ camera positions + version + grid from the "editor" block
    {: cjson | ej :}
    320 to gridw  240 to gridh  0 fixed-grid !    \ grid defaults
    cjson "editor" ?get-item to ej
    ej 0= if
        0 to version
        0 to camx  0 to camy  0 to main-camx  0 to main-camy
        0 to scratch-camx  0 to scratch-camy  exit
    then
    ej "version"     ?j>n          to version
    ej "camx"        ?j>n >p  dup  to camx  to main-camx
    ej "camy"        ?j>n >p  dup  to camy  to main-camy
    ej "scratchcamx" ?j>n >p       to scratch-camx
    ej "scratchcamy" ?j>n >p       to scratch-camy
    ej "grid"        ?j>j if 
        ej "grid" ?j>n             to grid?
    then
    ej "gridw"       ?j>n ?dup if  to gridw  then
    ej "gridh"       ?j>n ?dup if  to gridh  then
    ej "fixed-grid"  ?j>n  fixed-grid ! ;

: load-level ( cjson - )   \ refill the slot pool from a cjson root; enable used slots
    {: cjson | layersj n :}
    cjson the-level >src !
    cjson "layers" j>j to layersj
    layersj jsize to n
    scratch# for
        i n < if  layersj i j>j  i build-layer-slot
        else      i slot >en off  then
    loop
    cjson load-scratch
    cjson load-editor
    set-bounds
    cjson "w" ?j>n ?dup if the-level >pxw ! then
    cjson "h" ?j>n ?dup if the-level >pxh ! then ;

\ ---- open / new / save -------------------------------------------------------

: open-level ( path-a path-len - )
    expand lvl-path$ place
    lvl-path$ count load-json
    hide-tilesets 
    ( json ) dup preload-tilesets    \ load each layer's tileset from its "tilesetfile"
        load-level                   \ load-editor (inside) restores the cameras + version
    0 to layer#  0 load-brush-1 ;

: new-from-cjson ( cjson - )   \ build from an in-memory cjson; blank the layers
    load-level
    layer-count for  i slot clear-tilemap  loop
    0 to layer#  0 load-brush-1 ;

: *new-level ( tspath-a tspath-len tsname-a tsname-len - )   \ build a blank level around a chosen tileset
    {: tspath-a tspath-len tsname-a tsname-len | root layers layer0 _tw :}
    tsname-a tsname-len evaluate >tw @ to _tw
    cjson-new-object to root
    "untitled"  "tsname"  root  cjson-add-string
    cjson-new-array to layers
    cjson-new-object to layer0
    "layer0"   "tsname"  layer0 cjson-add-string
    tsname-a tsname-len gs-zbuf zplace  
    gs-zbuf  "tileset"      layer0 cjson-add-string
    tspath-a tspath-len gs-zbuf zplace  
    gs-zbuf  "tilesetfile"  layer0 cjson-add-string
    _tw    "tw"    layer0 cjson-add-int
    _tw    "th"    layer0 cjson-add-int
    128   "cols"  layer0 cjson-add-int
    128   "rows"  layer0 cjson-add-int
    "_"   "tiles" layer0 cjson-add-string
    layer0  0  layers  cjson-add-item
    layers  "layers"  root  cjson-add-array
    cjson-new-array  "actors"  root  cjson-add-array
    root new-from-cjson
    lvl-path$ off ;             \ unsaved -> Ctrl+S triggers save-as

: new-level ( - )
    pick-tileset  dup 0= if 4drop exit then  *new-level ;

: no-tileset ( - )
    z" GreySplatter" z" No tileset selected, quitting..." messagebox ;

\ Turnkey startup: like new-level, but a level is mandatory, so quit cleanly
\ (with a heads-up) when the user cancels the tileset dialog.
: new-level-or-quit ( - )
    pick-tileset  dup 0= if no-tileset bye then  *new-level ;

: open-dialog ( - )
    0 z" Open Level" z" *.json" load-dialog
    dup 0= if 2drop exit then
    gs-zbuf zplace  gs-zbuf zcount open-level ;

: revert ( - )   \ reload the current level from disk, re-slicing its tilesets
    lvl-path$ c@ 0= ?exit
    lvl-path$ count open-level
;

\ ---- save (serialize the live enabled layers to a fresh cjson tree) ----------

: layer>json ( tilemap - layerj )
    {: tm | json :}
    cjson-new-object to json
    tm {
        name$ count             gs-zbuf zplace  gs-zbuf  "name"         json cjson-add-string
        ts @ body>name            gs-zbuf zplace  gs-zbuf  "tileset"      json cjson-add-string
        ts @ >bmp @ tileset-path  gs-zbuf zplace  gs-zbuf  "tilesetfile"  json cjson-add-string
        w @  "cols"  json cjson-add-int
        h @  "rows"  json cjson-add-int
        prx @ "parallax" json cjson-add-fixed
        visx @ "visx"   json cjson-add-int
        visy @ "visy"   json cjson-add-int
        rpt  @ "repeat" json cjson-add-int
        vis  @ "vis"    json cjson-add-int
        this encode-tiles  "tiles"  json cjson-add-string
    }
    json ;

: save-cams ( - )   \ sync the inactive camera stash from the live camera
    layer# scratch# = if  camx to scratch-camx  camy to scratch-camy
                     else  camx to main-camx     camy to main-camy  then ;

: *editor-json ( - cjson )
    {: | ej :}
    cjson-new-object to ej
    version         "version"      ej cjson-add-int
    main-camx >i    "camx"         ej cjson-add-int
    main-camy >i    "camy"         ej cjson-add-int
    scratch-camx >i "scratchcamx"  ej cjson-add-int
    scratch-camy >i "scratchcamy"  ej cjson-add-int
    grid?           "grid"         ej cjson-add-int
    gridw           "gridw"        ej cjson-add-int
    gridh           "gridh"        ej cjson-add-int
    fixed-grid @    "fixed-grid"   ej cjson-add-int
    ej ;

: *level-json ( - cjson )   \ serialize live layers; bumps version + syncs cameras
    {: | root arr :}
    save-cams  1 +to version
    cjson-new-object to root
    cjson-new-array  to arr
    \ No root "name": the level's name is its file's base name (see build-level).
    scratch# for
        i slot >en @ if  i slot layer>json  0 arr cjson-add-item  then
    loop
    arr  "layers"  root cjson-add-array
    scratch# slot >en @ if  scratch# slot layer>json  "scratchlayer"  root cjson-add-item  then
    *editor-json  "editor"  root cjson-add-item
    root ;

|| : .json? ( a u - flag )   \ does the path already end in ".json"?
    fext  s" json"  s= ;

: save-as ( - )
    0 z" Save Level As" z" *.json" save-dialog
    dup 0= if 2drop exit then
    2dup .json? 0= if  f" %s.json"  then    \ ensure a .json extension
    lvl-path$ place
    *level-json lvl-path$ count save-json ;

: ?save-as ( - )  
    lvl-path$ c@ 0= if  save-as exit  then ;

: save-current ( - )
    ?save-as   *level-json lvl-path$ count save-json ;

\ ---- layer management (REPL) -------------------------------------------------
\ Layers are a fixed pool of slots; `en` marks a slot in use.

: free-slot ( - n )   \ first free paintable slot (excludes the scratch pad), or -1
    scratch# for  i slot >en @ 0= if  i unloop exit  then  loop  -1 ;

command : add-layer ( w h - )   
    \ Fill the first free slot with a blank layer + active tileset
    {: w h | n :}
    the-tileset -exit              \ nothing to inherit a tileset from
    free-slot to n
    n 0< ?exit
    n slot {
        w h  this resize-tilemap
        the-tileset ts !
        1.0 prx !
        this clear-tilemap
        en on  vis on
    }
    n to layer#
    set-bounds ;

command : delete-layer ( - )   
    \ Clear the active layer and free its slot
    the-layer {  this clear-tilemap  en off  } ;

command : reorder ( n - )   
    \ Move the active layer to draw-order position n (1-10)
    1 - 0 9 clamp {: n | tm :}
    n 0 max  layer-count 1 - min to n
    the-layer to tm
    layer# the-layers removeat
    tm n the-layers insertat
    n to layer# ;

command : resize-layer ( cols rows - )
    \ Resize active layer
    the-layer resize-tilemap
    set-bounds ;

