\ GreySplatter — tile picker screen.
\ Draws the active layer's tileset sheet at the top-left (vertically scrollable);
\ click (or shift-drag) picks tile(s) into the brush; right-click picks a single
\ tile. Picking returns to the paint screen. F1 also returns.

public

: sheet-cols ( - n )  the-tileset >bmp @ bmpw  tilew / ;

\ ---- vertical scroll ---------------------------------------------------------

0 value pick-scroll                  \ pixel y offset into the sheet (>= 0)
0 value wheel-prev                   \ last absolute wheel position (for delta)

: sheet-pxh ( - n )  the-tileset >bmp @ bmph ;
: sheet-rows ( - n )  sheet-pxh tileh / ;
: scroll-max ( - n )  sheet-pxh gameh -  0 max ;
: scroll-to ( n - )  0 scroll-max clamp to pick-scroll ;
: wheel-delta ( - n )  wheel  dup wheel-prev -  swap to wheel-prev ;

: ?tiles-scroll ( - )
    wheel-delta ?dup if  tileh 3 * *  negate  pick-scroll +  scroll-to  then
    <HOME> pressed? if  0 scroll-to  then
    <END>  pressed? if  scroll-max scroll-to  then
    <PGUP> pressed? if  pick-scroll gameh -  scroll-to  then
    <PGDN> pressed? if  pick-scroll gameh +  scroll-to  then ;

\ ---- mouse -> sheet cell -----------------------------------------------------

: sheet-cell ( - col row )           \ mouse over the (scrolled) sheet
    mouse  pick-scroll +  tilew tileh 2/ ;

: in-sheet? ( - flag )               \ mouse maps inside the tileset bitmap?
    sheet-cell
    0 sheet-rows within?  swap
    0 sheet-cols within?  and ;

: sheet-index ( col row - n )
    sheet-cols * +
    0 max  the-tileset >#tiles @ 1 - min ;

: pick-single ( - )  sheet-cell sheet-index load-brush-1  ->maped ;

\ ---- shift-drag rectangle pick -----------------------------------------------

-1 value pick-startc
0  value pick-startr

: 2abs  abs swap abs swap ;

: pick-box ( - col row w h )
    pick-startc pick-startr sheet-cell 2min``
    pick-startc pick-startr sheet-cell 2- 2abs 1 1 2+``
;

: pick-rect ( - )
    {: | left top w h :}
    shift? -exit
    <lmb> pressed? if  in-sheet? if  sheet-cell to pick-startr to pick-startc  then  then
    pick-startc 0< ?exit
    <lmb> letgo? -exit
    pick-box to h to w to top to left
    w h the-brush resize-tilemap
    h 0 do
        w 0 do
            left i +  top j +  sheet-index
            i j the-brush tile!
        loop
    loop
    -1 to pick-startc
    ->maped
;

: change-tileset ( - )   \ Ctrl+O: load a PNG tileset onto the current layer
    pick-tileset
    dup 0= if  2drop 2drop exit  then       \ dialog cancelled
    evaluate  the-layer >ts !  2drop ;

: tiles-input ( - )
    ?tiles-scroll
    ctrl? if  <O> pressed? if change-tileset then  exit  then
    shift? if  pick-rect exit  then
    in-sheet? -exit
    <lmb> letgo?   if pick-single then
    <rmb> letgo?   if pick-single then
;

\ ---- draw --------------------------------------------------------------------

: tat  ( col row - )  tilew tileh 2*  pick-scroll -  at ;
: trect  ( w h - )  tilew tileh 2*  2>p rect ;

: ~tiles-ghost ( - )
    in-sheet? -exit
    <lmb> held? <rmb> held? or ?exit
    the-tileset the-brush >ts !
    sheet-cell tat
    the-brush draw
;

: ~tiles-cursor ( - )
    15 color
    shift? pick-startc 0 >= and if
        pick-box  2swap tat  trect
    else
        in-sheet? -exit
        sheet-cell tat  brushw brushh trect
    then
;

: ~tiles-info ( - )
    vga-8x8 default-font!  15 color
    0 gameh 8 - at
    in-sheet? if  sheet-cell sheet-index  else  -1  then
    brushh brushw  the-tileset body>name
    f" %s  brush %n x %n  tile %n" print
;

: ~tiles ( - )
    0 pick-scroll negate at  the-tileset >bmp @ put
    ~tiles-ghost
    ~tiles-cursor
    ~tiles-info
;

: tiles-frame ( - )  tiles-input ~tiles ;

' tiles-frame to tiles-xt
