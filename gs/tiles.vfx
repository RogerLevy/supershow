\ GreySplatter — tile picker screen.
\ Draws the active layer's tileset sheet at the top-left; click (or shift-drag)
\ picks tile(s) into the brush; right-click picks a single tile; F1 returns.

public

: sheet-cols ( - n )  the-tileset >bmp @ bmpw  tilew / ;

: sheet-cell ( - col row )   \ mouse over the sheet (drawn at 0,0, 1:1)
    mouse tilew tileh 2/ ;

: sheet-index ( col row - n )
    sheet-cols * +
    0 max  the-tileset >#tiles @ 1 - min 
;

: pick-single ( - )  sheet-cell sheet-index load-brush-1 ;

\ ---- shift-drag rectangle pick -----------------------------------------------

-1 value pick-startc
0  value pick-startr

: 2abs  abs swap abs swap ;

: pick-box ( - col row w h )
    pick-startc pick-startr sheet-cell 2min``
    pick-startc pick-startr sheet-cell 2- 2abs 1 1 2+``
;

: pick-rect ( - )
    {: | left top w h :}
    shift? -exit
    <lmb> pressed? if  sheet-cell to pick-startr to pick-startc  then
    pick-startc 0< ?exit
    <lmb> letgo? -exit
    pick-box to h to w to top to left
    w h the-brush resize-tilemap
    h 0 do
        w 0 do
            left i +  top j +  sheet-index
            i j the-brush tile!
        loop
    loop
    -1 to pick-startc 
;

: tiles-input ( - )
    shift? if  pick-rect exit  then
    <lmb> pressed? if pick-single then
    <rmb> held?    if pick-single then 
;

\ ---- draw --------------------------------------------------------------------

: tat  tilew tileh 2* at ;
: trect  tilew tileh 2* 2>p rect ;

: ~tiles-cursor ( - )
    15 color
    shift? pick-startc 0 >= and if
        pick-box  2swap tat  trect
    else
        sheet-cell tat  1 1 trect
    then 
;
 
: ~tiles-info ( - )
    vga-8x8 default-font!  15 color
    0 gameh 8 - at
    sheet-cell sheet-index  f" tile %n" print 
;

: ~tiles ( - )
    0 0 at  the-tileset >bmp @ put
    ~tiles-cursor
    ~tiles-info 
;

: tiles-frame ( - )  tiles-input ~tiles ;

' tiles-frame to tiles-xt
