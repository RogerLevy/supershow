\ GreySplatter — Supershow's level editor.
\ Entry point: declares the project tileset, opens a level from JSON, installs
\ the editor frame, and runs the paint screen. v1 = tile painting only.
\
\ Controls:
\   F1 paint   F2 tiles   i info   Ctrl+S save
\   maped: lmb paint  rmb eyedrop  Space+drag pan  Shift+drag marquee
\          Ctrl+C/X/E copy/cut/erase  1..4 layer  h/v flip  e empty brush
\   tiles: lmb/Shift-drag pick  rmb single  F1 back

module [gs]
import %supershow%/src/supershow.vfx
import %supershow%/addons/shapes.vfx
import [cjson]
import [allegro5]
include %supershow%/lib/help.vfx
include %idir%/editor.vfx
include %idir%/maped.vfx
include %idir%/tiles.vfx

: save ( - )
    save-current ;

: main ( - )
    display al_show_mouse_cursor
    s" ^ gs" evaluate  \ fixes wrong search order in turnkey
    2 user-zoom !
    tv off
    debug @ if                                              \ dev: open a sample level
        s" %supershow%/gs/dat/levels/level01.json" open-level
    else                                                    \ turnkey: start a fresh level
        new-level-or-quit
    then
    ->maped
    show> editor-frame ;

debug @ [if] main [then]
