\ ------------------------------------------------------------------------------
\ Engineer 1.0 internal version 2 (regressed)
\ ------------------------------------------------------------------------------

\ =============================================================================
\ %vfxland5% string macro
\ =============================================================================

also substitutions definitions
    cstring vfxland5
    s" %idir%\.." expand vfxland5 place
    cstring home
    cstring project
only forth definitions

\ =============================================================================
\ Core System Components
\ =============================================================================

include %idir%/checks.vfx
include %idir%/variables.vfx \ System variables
include %idir%/window.vfx

\ =============================================================================
\ Game services
\ =============================================================================

fload %idir%/../forge/lib/allegro5/graphics.vfx   \ Graphics functions
fload %idir%/../forge/lib/allegro5/vga13h.vfx     \ VGA text support (don't remove!)
fload %idir%/../forge/lib/allegro5/input.vfx      \ Input functions
fload %idir%/go.vfx         \ Main Loop
fload %idir%/repl-game.vfx  \ REPL-Game Integration (IDE-responsive game loop)
include %idir%/trampoline.vfx

\ =============================================================================
\ Reset System Classifiers
\ =============================================================================

|| : fresh,  dup , /classifier move, ;

|| create fresh-classifiers   0
    1 + %object fresh,    
    1 + %iterable fresh,
    1 + %lifo fresh,
\   1 +  %fifo fresh,
    1 + %class fresh,
    1 + %trait fresh,
    1 + %property fresh,
    1 + %static fresh,
    1 + %protocol fresh,
    1 + %array fresh,
    1 + %stack fresh,   
    1 + %global fresh,
|| constant #freshes

|| : reset+ ( a - a' )
    @+ udup ( src src dest ) /classifier move 
    /classifier + ;

|| create fresh-all-classifiers classifiers #max-classifiers cells move,

|| : reset-system-classifiers ( - )
    fresh-classifiers #freshes for reset+ loop drop
    fresh-all-classifiers classifiers #max-classifiers cells move ;

\ =============================================================================
\ Reset Root EC
\ =============================================================================

create fresh-rootec  rootec EC_MAX_SIZE move,

: reset-rootec  fresh-rootec rootec EC_MAX_SIZE move ;

\ =============================================================================
\ Entry Points  
\ =============================================================================

: init-vfx-console
    -1 line# !
    hWndMain to vfx-hwnd
    vfx-hwnd z" VFX Console" SetWindowText drop 
    consoledev op-handle ! ;

: vfxforth-entrypoint ( hinst hpinst lpcommand nshow -- res )
    [ ' EntryPoint >body @ compile, ] ;

borrow nibs>> init-nibs

: run-main ( - )
    c" main" find if execute else drop then ;

: init-engineer ( - )
    reset-format-buffers
    reset-strout-buffers
    identity 
    vga-8x8 fnt! 
    reset-rootec
    'show off ;

: reset-engineer ( - )
    init-nibs
    reset-system-classifiers
    ['] noop is onSwitchIn
    ['] run-main is boot
    honing off ;

redef : empty ( - )
    rs
    init-engineer
    reset-engineer
    only forth definitions
    empty ; 

\ Isolation tool - for verifying that modules in a project can be loaded
\ individually.
VARIABLE isolation
REDEF : MODULE  isolation @ if empty then require ;

: cartridge ( - )
    empty hold off
    s" main.vfx" fileExist? if s" main.vfx" floaded then 
    repl-go ;

also substitutions 
    aka vfxland5$ vfxland5
    aka home$ home
    aka project$ project
previous

: ?..  wd@ '\' ending s" bin" s= if s" .." $cwd then ;
: init-xrefs  +xrefs  256 1024 * xref-kb ;
: init-vfxland5-path  s" %bin%\.." expand vfxland5$ place ;
: init-paths  init-vfxland5-path  ;
: dev-init  init-xrefs init-paths ;
: init-home-path  ?.. wd@ home$ place ;

: frigid ( - )
    \ Initialize runtime environment 
    rs
    hold off
    init-home-path
    init-mersenne
    init-allegro
    *display
    init-vga-font
    0d to ustime 
    init-engineer ;

: release-entrypoint ( - )
    \ Release cold start sequence - initialize all systems and begin execution
    debug off frigid boot  blocking-go ;

: debug-entrypoint ( - )
    vfxforth-entrypoint init-vfx-console ;

\ =============================================================================
\ Turnkey creation
\ =============================================================================

: save-release ( - <path> )
    ['] release-entrypoint is EntryPoint
    debug off
    hold off
    fullscreen
    esc-quits off
    0 to GenINI?
    0 to InitSupport?
    repl-stop
    uninstall-repl-game-hook
    save-exe cr
    esc-quits on ;

: save-debug ( - <path> )
    ['] debug-entrypoint is EntryPoint
    debug on
    hold off
    windowed
    repl-stop
    uninstall-repl-game-hook
    ['] (.cold) is .cold
    -1 to GenINI?
    0 to InitSupport?
    'show off
    save-exe cr ;

\ =============================================================================
\ Development tool commands
\ =============================================================================

fload %idir%/tools.vfx
fload %idir%/ls.vfx

public
include %vfxland5%/forge/lib/back.vfx           \ Backward compatibility shim

\ =============================================================================
\ Kickoff
\ =============================================================================
public

: dev-entrypoint ( hinst hpinst lpcommand nshow -- res )
    init-nibs
    over zcount zcommand zplace
    vfxforth-entrypoint ;

: cmdline-params  zcommand zcount strip-exe ;

: dev-cold ( - )
    \ Main Engineer entry point - initialize and run with command line args
    init-vfx-console
    (.cold)
    ." ~~~ Engineer v2 (regress) ~~~ " cr cr
    dev-init
    frigid
    freeze  \ Avoids dictionary corruption after calling EMPTY
    boot 
    backup remember 
    ." Starting engine..." cr
    repl-go 
    >vfx ;

['] dev-entrypoint is EntryPoint
['] dev-cold is .cold

: save-dev ( - <path> )
    ['] dev-entrypoint is EntryPoint
    ['] dev-cold is .cold
    repl-stop
    uninstall-repl-game-hook
    hold off
    windowed
    'show off
    backup off
    -1 to GenINI?
    -1 to InitSupport?
    save-exe cr ;

gild-nib
['] main >name hidename
only forth definitions
freeze 