\ ------------------------------------------------------------------------------
\ Engineer 1.0 internal version 2 (regressed)
\ ------------------------------------------------------------------------------

module [engineer]

\ =============================================================================
\ %supershow% string macro
\ =============================================================================

also substitutions definitions
    cstring supershow
    s" %idir%\.." expand supershow place
    cstring home
    cstring project
only forth definitions

\ =============================================================================
\ Core System Components
\ =============================================================================

include %idir%/checks.vfx
include %idir%/variables.vfx \ System variables
include %idir%/window.vfx

\ =============================================================================
\ Game services
\ =============================================================================

import %idir%/../allegro5/allegro5.vfx

include %idir%/go.vfx         \ Main Loop
include %idir%/repl-game.vfx  \ REPL-Game Integration (IDE-responsive game loop)
include %idir%/trampoline.vfx

\ =============================================================================
\ Reset System Classifiers
\ =============================================================================

private

: fresh,  dup , /classifier move, ;

create fresh-classifiers   0
    1 + %object fresh,    
    1 + %iterable fresh,
    1 + %lifo fresh,
\   1 +  %fifo fresh,
    1 + %class fresh,
    1 + %trait fresh,
    1 + %property fresh,
    1 + %static fresh,
    1 + %protocol fresh,
    1 + %array fresh,
    1 + %stack fresh,
    1 + %global fresh,
    1 + %dltree fresh,
constant #freshes

: reset+ ( a - a' )
    @+ udup ( src src dest ) /classifier move 
    /classifier + ;

create fresh-all-classifiers classifiers #max-classifiers cells move,

: reset-system-classifiers ( - )
    fresh-classifiers #freshes for reset+ loop drop
    fresh-all-classifiers classifiers #max-classifiers cells move ;

\ =============================================================================
\ Reset Root EC
\ =============================================================================

private

create fresh-rootec  rootec EC_MAX_SIZE move,

: reset-rootec  fresh-rootec rootec EC_MAX_SIZE move ;

\ =============================================================================
\ Entry Points  
\ =============================================================================

private

: init-vfx-console
    -1 line# !
    hWndMain to vfx-hwnd
    vfx-hwnd z" VFX Console" SetWindowText drop 
    consoledev op-handle ! ;

: vfxforth-entrypoint ( hinst hpinst lpcommand nshow -- res )
    [ ' EntryPoint >body @ compile, ] ;

public

: run-main ( - )
    c" main" find if execute else drop then ;

: init-engineer ( - )
    reset-format-buffers
    identity 
    vga-8x8 fnt! 
    reset-rootec
    'show off ;

: reset-engineer ( - )
    init-nibs
    reset-system-classifiers
    ['] noop is onSwitchIn
    ['] run-main is boot
    honing off ;

\ Isolation tool - for verifying that modules in a project can be loaded
\ individually.
\ VARIABLE isolation
\ REDEF : MODULE  isolation @ if empty then require ;

also substitutions
    aka supershow$ supershow
    aka home$ home
    aka project$ project
previous

private

: ?..  wd@ '\' ending s" bin" s= if s" .." $cwd then ;
: init-xrefs  +xrefs  256 1024 * xref-kb ;
: init-supershow-path  s" %bin%\.." expand supershow$ place ;
: init-paths  init-supershow-path  ;
: dev-init  init-xrefs init-paths ;
: init-home-path  ?.. wd@ home$ place ;

public

redef : empty ( - )
    rs
    init-engineer
    reset-engineer
    only forth definitions
    empty ; 

: cartridge ( - )
    empty hold off
    s" main.vfx" fileExist? if s" main.vfx" included then 
    repl-go ;

: frigid ( - )
    \ Initialize runtime environment 
    rs
    hold off
    init-home-path
    init-allegro
    *display
    init-vga-font
    0d to ustime 
    init-engineer ;

\ =============================================================================
\ Turnkey creation
\ =============================================================================

private

: release-entrypoint ( - )
    \ Release cold start sequence - initialize all systems and begin execution
    debug off frigid boot  blocking-go ;

: debug-entrypoint ( - )
    vfxforth-entrypoint init-vfx-console ;

public

: save-release ( - <path> )
    ['] release-entrypoint is EntryPoint
    debug off
    hold off
    fullscreen
    esc-quits off
    0 to GenINI?
    0 to InitSupport?
    repl-stop
    uninstall-repl-game-hook
    save-exe cr
    esc-quits on ;

: save-debug ( - <path> )
    ['] debug-entrypoint is EntryPoint
    debug on
    hold off
    windowed
    repl-stop
    uninstall-repl-game-hook
    ['] (.cold) is .cold
    -1 to GenINI?
    0 to InitSupport?
    'show off
    save-exe cr ;

\ =============================================================================
\ Development tool commands
\ =============================================================================

include %idir%/tools.vfx
import %idir%/ls.vfx

\ public
\ include %supershow%/lib/back.vfx           \ Backward compatibility shim

\ =============================================================================
\ Kickoff
\ =============================================================================

private

: dev-entrypoint ( hinst hpinst lpcommand nshow -- res )
    init-nibs
    over zcount zcommand zplace
    vfxforth-entrypoint ;

: cmdline-params  zcommand zcount strip-exe ;

: dev-cold ( - )
    \ Main Engineer entry point - initialize and run with command line args
    init-vfx-console
    (.cold)
    ." ~~~ Engineer v2 (regress) ~~~ " cr cr
    dev-init
    frigid
    freeze  \ Avoids dictionary corruption after calling EMPTY
    boot 
    backup remember 
    ." Starting engine..." cr
    s" module [engineer]" evaluate 
    repl-go 
    >vfx ;

['] dev-entrypoint is EntryPoint
['] dev-cold is .cold

public

: save-dev ( - <path> )
    ['] dev-entrypoint is EntryPoint
    ['] dev-cold is .cold
    repl-stop
    uninstall-repl-game-hook
    hold off
    windowed
    'show off
    backup off
    -1 to GenINI?
    -1 to InitSupport?
    save-exe cr ;

gild-nib
['] main >name hidename
only forth definitions
freeze 