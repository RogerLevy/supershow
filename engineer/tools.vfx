module [engineer]

forth-public

\ =============================================================================
\ File loading and hot-reload
\ =============================================================================
\ ld <name|path>     Load file (no honing; redef errors if already loaded)
\ rld [<name|path>]  Reload file with honing (no arg = repeat last target)
\ ldp <project>      Load project (empty + cartridge)
\ rldp               Reload current project
\
\ Resolution (ld/rld) follows IMPORT rules:
\   [name]   -> module registry lookup (srcfile)
\   barename -> %idir%/name.vfx if exists, else name.vfx relative to cwd
\   path     -> as-is (appends .vfx if missing)
\ Resolution (ldp):
\   name/    -> name/main.vfx (directory project)
\   name     -> home/name/main.vfx, or name.vfx (direct file)
\ =============================================================================

private

: resolve-target ( a u - )
    \ Resolve name or path into ld-action$ (always stores full expanded path)
    \ Strip brackets if present
    2dup over c@ '[' = >r + 1- c@ ']' = r> and if
        1 /string 1-
    then
    {: | name[ 256 ] :}
    name[ place
    \ Module registry lookup
    name[ count resolve-module ?dup if
        module-srcfile ld-action$ place exit
    then
    \ Bare name: try %idir%/name.vfx
    name[ count bare-module-name? if
        s" %idir%/" ld-action$ place
        name[ count ld-action$ append
        s" .vfx" ld-action$ append
        ld-action$ count expanded normalize 2dup fileexists? if
            ld-action$ place exit
        then
        2drop
    then
    \ Path as-is, append .vfx if needed
    name[ count ld-action$ place
    ld-action$ count s" .vfx" strin? 0= if s" .vfx" ld-action$ append then
    ld-action$ count expanded normalize ld-action$ place ;

: do-include ( - )
    honing @ if honing-wl +order then
    ld-action$ count ['] included catch
    honing @ if honing-wl -order then
    throw ;

save-order
honing-wl +order definitions
: require include ;
: required included ;
restore-order

forth-public

: ld ( - <namespec> )
    bl parse dup 0= abort" Usage: ld <name|path>"
    resolve-target do-include ;

: rld ( - [<namespec>] )
    bl parse dup if resolve-target else 2drop then
    ld-action$ c@ 0= abort" No file loaded."
    honing on do-include honing off ;

: hone! ( a len - )
    dup 0= abort" Tried to set load action to null string."
    ld-action$ place honing on ;

: watch ( - <code> )
    context @ watch-context !
    0 parse 2dup f" :noname %s ;" evaluate watch-xt !
    watch$ place ;

: ldp ( - <namespec> )
    {: | name[ 256 ] path[ 256 ] :}
    bl parse dup 0= abort" Usage: ldp <name|path>"
    name[ place
    \ Directory with main.vfx?
    name[ count f" %s/main.vfx" fexists? if
        name[ count >abspath project$ place
        s" main.vfx" project-file$ place
    else
        \ Try home/name/main.vfx
        name[ count home$ count f" %s/%s/main.vfx" fexists? if
            name[ count home$ count f" %s/%s" >abspath project$ place
            s" main.vfx" project-file$ place
        else
            \ Direct file: path is directory, filename is target
            name[ count f" %s.vfx" fexists? if
                name[ count f" %s.vfx" fpath dup if
                    >abspath project$ place
                else
                    2drop s" ." >abspath project$ place
                then
                name[ count f" %s.vfx" -path project-file$ place
            else
                name[ count f" '%s' not found!" type cr exit
            then
        then
    then
    project$ count $cwd
    500 ms
    >vfx
    cartridge ;

: rldp ( - )
    project$ count nip 0= abort" No project loaded."
    project$ count $cwd
    cartridge ;

: +project ( - <name> )
    home$ count $cwd
    bl preparse f" spunk\project.bat %s" cr 2dup type shellcmd
    200 ms
    ldp ;

\ "pre-heating" gets a more reliable result
: .perf  process-tick ['] process-tick time? ;
