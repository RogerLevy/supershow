module [ctest]
import %idir%/../3d/model.vfx
import %idir%/../3d/cube.vfx
public

%model object thecube

\ Compile + data-build check only -- never run a drawing `main` here (the draw
\ path needs a live display; headless it 504-loops).
: check ( - )
    cube-mesh >vcount @ 36 <> abort" cube vcount != 36"
    cube-mesh thecube /model
    thecube -> msh @ cube-mesh <> abort" /model did not set msh"
    ." cube vcount=" cube-mesh >vcount @ . cr
    ." model3d + cube ok" cr ;

check
